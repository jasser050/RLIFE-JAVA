<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.NotesController"
      spacing="24" style="-fx-background-color: #020617;">

    <padding>
        <Insets top="0" right="0" bottom="24" left="0"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Notes" styleClass="text-heading"/>
            <Label text="Organize and search your study notes" styleClass="text-muted"/>
        </VBox>
        <HBox spacing="12">
            <Button text="Import" styleClass="btn-secondary">
                <graphic>
                    <FontIcon iconLiteral="fth-upload" iconSize="16"/>
                </graphic>
            </Button>
            <Button text="New Note" styleClass="btn-primary" onAction="#showNewNoteDialog">
                <graphic>
                    <FontIcon iconLiteral="fth-plus" iconSize="16" iconColor="white"/>
                </graphic>
            </Button>
        </HBox>
    </HBox>

    <!-- Stats Row -->
    <HBox spacing="16">
        <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, primary" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-file-text" iconSize="18"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="totalNotesLabel" text="0" styleClass="stat-value"/>
                    <Label text="Total Notes" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, success" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-folder" iconSize="18"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="foldersLabel" text="0" styleClass="stat-value"/>
                    <Label text="Folders" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, warning" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-star" iconSize="18"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="favoritesLabel" text="0" styleClass="stat-value"/>
                    <Label text="Favorites" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, accent" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-clock" iconSize="18"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="recentLabel" text="0" styleClass="stat-value"/>
                    <Label text="Recent" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>
    </HBox>

    <!-- Main Content -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Sidebar with folders -->
        <VBox styleClass="card" prefWidth="260" spacing="0">
            <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="8">
                <FontIcon iconLiteral="fth-folder" iconSize="16" iconColor="#A78BFA"/>
                <Label text="Folders" styleClass="card-title" HBox.hgrow="ALWAYS"/>
                <Button style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <graphic>
                        <FontIcon iconLiteral="fth-plus" iconSize="14" iconColor="#64748B"/>
                    </graphic>
                </Button>
            </HBox>
            <VBox styleClass="card-body" spacing="4" VBox.vgrow="ALWAYS">
                <VBox fx:id="foldersBox" spacing="4"/>
            </VBox>
        </VBox>

        <!-- Notes List -->
        <VBox spacing="16" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <TextField promptText="Search notes..." prefWidth="280" styleClass="search-field">
                    <HBox.margin>
                        <Insets right="8"/>
                    </HBox.margin>
                </TextField>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox styleClass="filter-tabs" spacing="0">
                    <Button text="All" styleClass="filter-tab, active"/>
                    <Button text="Recent" styleClass="filter-tab"/>
                    <Button text="Favorites" styleClass="filter-tab"/>
                </HBox>
                <HBox styleClass="filter-tabs" spacing="0">
                    <Button styleClass="filter-tab, active">
                        <graphic>
                            <FontIcon iconLiteral="fth-grid" iconSize="14"/>
                        </graphic>
                    </Button>
                    <Button styleClass="filter-tab">
                        <graphic>
                            <FontIcon iconLiteral="fth-list" iconSize="14"/>
                        </graphic>
                    </Button>
                </HBox>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;">
                <FlowPane fx:id="notesGrid" hgap="16" vgap="16" prefWrapLength="800"/>
            </ScrollPane>
        </VBox>
    </HBox>
</VBox>
