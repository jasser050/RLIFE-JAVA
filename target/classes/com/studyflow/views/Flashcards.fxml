<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.layout.AnchorPane?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.studyflow.controllers.FlashcardsController"
           style="-fx-background-color:#020617;">

    <!-- ╔══════════════════════════════════════════════════════════════╗
         ║  VIEW 1 — DECK LIST                                         ║
         ╚══════════════════════════════════════════════════════════════╝ -->
    <VBox fx:id="listView" spacing="24">
        <padding><Insets top="0" right="0" bottom="24" left="0"/></padding>

        <!-- Header + Search -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="14" HBox.hgrow="ALWAYS">
                <Label text="My Flashcards" styleClass="text-heading"/>
                <Label text="Choose a deck to study or create flashcards" styleClass="text-muted"/>

                <VBox spacing="10">
                    <!-- Row 1 : Search + Sort -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <HBox fx:id="searchBoxDeck" alignment="CENTER_LEFT" spacing="8"
                              HBox.hgrow="ALWAYS"
                              style="-fx-background-color:#0F172A;
                                     -fx-border-color:#334155;
                                     -fx-border-radius:14;-fx-background-radius:14;
                                     -fx-padding:0 14 0 12;
                                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.2),8,0,0,2);">
                            <FontIcon fx:id="searchIconDeck" iconLiteral="fth-search" iconSize="15" iconColor="#475569"/>
                            <TextField fx:id="searchDeckField"
                                       promptText="Search by title, subject, level…"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-background-color:transparent;
                                              -fx-text-fill:#F8FAFC;
                                              -fx-prompt-text-fill:#475569;
                                              -fx-border-color:transparent;
                                              -fx-padding:11 0;-fx-font-size:13px;"/>
                            <Label fx:id="searchDeckCounter" text=""
                                   style="-fx-text-fill:#334155;-fx-font-size:10px;-fx-font-weight:600;"/>
                            <Button fx:id="clearDeckSearchBtn" text=""
                                    visible="false" managed="false"
                                    style="-fx-background-color:rgba(148,163,184,0.15);
                                           -fx-background-radius:100;-fx-cursor:hand;
                                           -fx-padding:4;-fx-pref-width:22;-fx-pref-height:22;">
                                <graphic><FontIcon iconLiteral="fth-x" iconSize="10" iconColor="#94A3B8"/></graphic>
                            </Button>
                        </HBox>
                        <ComboBox fx:id="sortDeckCombo" prefWidth="155"
                                  style="-fx-background-color:#1E293B;
                                         -fx-border-color:#334155;
                                         -fx-border-radius:14;-fx-background-radius:14;
                                         -fx-font-size:12px;-fx-text-fill:#CBD5E1;
                                         -fx-padding:2 0;"/>
                    </HBox>

                    <!-- Row 2 : Active filter chips -->
                    <HBox fx:id="activeFiltersBar" spacing="8" alignment="CENTER_LEFT"
                          visible="false" managed="false">
                        <Label text="Filters:" style="-fx-text-fill:#475569;-fx-font-size:11px;-fx-font-weight:600;"/>
                        <HBox fx:id="filterChipsBox" spacing="6" alignment="CENTER_LEFT"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="deckResultCountLabel" text=""
                               style="-fx-text-fill:#475569;-fx-font-size:11px;"/>
                        <Button fx:id="clearAllFiltersBtn" text="Clear all"
                                style="-fx-background-color:rgba(251,113,133,0.12);
                                       -fx-text-fill:#FB7185;-fx-font-size:10px;
                                       -fx-font-weight:700;-fx-background-radius:8;
                                       -fx-cursor:hand;-fx-padding:4 10;"/>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>

        <!-- Stats (4 cards) -->
        <HBox spacing="16">
            <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box, primary" prefWidth="40" prefHeight="40">
                        <FontIcon iconLiteral="fth-layers" iconSize="18"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="totalDecksLabel" text="0" styleClass="stat-value"/>
                        <Label text="Total Decks" styleClass="stat-label"/>
                    </VBox>
                </HBox>
            </VBox>
            <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box, success" prefWidth="40" prefHeight="40">
                        <FontIcon iconLiteral="fth-check-circle" iconSize="18"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="masteredLabel" text="0" styleClass="stat-value"/>
                        <Label text="Cards Mastered" styleClass="stat-label"/>
                    </VBox>
                </HBox>
            </VBox>
            <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box, warning" prefWidth="40" prefHeight="40">
                        <FontIcon iconLiteral="fth-clock" iconSize="18"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="dueReviewLabel" text="0" styleClass="stat-value"/>
                        <Label text="Due for Review" styleClass="stat-label"/>
                    </VBox>
                </HBox>
            </VBox>
            <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box, accent" prefWidth="40" prefHeight="40">
                        <FontIcon iconLiteral="fth-zap" iconSize="18"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="streakLabel" text="0" styleClass="stat-value"/>
                        <Label text="Day Streak" styleClass="stat-label"/>
                    </VBox>
                </HBox>
            </VBox>
        </HBox>

        <!-- Decks + Quick Study panel -->
        <HBox spacing="20" VBox.vgrow="ALWAYS">
            <VBox spacing="16" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Your Decks" styleClass="text-subheading" HBox.hgrow="ALWAYS"/>
                    <!-- View mode toggle -->
                    <HBox spacing="4" alignment="CENTER"
                          style="-fx-background-color:#1E293B;-fx-background-radius:10;-fx-padding:3;">
                        <ToggleButton fx:id="gridViewBtn" userData="grid"
                                      style="-fx-background-color:rgba(124,58,237,0.2);-fx-background-radius:8;
                                             -fx-cursor:hand;-fx-padding:5 9;">
                            <graphic><FontIcon iconLiteral="fth-grid" iconSize="13" iconColor="#A78BFA"/></graphic>
                        </ToggleButton>
                        <ToggleButton fx:id="listViewBtn" userData="list"
                                      style="-fx-background-color:transparent;-fx-background-radius:8;
                                             -fx-cursor:hand;-fx-padding:5 9;">
                            <graphic><FontIcon iconLiteral="fth-list" iconSize="13" iconColor="#64748B"/></graphic>
                        </ToggleButton>
                    </HBox>
                    <!-- Tabs: All / In Progress / Mastered -->
                    <HBox styleClass="filter-tabs" spacing="0">
                        <Button fx:id="tabAll"        text="All"         styleClass="filter-tab, active"/>
                        <Button fx:id="tabInProgress" text="In Progress" styleClass="filter-tab"/>
                        <Button fx:id="tabMastered"   text="Mastered"    styleClass="filter-tab"/>
                    </HBox>
                </HBox>

                <!-- Empty state -->
                <VBox fx:id="emptySearchState" alignment="CENTER" spacing="16"
                      visible="false" managed="false" style="-fx-padding:60 0;">
                    <FontIcon iconLiteral="fth-search" iconSize="48" iconColor="#1E293B"/>
                    <Label fx:id="emptySearchLabel" text="No decks match your search"
                           style="-fx-text-fill:#475569;-fx-font-size:14px;-fx-font-weight:600;"/>
                    <Label text="Try different keywords or clear the filters"
                           style="-fx-text-fill:#334155;-fx-font-size:12px;"/>
                    <Button fx:id="resetSearchBtn" text="Reset Search"
                            style="-fx-background-color:#1E293B;-fx-text-fill:#A78BFA;
                                   -fx-font-size:12px;-fx-font-weight:700;
                                   -fx-background-radius:10;-fx-cursor:hand;-fx-padding:9 20;
                                   -fx-border-color:#334155;-fx-border-radius:10;-fx-border-width:1;"/>
                </VBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color:transparent;-fx-background:transparent;">
                    <FlowPane fx:id="decksGrid" hgap="16" vgap="16" prefWrapLength="800"/>
                </ScrollPane>
            </VBox>

            <!-- Quick Study panel -->
            <VBox styleClass="card" prefWidth="320" spacing="0">
                <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box, primary" prefWidth="36" prefHeight="36">
                        <FontIcon iconLiteral="fth-play-circle" iconSize="16"/>
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Quick Study" styleClass="card-title"/>
                        <Label text="Start a review session" styleClass="text-small"/>
                    </VBox>
                </HBox>
                <VBox styleClass="card-body" spacing="16" VBox.vgrow="ALWAYS">
                    <VBox spacing="12">
                        <Label text="Today's Progress"
                               style="-fx-text-fill:#94A3B8;-fx-font-size:12px;-fx-font-weight:600;"/>
                        <HBox spacing="16">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label fx:id="reviewedTodayLabel" text="0"
                                       style="-fx-text-fill:#10B981;-fx-font-size:24px;-fx-font-weight:700;"/>
                                <Label text="Reviewed" style="-fx-text-fill:#64748B;-fx-font-size:11px;"/>
                            </VBox>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label fx:id="remainingTodayLabel" text="0"
                                       style="-fx-text-fill:#FBBF24;-fx-font-size:24px;-fx-font-weight:700;"/>
                                <Label text="Remaining" style="-fx-text-fill:#64748B;-fx-font-size:11px;"/>
                            </VBox>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label fx:id="accuracyLabel" text="0%"
                                       style="-fx-text-fill:#8B5CF6;-fx-font-size:24px;-fx-font-weight:700;"/>
                                <Label text="Accuracy" style="-fx-text-fill:#64748B;-fx-font-size:11px;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <Region style="-fx-background-color:#1E293B;-fx-pref-height:1;"/>
                    <VBox spacing="8" VBox.vgrow="ALWAYS">
                        <Label text="Decks Due Today"
                               style="-fx-text-fill:#94A3B8;-fx-font-size:12px;-fx-font-weight:600;"/>
                        <VBox fx:id="dueDecksBox" spacing="8"/>
                    </VBox>
                </VBox>
            </VBox>
        </HBox>
    </VBox>

    <!-- ╔══════════════════════════════════════════════════════════════╗
         ║  VIEW 2 — FLASHCARD LIST (stylish hero centré)             ║
         ╚══════════════════════════════════════════════════════════════╝ -->
    <VBox fx:id="flashcardsView" spacing="20" visible="false" managed="false">
        <padding><Insets top="0" right="0" bottom="24" left="0"/></padding>

        <!-- ── HERO CENTRÉ (AnchorPane pour positionner le bouton back) ── -->
        <AnchorPane fx:id="deckHeroPane"
                    style="-fx-background-color:linear-gradient(to bottom right,#0F172A,#130926,#0F172A);
                           -fx-background-radius:24;
                           -fx-border-color:#1E293B;
                           -fx-border-radius:24;
                           -fx-border-width:1;
                           -fx-min-height:320;">

            <!-- Bouton retour — ancré en haut à gauche -->
            <Button onAction="#goBackToList"
                    AnchorPane.topAnchor="16" AnchorPane.leftAnchor="16"
                    style="-fx-background-color:#1E293B;
                           -fx-text-fill:#94A3B8;
                           -fx-font-size:12px;-fx-font-weight:600;
                           -fx-background-radius:10;-fx-cursor:hand;
                           -fx-padding:8 16;
                           -fx-border-color:#334155;-fx-border-radius:10;-fx-border-width:1;">
                <graphic><FontIcon iconLiteral="fth-arrow-left" iconSize="14" iconColor="#94A3B8"/></graphic>
            </Button>

            <!-- Contenu centré — rempli toute la largeur -->
            <VBox alignment="CENTER" spacing="18"
                  AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                  AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
                  style="-fx-padding:36 28 28 28;">

                <!-- Icône du deck — dynamique via fx:id -->
                <StackPane fx:id="deckIconBox" prefWidth="72" prefHeight="72"
                           style="-fx-background-color:linear-gradient(to bottom right,#7C3AED,#6D28D9);
                                  -fx-background-radius:20;
                                  -fx-effect:dropshadow(gaussian,rgba(124,58,237,0.55),28,0,0,0);">
                    <FontIcon fx:id="deckIconGlyph" iconLiteral="fth-layers" iconSize="30" iconColor="white"/>
                </StackPane>

                <!-- Titre du deck — grand, centré -->
                <Label fx:id="deckTitleLabel" text=""
                       style="-fx-text-fill:#F8FAFC;
                              -fx-font-size:28px;-fx-font-weight:800;
                              -fx-alignment:CENTER;-fx-text-alignment:CENTER;"/>

                <!-- Sous-titre matière • niveau -->
                <HBox alignment="CENTER" spacing="8">
                    <Label fx:id="deckSubLabel" text=""
                           style="-fx-background-color:rgba(124,58,237,0.18);
                                  -fx-text-fill:#A78BFA;
                                  -fx-font-size:12px;-fx-font-weight:700;
                                  -fx-padding:4 14;-fx-background-radius:20;"/>
                </HBox>

                <!-- Stats bar -->
                <HBox alignment="CENTER" spacing="16">
                    <VBox alignment="CENTER" spacing="3"
                          style="-fx-background-color:rgba(15,23,42,0.7);
                                 -fx-border-color:#1E293B;-fx-border-radius:14;
                                 -fx-background-radius:14;-fx-padding:12 22;">
                        <Label fx:id="fcTotalLabel" text="0"
                               style="-fx-text-fill:#A78BFA;-fx-font-size:22px;-fx-font-weight:800;"/>
                        <Label text="Total"
                               style="-fx-text-fill:#475569;-fx-font-size:10px;-fx-font-weight:700;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="3"
                          style="-fx-background-color:rgba(15,23,42,0.7);
                                 -fx-border-color:#1E293B;-fx-border-radius:14;
                                 -fx-background-radius:14;-fx-padding:12 22;">
                        <Label fx:id="fcMasteredLabel" text="0"
                               style="-fx-text-fill:#34D399;-fx-font-size:22px;-fx-font-weight:800;"/>
                        <Label text="Mastered"
                               style="-fx-text-fill:#475569;-fx-font-size:10px;-fx-font-weight:700;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="3"
                          style="-fx-background-color:rgba(15,23,42,0.7);
                                 -fx-border-color:#1E293B;-fx-border-radius:14;
                                 -fx-background-radius:14;-fx-padding:12 22;">
                        <Label fx:id="fcLearningLabel" text="0"
                               style="-fx-text-fill:#FBBF24;-fx-font-size:22px;-fx-font-weight:800;"/>
                        <Label text="Learning"
                               style="-fx-text-fill:#475569;-fx-font-size:10px;-fx-font-weight:700;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="3"
                          style="-fx-background-color:rgba(15,23,42,0.7);
                                 -fx-border-color:#1E293B;-fx-border-radius:14;
                                 -fx-background-radius:14;-fx-padding:12 22;">
                        <Label fx:id="fcNewLabel" text="0"
                               style="-fx-text-fill:#94A3B8;-fx-font-size:22px;-fx-font-weight:800;"/>
                        <Label text="New"
                               style="-fx-text-fill:#475569;-fx-font-size:10px;-fx-font-weight:700;"/>
                    </VBox>
                </HBox>

                <!-- Bouton Add -->
                <HBox alignment="CENTER" spacing="12">
                    <Button text="Add Flashcard" onAction="#showAddFlashcardForm"
                            style="-fx-background-color:linear-gradient(to right,#7C3AED,#6D28D9);
                                   -fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:700;
                                   -fx-background-radius:13;-fx-cursor:hand;-fx-padding:12 26;
                                   -fx-effect:dropshadow(gaussian,rgba(124,58,237,0.45),14,0,0,4);">
                        <graphic><FontIcon iconLiteral="fth-plus" iconSize="15" iconColor="white"/></graphic>
                    </Button>
                </HBox>
            </VBox>
        </AnchorPane>

        <!-- ── TOOLBAR ── -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label fx:id="fcCountLabel" text="0 cards"
                   style="-fx-background-color:#1E293B;-fx-text-fill:#A78BFA;
                          -fx-font-size:12px;-fx-font-weight:700;
                          -fx-padding:6 14;-fx-background-radius:20;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="sortFcCombo" prefWidth="160" promptText="Sort cards…"
                      style="-fx-background-color:#1E293B;-fx-border-color:#334155;
                             -fx-border-radius:10;-fx-background-radius:10;-fx-font-size:12px;"/>
        </HBox>

        <!-- ── SEARCH BAR ── -->
        <VBox spacing="8">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <HBox fx:id="searchBoxFc" alignment="CENTER_LEFT" spacing="0"
                      HBox.hgrow="ALWAYS"
                      style="-fx-background-color:#0F172A;
                             -fx-border-color:#1E293B;
                             -fx-border-radius:14;-fx-background-radius:14;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.2),6,0,0,2);">
                    <ComboBox fx:id="searchScopeFc" prefWidth="120"
                              style="-fx-background-color:#1E293B;-fx-border-color:transparent;
                                     -fx-border-radius:14 0 0 14;-fx-background-radius:14 0 0 14;
                                     -fx-font-size:11px;-fx-font-weight:600;
                                     -fx-text-fill:#94A3B8;-fx-padding:2 0;"/>
                    <Region style="-fx-background-color:#334155;-fx-pref-width:1;-fx-pref-height:26;"/>
                    <FontIcon iconLiteral="fth-search" iconSize="14" iconColor="#475569"
                              style="-fx-padding:0 10 0 12;"/>
                    <TextField fx:id="searchFcField"
                               promptText="Type to search flashcards…"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color:transparent;
                                      -fx-text-fill:#F8FAFC;
                                      -fx-prompt-text-fill:#475569;
                                      -fx-border-color:transparent;
                                      -fx-padding:11 0;-fx-font-size:13px;"/>
                    <Label fx:id="fcMatchCount" text=""
                           style="-fx-background-color:#1E293B;-fx-text-fill:#64748B;
                                  -fx-font-size:10px;-fx-font-weight:700;
                                  -fx-padding:3 8;-fx-background-radius:20;"/>
                    <Button fx:id="clearFcSearchBtn" text=""
                            visible="false" managed="false"
                            style="-fx-background-color:rgba(148,163,184,0.12);
                                   -fx-background-radius:100;-fx-cursor:hand;
                                   -fx-padding:4;-fx-pref-width:22;-fx-pref-height:22;">
                        <graphic><FontIcon iconLiteral="fth-x" iconSize="10" iconColor="#94A3B8"/></graphic>
                    </Button>
                    <Region style="-fx-pref-width:8;"/>
                </HBox>
                <ComboBox fx:id="filterEtat" prefWidth="145"
                          style="-fx-background-color:#0F172A;-fx-border-color:#1E293B;
                                 -fx-border-radius:14;-fx-background-radius:14;-fx-font-size:12px;"/>
                <ComboBox fx:id="filterDifficulty" prefWidth="145" promptText="Difficulty…"
                          style="-fx-background-color:#0F172A;-fx-border-color:#1E293B;
                                 -fx-border-radius:14;-fx-background-radius:14;-fx-font-size:12px;"/>
            </HBox>

            <HBox fx:id="fcFiltersBar" spacing="8" alignment="CENTER_LEFT"
                  visible="false" managed="false">
                <Label text="Active:" style="-fx-text-fill:#475569;-fx-font-size:11px;-fx-font-weight:600;"/>
                <HBox fx:id="fcChipsBox" spacing="6" alignment="CENTER_LEFT"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="fcFilterResultCount" text=""
                       style="-fx-text-fill:#475569;-fx-font-size:11px;"/>
                <Button fx:id="clearFcFiltersBtn" text="Clear all"
                        style="-fx-background-color:rgba(251,113,133,0.12);
                               -fx-text-fill:#FB7185;-fx-font-size:10px;
                               -fx-font-weight:700;-fx-background-radius:8;
                               -fx-cursor:hand;-fx-padding:4 10;"/>
            </HBox>
        </VBox>

        <!-- ── GRILLE DE FLASHCARDS ── -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color:transparent;-fx-background:transparent;">
            <FlowPane fx:id="flashcardsGrid" hgap="16" vgap="16" prefWrapLength="900"/>
        </ScrollPane>
    </VBox>

    <!-- VIEW 3 — Form (loaded dynamically) -->
    <StackPane fx:id="formHost" visible="false" managed="false"/>

</StackPane>
