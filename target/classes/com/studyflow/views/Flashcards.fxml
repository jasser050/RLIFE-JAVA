<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.studyflow.controllers.FlashcardsController"
           style="-fx-background-color:#020617;">

    <!-- VIEW 1 – DECK LIST -->
    <VBox fx:id="listView" spacing="24">
        <padding><Insets top="0" right="0" bottom="24" left="0"/></padding>
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="14" HBox.hgrow="ALWAYS">
                <Label text="My Flashcards" styleClass="text-heading"/>
                <Label text="Choose a deck to study or create flashcards" styleClass="text-muted"/>
                <VBox spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <HBox fx:id="searchBoxDeck" alignment="CENTER_LEFT" spacing="8"
                              HBox.hgrow="ALWAYS"
                              style="-fx-background-color:#0F172A;-fx-border-color:#334155;
                                     -fx-border-radius:14;-fx-background-radius:14;
                                     -fx-padding:0 14 0 12;
                                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.2),8,0,0,2);">
                            <FontIcon fx:id="searchIconDeck" iconLiteral="fth-search" iconSize="15" iconColor="#475569"
                                      mouseTransparent="true"/>
                            <TextField fx:id="searchDeckField" promptText="Search by title, subject, level…"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-background-color:transparent;-fx-text-fill:#F8FAFC;
                                              -fx-prompt-text-fill:#475569;-fx-border-color:transparent;
                                              -fx-padding:11 0;-fx-font-size:13px;"/>
                            <Label fx:id="searchDeckCounter" text=""
                                   style="-fx-text-fill:#334155;-fx-font-size:10px;-fx-font-weight:600;"/>
                            <Button fx:id="clearDeckSearchBtn" text="" visible="false" managed="false"
                                    style="-fx-background-color:rgba(148,163,184,0.15);-fx-background-radius:100;
                                           -fx-cursor:hand;-fx-padding:4;-fx-pref-width:22;-fx-pref-height:22;">
                                <graphic><FontIcon iconLiteral="fth-x" iconSize="10" iconColor="#94A3B8"/></graphic>
                            </Button>
                        </HBox>
                        <ComboBox fx:id="sortDeckCombo" prefWidth="155"
                                  style="-fx-background-color:#1E293B;-fx-border-color:#334155;
                                         -fx-border-radius:14;-fx-background-radius:14;
                                         -fx-font-size:12px;-fx-text-fill:#CBD5E1;-fx-padding:2 0;"/>
                    </HBox>
                    <HBox fx:id="activeFiltersBar" spacing="8" alignment="CENTER_LEFT"
                          visible="false" managed="false">
                        <Label text="Filters:" style="-fx-text-fill:#475569;-fx-font-size:11px;-fx-font-weight:600;"/>
                        <HBox fx:id="filterChipsBox" spacing="6" alignment="CENTER_LEFT"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="deckResultCountLabel" text="" style="-fx-text-fill:#475569;-fx-font-size:11px;"/>
                        <Button fx:id="clearAllFiltersBtn" text="Clear all"
                                style="-fx-background-color:rgba(251,113,133,0.12);-fx-text-fill:#FB7185;
                                       -fx-font-size:10px;-fx-font-weight:700;-fx-background-radius:8;
                                       -fx-cursor:hand;-fx-padding:4 10;"/>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>

        <!-- Stats -->
        <HBox spacing="16">
            <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box, primary" prefWidth="40" prefHeight="40">
                        <FontIcon iconLiteral="fth-layers" iconSize="18"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="totalDecksLabel" text="0" styleClass="stat-value"/>
                        <Label text="Total Decks" styleClass="stat-label"/>
                    </VBox>
                </HBox>
            </VBox>
            <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box, success" prefWidth="40" prefHeight="40">
                        <FontIcon iconLiteral="fth-check-circle" iconSize="18"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="masteredLabel" text="0" styleClass="stat-value"/>
                        <Label text="Cards Mastered" styleClass="stat-label"/>
                    </VBox>
                </HBox>
            </VBox>
            <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box, warning" prefWidth="40" prefHeight="40">
                        <FontIcon iconLiteral="fth-clock" iconSize="18"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="dueReviewLabel" text="0" styleClass="stat-value"/>
                        <Label text="Due for Review" styleClass="stat-label"/>
                    </VBox>
                </HBox>
            </VBox>
            <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box, accent" prefWidth="40" prefHeight="40">
                        <FontIcon iconLiteral="fth-zap" iconSize="18"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="streakLabel" text="0" styleClass="stat-value"/>
                        <Label text="Day Streak" styleClass="stat-label"/>
                    </VBox>
                </HBox>
            </VBox>
        </HBox>

        <!-- Decks + Quick Study -->
        <HBox fx:id="deckStudyRow" alignment="TOP_LEFT" spacing="0" VBox.vgrow="ALWAYS">
            <VBox fx:id="decksColumn" spacing="16" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Your Decks" styleClass="text-subheading" HBox.hgrow="ALWAYS"/>
                    <HBox spacing="4" alignment="CENTER"
                          style="-fx-background-color:#1E293B;-fx-background-radius:10;-fx-padding:3;">
                        <ToggleButton fx:id="gridViewBtn" userData="grid"
                                      style="-fx-background-color:rgba(124,58,237,0.2);-fx-background-radius:8;-fx-cursor:hand;-fx-padding:5 9;">
                            <graphic><FontIcon iconLiteral="fth-grid" iconSize="13" iconColor="#A78BFA"/></graphic>
                        </ToggleButton>
                        <ToggleButton fx:id="listViewBtn" userData="list"
                                      style="-fx-background-color:transparent;-fx-background-radius:8;-fx-cursor:hand;-fx-padding:5 9;">
                            <graphic><FontIcon iconLiteral="fth-list" iconSize="13" iconColor="#64748B"/></graphic>
                        </ToggleButton>
                    </HBox>
                    <HBox styleClass="filter-tabs" spacing="0">
                        <Button fx:id="tabAll" text="All" styleClass="filter-tab, active"/>
                        <Button fx:id="tabInProgress" text="In Progress" styleClass="filter-tab"/>
                        <Button fx:id="tabMastered" text="Mastered" styleClass="filter-tab"/>
                    </HBox>
                </HBox>
                <VBox fx:id="emptySearchState" alignment="CENTER" spacing="16"
                      visible="false" managed="false" style="-fx-padding:60 0;">
                    <FontIcon iconLiteral="fth-search" iconSize="48" iconColor="#1E293B"/>
                    <Label fx:id="emptySearchLabel" text="No decks match your search"
                           style="-fx-text-fill:#475569;-fx-font-size:14px;-fx-font-weight:600;"/>
                    <Label text="Try different keywords or clear the filters"
                           style="-fx-text-fill:#334155;-fx-font-size:12px;"/>
                    <Button fx:id="resetSearchBtn" text="Reset Search"
                            style="-fx-background-color:#1E293B;-fx-text-fill:#A78BFA;-fx-font-size:12px;
                                   -fx-font-weight:700;-fx-background-radius:10;-fx-cursor:hand;-fx-padding:9 20;
                                   -fx-border-color:#334155;-fx-border-radius:10;-fx-border-width:1;"/>
                </VBox>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color:transparent;-fx-background:transparent;-fx-padding:0;">
                    <FlowPane fx:id="decksGrid" hgap="16" vgap="16" prefWrapLength="800"/>
                </ScrollPane>
            </VBox>

            <!-- Quick Study panel -->
            <VBox fx:id="quickStudyPanel" styleClass="card" prefWidth="340" minWidth="340" spacing="0" HBox.hgrow="ALWAYS">
                <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box, primary" prefWidth="36" prefHeight="36">
                        <FontIcon iconLiteral="fth-play-circle" iconSize="16"/>
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Quick Study" styleClass="card-title"/>
                        <Label text="Start a review session" styleClass="text-small"/>
                    </VBox>
                </HBox>
                <VBox styleClass="card-body" spacing="16" VBox.vgrow="ALWAYS">
                    <VBox spacing="12">
                        <Label text="Today's Progress"
                               style="-fx-text-fill:#94A3B8;-fx-font-size:12px;-fx-font-weight:600;"/>
                        <HBox spacing="16">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label fx:id="reviewedTodayLabel" text="0"
                                       style="-fx-text-fill:#10B981;-fx-font-size:24px;-fx-font-weight:700;"/>
                                <Label text="Reviewed" style="-fx-text-fill:#64748B;-fx-font-size:11px;"/>
                            </VBox>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label fx:id="remainingTodayLabel" text="0"
                                       style="-fx-text-fill:#FBBF24;-fx-font-size:24px;-fx-font-weight:700;"/>
                                <Label text="Remaining" style="-fx-text-fill:#64748B;-fx-font-size:11px;"/>
                            </VBox>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label fx:id="accuracyLabel" text="0%"
                                       style="-fx-text-fill:#8B5CF6;-fx-font-size:24px;-fx-font-weight:700;"/>
                                <Label text="Accuracy" style="-fx-text-fill:#64748B;-fx-font-size:11px;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <Region style="-fx-background-color:#1E293B;-fx-pref-height:1;"/>
                    <VBox spacing="8" VBox.vgrow="ALWAYS">
                        <Label text="Decks Due Today"
                               style="-fx-text-fill:#94A3B8;-fx-font-size:12px;-fx-font-weight:600;"/>
                        <VBox fx:id="dueDecksBox" spacing="8"/>
                    </VBox>
                </VBox>
            </VBox>
        </HBox>
    </VBox>

    <!-- VIEW 2 – FLASHCARD LIST -->
    <VBox fx:id="flashcardsView" spacing="20" visible="false" managed="false">
        <padding><Insets top="0" right="0" bottom="24" left="0"/></padding>

        <!-- UNIFIED TOP BAR – without Add and Generate with AI buttons -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <!-- Back button -->
            <Button onAction="#goBackToList"
                    style="-fx-background-color:#1E293B;-fx-background-radius:10;-fx-cursor:hand;
                           -fx-padding:8 12;-fx-border-color:#334155;-fx-border-radius:10;-fx-border-width:1;">
                <graphic><FontIcon iconLiteral="fth-arrow-left" iconSize="14" iconColor="#94A3B8"/></graphic>
            </Button>
            <Label text="Back" style="-fx-text-fill:#CBD5E1;-fx-font-size:12px;-fx-font-weight:700;"/>

            <!-- Card count badge -->
            <Label fx:id="fcCountLabel" text="0 cards"
                   style="-fx-background-color:#1E293B;-fx-text-fill:#A78BFA;
                          -fx-font-size:11px;-fx-font-weight:700;
                          -fx-padding:5 12;-fx-background-radius:20;"/>

            <!-- Search box -->
            <HBox fx:id="searchBoxFc" alignment="CENTER_LEFT" spacing="0"
                  HBox.hgrow="ALWAYS"
                  style="-fx-background-color:#0F172A;-fx-border-color:#1E293B;
                         -fx-border-radius:14;-fx-background-radius:14;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.2),6,0,0,2);">
                <ComboBox fx:id="searchScopeFc" prefWidth="108"
                          style="-fx-background-color:#1E293B;-fx-border-color:transparent;
                                 -fx-border-radius:14 0 0 14;-fx-background-radius:14 0 0 14;
                                 -fx-font-size:11px;-fx-font-weight:600;-fx-text-fill:#94A3B8;-fx-padding:2 0;"/>
                <Region style="-fx-background-color:#334155;-fx-pref-width:1;-fx-pref-height:24;"/>
                <FontIcon iconLiteral="fth-search" iconSize="13" iconColor="#475569" mouseTransparent="true"
                          style="-fx-padding:0 8 0 10;"/>
                <TextField fx:id="searchFcField" promptText="Search flashcards…"
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-color:transparent;-fx-text-fill:#F8FAFC;
                                  -fx-prompt-text-fill:#475569;-fx-border-color:transparent;
                                  -fx-padding:9 0;-fx-font-size:12px;"/>
                <Label fx:id="fcMatchCount" text=""
                       style="-fx-background-color:#1E293B;-fx-text-fill:#64748B;
                              -fx-font-size:10px;-fx-font-weight:700;
                              -fx-padding:3 8;-fx-background-radius:20;"/>
                <Button fx:id="clearFcSearchBtn" text="" visible="false" managed="false"
                        style="-fx-background-color:rgba(148,163,184,0.12);-fx-background-radius:100;
                               -fx-cursor:hand;-fx-padding:4;-fx-pref-width:22;-fx-pref-height:22;">
                    <graphic><FontIcon iconLiteral="fth-x" iconSize="10" iconColor="#94A3B8"/></graphic>
                </Button>
                <Region style="-fx-pref-width:6;"/>
            </HBox>

            <!-- Status filter -->
            <ComboBox fx:id="filterEtat" prefWidth="128"
                      style="-fx-background-color:#0F172A;-fx-border-color:#1E293B;
                             -fx-border-radius:14;-fx-background-radius:14;-fx-font-size:11px;"/>

            <!-- Difficulty filter -->
            <ComboBox fx:id="filterDifficulty" prefWidth="128" promptText="Difficulty…"
                      style="-fx-background-color:#0F172A;-fx-border-color:#1E293B;
                             -fx-border-radius:14;-fx-background-radius:14;-fx-font-size:11px;"/>

            <!-- Sort combo -->
            <ComboBox fx:id="sortFcCombo" prefWidth="138" promptText="Sort cards…"
                      style="-fx-background-color:#1E293B;-fx-border-color:#334155;
                             -fx-border-radius:10;-fx-background-radius:10;-fx-font-size:11px;"/>
        </HBox>

        <!-- Active filter chips bar -->
        <HBox fx:id="fcFiltersBar" spacing="8" alignment="CENTER_LEFT"
              visible="false" managed="false">
            <Label text="Active:" style="-fx-text-fill:#475569;-fx-font-size:11px;-fx-font-weight:600;"/>
            <HBox fx:id="fcChipsBox" spacing="6" alignment="CENTER_LEFT"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="fcFilterResultCount" text="" style="-fx-text-fill:#475569;-fx-font-size:11px;"/>
            <Button fx:id="clearFcFiltersBtn" text="Clear all"
                    style="-fx-background-color:rgba(251,113,133,0.12);-fx-text-fill:#FB7185;
                           -fx-font-size:10px;-fx-font-weight:700;-fx-background-radius:8;
                           -fx-cursor:hand;-fx-padding:4 10;"/>
        </HBox>

        <!-- HERO COMPACT -->
        <HBox fx:id="deckHeroPane" spacing="0" alignment="CENTER_LEFT"
              style="-fx-background-color:linear-gradient(to bottom right,#0F172A,#130926,#0F172A);
                      -fx-background-radius:18;-fx-border-color:#1E293B;
                      -fx-border-radius:18;-fx-border-width:1;
                      -fx-min-height:168;-fx-max-height:190;">
            <StackPane fx:id="deckIconBox" prefWidth="130" prefHeight="130"
                       style="-fx-background-color:linear-gradient(to bottom right,#7C3AED,#6D28D9);
                              -fx-background-radius:18 0 0 18;">
                <FontIcon fx:id="deckIconGlyph" iconLiteral="fth-layers" iconSize="28" iconColor="white"/>
            </StackPane>
            <VBox spacing="6" HBox.hgrow="ALWAYS" style="-fx-padding:12 16;">
                <Label fx:id="deckTitleLabel" text=""
                       style="-fx-text-fill:#F8FAFC;-fx-font-size:17px;-fx-font-weight:800;"/>
                <Label fx:id="deckSubLabel" text=""
                       style="-fx-background-color:rgba(124,58,237,0.18);-fx-text-fill:#A78BFA;
                              -fx-font-size:11px;-fx-font-weight:700;
                              -fx-padding:3 10;-fx-background-radius:20;"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <VBox alignment="CENTER" spacing="1"
                          style="-fx-background-color:rgba(15,23,42,0.7);-fx-border-color:#1E293B;
                                 -fx-border-radius:10;-fx-background-radius:10;-fx-padding:5 12;">
                        <Label fx:id="fcTotalLabel" text="0"
                               style="-fx-text-fill:#A78BFA;-fx-font-size:15px;-fx-font-weight:800;"/>
                        <Label text="Total" style="-fx-text-fill:#475569;-fx-font-size:9px;-fx-font-weight:700;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="1"
                          style="-fx-background-color:rgba(15,23,42,0.7);-fx-border-color:#1E293B;
                                 -fx-border-radius:10;-fx-background-radius:10;-fx-padding:5 12;">
                        <Label fx:id="fcMasteredLabel" text="0"
                               style="-fx-text-fill:#34D399;-fx-font-size:15px;-fx-font-weight:800;"/>
                        <Label text="Mastered" style="-fx-text-fill:#475569;-fx-font-size:9px;-fx-font-weight:700;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="1"
                          style="-fx-background-color:rgba(15,23,42,0.7);-fx-border-color:#1E293B;
                                 -fx-border-radius:10;-fx-background-radius:10;-fx-padding:5 12;">
                        <Label fx:id="fcLearningLabel" text="0"
                               style="-fx-text-fill:#FBBF24;-fx-font-size:15px;-fx-font-weight:800;"/>
                        <Label text="Learning" style="-fx-text-fill:#475569;-fx-font-size:9px;-fx-font-weight:700;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="1"
                          style="-fx-background-color:rgba(15,23,42,0.7);-fx-border-color:#1E293B;
                                 -fx-border-radius:10;-fx-background-radius:10;-fx-padding:5 12;">
                        <Label fx:id="fcNewLabel" text="0"
                               style="-fx-text-fill:#94A3B8;-fx-font-size:15px;-fx-font-weight:800;"/>
                        <Label text="New" style="-fx-text-fill:#475569;-fx-font-size:9px;-fx-font-weight:700;"/>
                    </VBox>
                </HBox>
            </VBox>
        </HBox>

        <!-- Flashcards card – Generate with AI button REMOVED -->
        <VBox styleClass="card" spacing="0" VBox.vgrow="ALWAYS">
            <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, accent" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-book-open" iconSize="18"/>
                </StackPane>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Flashcards List" styleClass="card-title"/>
                    <Label text="Browse and manage flashcards for this deck." styleClass="text-small"/>
                </VBox>
            </HBox>
            <VBox styleClass="card-body" spacing="0" VBox.vgrow="ALWAYS">
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color:transparent;-fx-background:transparent;">
                    <FlowPane fx:id="flashcardsGrid" hgap="16" vgap="16" prefWrapLength="900"/>
                </ScrollPane>
            </VBox>
        </VBox>
    </VBox>

    <!-- VIEW 2B – RATING VIEW -->
    <VBox fx:id="ratingView" spacing="22" visible="false" managed="false">
        <padding><Insets top="0" right="0" bottom="24" left="0"/></padding>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Button onAction="#handleRatingBack"
                    style="-fx-background-color:#1E293B;-fx-background-radius:10;-fx-cursor:hand;-fx-padding:8 12;-fx-border-color:#334155;-fx-border-radius:10;-fx-border-width:1;">
                <graphic><FontIcon iconLiteral="fth-arrow-left" iconSize="14" iconColor="#94A3B8"/></graphic>
            </Button>
            <Label text="My Flashcards" style="-fx-text-fill:#475569;-fx-font-size:13px;"/>
            <Label text="›" style="-fx-text-fill:#334155;-fx-font-size:14px;"/>
            <Label text="Deck Rating" style="-fx-text-fill:#F8FAFC;-fx-font-size:13px;-fx-font-weight:700;"/>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Rate This Deck" styleClass="text-heading"/>
                <Label text="Open a deck rating page, select 1 to 5, then save your feedback." styleClass="text-muted"/>
            </VBox>
        </HBox>
        <VBox styleClass="card" spacing="0">
            <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, accent" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-star" iconSize="18"/>
                </StackPane>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label fx:id="ratingDeckTitleLabel" text="Deck rating" styleClass="card-title"/>
                    <Label fx:id="ratingDeckMetaLabel" text="Choose a deck from My Flashcards." styleClass="text-small"/>
                </VBox>
            </HBox>
            <VBox styleClass="card-body" spacing="18">
                <VBox spacing="10">
                    <Label text="Choose your rating" style="-fx-text-fill:#CBD5E1;-fx-font-size:13px;-fx-font-weight:700;"/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Button fx:id="ratingStarBtn1" text="1" onAction="#selectRating1"/>
                        <Button fx:id="ratingStarBtn2" text="2" onAction="#selectRating2"/>
                        <Button fx:id="ratingStarBtn3" text="3" onAction="#selectRating3"/>
                        <Button fx:id="ratingStarBtn4" text="4" onAction="#selectRating4"/>
                        <Button fx:id="ratingStarBtn5" text="5" onAction="#selectRating5"/>
                    </HBox>
                    <Label fx:id="selectedStarsLabel" text="No rating selected"
                           style="-fx-text-fill:#94A3B8;-fx-font-size:12px;-fx-font-weight:600;"/>
                </VBox>
                <VBox spacing="8">
                    <Label text="Comment (optional)" style="-fx-text-fill:#CBD5E1;-fx-font-size:13px;-fx-font-weight:700;"/>
                    <TextArea fx:id="ratingCommentArea" promptText="Example: this deck is difficult / easy / needs simpler explanations..."
                              prefRowCount="4"
                              style="-fx-control-inner-background:#1E293B;-fx-background-color:#1E293B;-fx-text-fill:#F8FAFC;-fx-prompt-text-fill:#475569;-fx-border-color:#334155;-fx-border-width:1.5;-fx-border-radius:10;-fx-background-radius:10;-fx-font-size:13px;"/>
                </VBox>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Button text="Submit Rating" onAction="#submitDeckRating"
                            style="-fx-background-color:linear-gradient(to right,#EC4899,#C026D3);-fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:700;-fx-background-radius:12;-fx-cursor:hand;-fx-padding:10 22;">
                        <graphic><FontIcon iconLiteral="fth-send" iconSize="14" iconColor="white"/></graphic>
                    </Button>
                    <Button text="Cancel" onAction="#handleRatingBack"
                            style="-fx-background-color:#1E293B;-fx-text-fill:#CBD5E1;-fx-font-size:13px;-fx-font-weight:700;-fx-background-radius:12;-fx-cursor:hand;-fx-padding:10 18;-fx-border-color:#334155;-fx-border-radius:12;-fx-border-width:1;"/>
                </HBox>
                <Label fx:id="ratingStatusLabel" text="Rate a deck from the list to continue."
                       style="-fx-text-fill:#64748B;-fx-font-size:11px;"/>
            </VBox>
        </VBox>
    </VBox>

    <!-- VIEW 3 – Form (loaded dynamically) -->
    <StackPane fx:id="formHost" visible="false" managed="false"/>

</StackPane>