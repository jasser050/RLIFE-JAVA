<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.MainController"
      styleClass="app-container">

    <!-- Custom Title Bar -->
    <HBox fx:id="titleBar" styleClass="title-bar" alignment="CENTER_LEFT" spacing="0"
          onMousePressed="#onTitleBarPressed" onMouseDragged="#onTitleBarDragged">

        <!-- App Icon and Title -->
        <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
            <padding>
                <Insets left="16"/>
            </padding>
            <StackPane styleClass="title-bar-logo">
                <FontIcon iconLiteral="fth-layers" iconSize="14" iconColor="white"/>
            </StackPane>
            <Label text="StudyFlow" styleClass="title-bar-title"/>
            <Label text="—" style="-fx-text-fill: #475569;"/>
            <Label text="Student Dashboard" styleClass="title-bar-subtitle"/>
        </HBox>

        <!-- Window Controls -->
        <HBox alignment="CENTER_RIGHT" spacing="0" styleClass="window-controls">
            <Button fx:id="btnMinimize" styleClass="window-btn, minimize-btn" onAction="#minimizeWindow">
                <graphic>
                    <FontIcon iconLiteral="fth-minus" iconSize="14"/>
                </graphic>
            </Button>

            <Button fx:id="btnMaximize" styleClass="window-btn, maximize-btn" onAction="#maximizeWindow">
                <graphic>
                    <FontIcon fx:id="maximizeIcon" iconLiteral="fth-square" iconSize="12"/>
                </graphic>
            </Button>

            <Button fx:id="btnClose" styleClass="window-btn, close-btn" onAction="#closeWindow">
                <graphic>
                    <FontIcon iconLiteral="fth-x" iconSize="14"/>
                </graphic>
            </Button>
        </HBox>
    </HBox>

    <!-- Main App Content -->
    <BorderPane VBox.vgrow="ALWAYS" styleClass="root">

        <!-- Sidebar -->
        <left>
            <VBox styleClass="sidebar" spacing="0">

                <!-- Logo Section -->
                <HBox styleClass="sidebar-header" alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="sidebar-logo">
                        <FontIcon iconLiteral="fth-layers" iconSize="20" iconColor="white"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="StudyFlow" styleClass="sidebar-title"/>
                        <Label text="Student Dashboard" styleClass="sidebar-subtitle"/>
                    </VBox>
                </HBox>

                <!-- Navigation -->
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                            styleClass="nav-scroll">
                    <VBox styleClass="sidebar-nav" spacing="4">

                        <!-- Main Section -->
                        <Label text="MAIN" styleClass="nav-section-title"/>

                        <Button fx:id="btnDashboard" styleClass="nav-button, active"
                                onAction="#showDashboard" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-home" iconSize="18"/>
                            </graphic>
                            <text>Dashboard</text>
                        </Button>

                        <Button fx:id="btnCourses" styleClass="nav-button"
                                onAction="#showCourses" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-book-open" iconSize="18"/>
                            </graphic>
                            <text>Courses</text>
                        </Button>

                        <Button fx:id="btnAssignments" styleClass="nav-button"
                                onAction="#showAssignments" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-clipboard" iconSize="18"/>
                            </graphic>
                            <text>Assignments</text>
                        </Button>

                        <Button fx:id="btnPlanning" styleClass="nav-button"
                                onAction="#showPlanning" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-calendar" iconSize="18"/>
                            </graphic>
                            <text>Planning</text>
                        </Button>

                        <!-- Study Tools Section -->
                        <Label text="STUDY TOOLS" styleClass="nav-section-title">
                            <VBox.margin>
                                <Insets top="16"/>
                            </VBox.margin>
                        </Label>

                        <Button fx:id="btnRevisions" styleClass="nav-button"
                                onAction="#showRevisions" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-layers" iconSize="18"/>
                            </graphic>
                            <text>Decks</text>
                        </Button>

                        <Button fx:id="btnNotes" styleClass="nav-button"
                                onAction="#showNotes" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-file-text" iconSize="18"/>
                            </graphic>
                            <text>Notes</text>
                        </Button>

                        <Button fx:id="btnProjects" styleClass="nav-button"
                                onAction="#showProjects" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-briefcase" iconSize="18"/>
                            </graphic>
                            <text>Projects</text>
                        </Button>

                        <!-- Wellness Section -->
                        <Label text="WELLNESS" styleClass="nav-section-title">
                            <VBox.margin>
                                <Insets top="16"/>
                            </VBox.margin>
                        </Label>

                        <Button fx:id="btnWellbeing" styleClass="nav-button"
                                onAction="#showWellbeing" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-heart" iconSize="18"/>
                            </graphic>
                            <text>Wellbeing</text>
                        </Button>

                        <Button fx:id="btnStats" styleClass="nav-button"
                                onAction="#showStats" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-bar-chart-2" iconSize="18"/>
                            </graphic>
                            <text>Statistics</text>
                        </Button>

                    </VBox>
                </ScrollPane>

                <!-- User Section at Bottom -->
                <HBox styleClass="sidebar-header sidebar-user-row" alignment="CENTER_LEFT" spacing="12"
                      onMouseClicked="#showProfile" style="-fx-cursor: hand;">
                    <StackPane styleClass="avatar">
                        <Label fx:id="sidebarAvatar" text="??" styleClass="avatar-text"/>
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="sidebarUserName" text="Guest" styleClass="sidebar-title"
                               style="-fx-font-size: 14px;"/>
                        <Label fx:id="sidebarUserSub" text="" styleClass="sidebar-subtitle"/>
                    </VBox>
                    <Button styleClass="btn-ghost" style="-fx-padding: 8;" onAction="#handleLogout">
                        <graphic>
                            <FontIcon iconLiteral="fth-log-out" iconSize="18"/>
                        </graphic>
                    </Button>
                </HBox>

            </VBox>
        </left>

        <!-- Main Content Area -->
        <center>
            <VBox styleClass="main-content">

                <!-- Top Bar -->
                <HBox styleClass="topbar" alignment="CENTER_LEFT">
                    <HBox alignment="CENTER_LEFT" spacing="16" HBox.hgrow="ALWAYS">
                        <!-- Search Field -->
                        <StackPane>
                            <TextField fx:id="searchField" styleClass="search-field"
                                       promptText="Search courses, assignments..."/>
                            <FontIcon iconLiteral="fth-search" iconSize="18" mouseTransparent="true"
                                      style="-fx-icon-color: #64748B;"
                                      StackPane.alignment="CENTER_LEFT"
                                      translateX="12"/>
                        </StackPane>
                    </HBox>

                    <HBox alignment="CENTER_RIGHT" spacing="8">
                        <!-- Notifications -->
                        <Button styleClass="topbar-button">
                            <graphic>
                                <FontIcon iconLiteral="fth-bell" iconSize="20"/>
                            </graphic>
                            <tooltip>
                                <Tooltip text="Notifications"/>
                            </tooltip>
                        </Button>

                        <!-- Quick Add -->
                        <Button styleClass="btn-primary" text="New Task">
                            <graphic>
                                <FontIcon iconLiteral="fth-plus" iconSize="16" iconColor="white"/>
                            </graphic>
                        </Button>

                        <!-- Theme Toggle -->
                        <Button fx:id="btnThemeToggle" styleClass="topbar-button" onAction="#toggleTheme">
                            <graphic>
                                <FontIcon fx:id="themeToggleIcon" iconLiteral="fth-moon" iconSize="20"/>
                            </graphic>
                            <tooltip>
                                <Tooltip text="Toggle Theme"/>
                            </tooltip>
                        </Button>
                    </HBox>
                </HBox>

                <!-- Content Container -->
                <ScrollPane fx:id="contentScroll" fitToWidth="true" fitToHeight="true"
                            hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
                    <StackPane fx:id="contentArea" styleClass="content-area"/>
                </ScrollPane>

            </VBox>
        </center>

    </BorderPane>
</VBox>
