<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.web.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.RegisterController"
      styleClass="app-container">

    <!-- ══════════ TITLE BAR ══════════ -->
    <HBox styleClass="title-bar" alignment="CENTER_LEFT" spacing="0"
          onMousePressed="#onDragStart" onMouseDragged="#onDragged">
        <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
            <padding><Insets left="16"/></padding>
            <StackPane styleClass="title-bar-logo">
                <FontIcon iconLiteral="fth-layers" iconSize="14" iconColor="white"/>
            </StackPane>
            <Label text="RLife" styleClass="title-bar-title"/>
            <Label text="—" style="-fx-text-fill: #475569;"/>
            <Label text="Create Account" styleClass="title-bar-subtitle"/>
        </HBox>
        <HBox alignment="CENTER_RIGHT" spacing="0" styleClass="window-controls">
            <Button styleClass="window-btn, minimize-btn" onAction="#minimizeWindow">
                <graphic><FontIcon iconLiteral="fth-minus" iconSize="14"/></graphic>
            </Button>
            <Button styleClass="window-btn, maximize-btn" onAction="#maximizeWindow">
                <graphic><FontIcon iconLiteral="fth-square" iconSize="12"/></graphic>
            </Button>
            <Button styleClass="window-btn, close-btn" onAction="#closeWindow">
                <graphic><FontIcon iconLiteral="fth-x" iconSize="14"/></graphic>
            </Button>
        </HBox>
    </HBox>

    <!-- ══════════ CONTENT ══════════ -->
    <HBox VBox.vgrow="ALWAYS" spacing="0">

        <!-- ─── LEFT: Form ─── -->
        <VBox styleClass="auth-left-panel" HBox.hgrow="SOMETIMES" minWidth="440" maxWidth="480">
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" styleClass="auth-scroll">
                <VBox spacing="0" alignment="TOP_CENTER">
                    <padding><Insets top="32" right="48" bottom="32" left="48"/></padding>

                    <StackPane styleClass="auth-icon-badge" alignment="CENTER">
                        <FontIcon iconLiteral="fth-user-plus" iconSize="24" iconColor="#A78BFA"/>
                    </StackPane>
                    <VBox.margin><Insets bottom="18"/></VBox.margin>

                    <Label text="Create your account" styleClass="auth-title"/>
                    <VBox.margin><Insets bottom="6"/></VBox.margin>
                    <Label text="Join 50,000+ students learning smarter" styleClass="auth-subtitle"/>
                    <VBox.margin><Insets bottom="26"/></VBox.margin>

                    <Label fx:id="errorLabel" styleClass="auth-error" managed="false" visible="false"
                           wrapText="true" maxWidth="Infinity"/>
                    <VBox.margin><Insets bottom="12"/></VBox.margin>

                    <HBox spacing="14">
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="First name" styleClass="auth-field-label"/>
                            <TextField fx:id="firstNameField" styleClass="auth-field" promptText="John"/>
                        </VBox>
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Last name" styleClass="auth-field-label"/>
                            <TextField fx:id="lastNameField" styleClass="auth-field" promptText="Doe"/>
                        </VBox>
                    </HBox>
                    <VBox.margin><Insets bottom="16"/></VBox.margin>

                    <VBox spacing="8">
                        <Label text="Username" styleClass="auth-field-label"/>
                        <TextField fx:id="usernameField" styleClass="auth-field" promptText="johndoe123"/>
                    </VBox>
                    <VBox.margin><Insets bottom="16"/></VBox.margin>

                    <VBox spacing="8">
                        <Label text="Email address" styleClass="auth-field-label"/>
                        <TextField fx:id="emailField" styleClass="auth-field" promptText="you@university.edu"/>
                    </VBox>
                    <VBox.margin><Insets bottom="16"/></VBox.margin>

                    <VBox spacing="8">
                        <Label text="Password" styleClass="auth-field-label"/>
                        <PasswordField fx:id="passwordField" styleClass="auth-field" promptText="Minimum 6 characters"/>
                    </VBox>
                    <VBox.margin><Insets bottom="16"/></VBox.margin>

                    <VBox spacing="8">
                        <Label text="Confirm password" styleClass="auth-field-label"/>
                        <PasswordField fx:id="confirmPasswordField" styleClass="auth-field" promptText="Repeat your password"/>
                    </VBox>
                    <VBox.margin><Insets bottom="26"/></VBox.margin>

                    <Button fx:id="registerBtn" text="Create Account" styleClass="auth-btn-primary"
                            maxWidth="Infinity" onAction="#handleRegister"/>
                    <VBox.margin><Insets bottom="22"/></VBox.margin>

                    <HBox alignment="CENTER" spacing="12">
                        <Separator HBox.hgrow="ALWAYS"/>
                        <Label text="or" styleClass="auth-divider-text"/>
                        <Separator HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <VBox.margin><Insets bottom="22"/></VBox.margin>

                    <HBox alignment="CENTER" spacing="6">
                        <Label text="Already have an account?" styleClass="auth-muted-text"/>
                        <Button text="Sign in instead" styleClass="auth-link" onAction="#goToLogin"/>
                    </HBox>
                    <VBox.margin><Insets bottom="10"/></VBox.margin>

                    <HBox alignment="CENTER">
                        <Button text="← Back to home" styleClass="auth-link-sm" onAction="#goToLanding"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>

        <!-- ─── RIGHT: Spline 3D Robot ─── -->
        <StackPane styleClass="auth-right-panel" HBox.hgrow="ALWAYS">

            <WebView fx:id="splineView"/>

            <VBox alignment="TOP_CENTER" pickOnBounds="false">
                <padding><Insets top="32"/></padding>
                <Label text="✦  Join 50,000+ students worldwide" styleClass="auth-award-badge"/>
            </VBox>

            <VBox alignment="BOTTOM_CENTER" spacing="14" pickOnBounds="false">
                <padding><Insets bottom="36"/></padding>
                <Label text="Start your journey today." styleClass="auth-right-headline"/>
                <HBox alignment="CENTER" spacing="12">
                    <VBox styleClass="auth-stat-card" alignment="CENTER" spacing="4">
                        <Label text="Free" styleClass="auth-stat-value"/>
                        <Label text="Forever" styleClass="auth-stat-label"/>
                    </VBox>
                    <VBox styleClass="auth-stat-card" alignment="CENTER" spacing="4">
                        <Label text="AI" styleClass="auth-stat-value"/>
                        <Label text="Powered" styleClass="auth-stat-label"/>
                    </VBox>
                    <VBox styleClass="auth-stat-card" alignment="CENTER" spacing="4">
                        <Label text="5 min" styleClass="auth-stat-value"/>
                        <Label text="Quick Setup" styleClass="auth-stat-label"/>
                    </VBox>
                </HBox>
            </VBox>

        </StackPane>
    </HBox>
</VBox>
