<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.StatisticsController"
      spacing="24" style="-fx-background-color: #020617;">

    <padding>
        <Insets top="0" right="0" bottom="24" left="0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Statistics &amp; Analytics" styleClass="text-heading"/>
            <Label text="Track your study habits and progress over time" styleClass="text-muted"/>
        </VBox>
        <Button text="Export Report" styleClass="btn-secondary">
            <graphic>
                <FontIcon iconLiteral="fth-download" iconSize="16"/>
            </graphic>
        </Button>
    </HBox>

    <!-- Stats Summary -->
    <HBox spacing="16">
        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, primary" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-clock" iconSize="20"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="156h" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                    <Label text="Total Study Time" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, success" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-check-circle" iconSize="20"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="89" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                    <Label text="Tasks Completed" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, warning" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-layers" iconSize="20"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="1,247" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                    <Label text="Cards Reviewed" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, accent" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-zap" iconSize="20"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="21" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                    <Label text="Best Streak" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>
    </HBox>

    <!-- Charts Grid -->
    <HBox spacing="16">
        <!-- Monthly Study Time -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS">
            <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, primary" prefWidth="36" prefHeight="36">
                    <FontIcon iconLiteral="fth-bar-chart-2" iconSize="16"/>
                </StackPane>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Monthly Study Time" styleClass="card-title"/>
                    <Label text="Hours studied per month" styleClass="text-small"/>
                </VBox>
            </HBox>
            <VBox styleClass="card-body" VBox.vgrow="ALWAYS">
                <BarChart fx:id="monthlyChart" legendVisible="false" prefHeight="250">
                    <xAxis>
                        <CategoryAxis side="BOTTOM"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis side="LEFT"/>
                    </yAxis>
                </BarChart>
            </VBox>
        </VBox>

        <!-- Course Distribution -->
        <VBox styleClass="card" prefWidth="350">
            <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, success" prefWidth="36" prefHeight="36">
                    <FontIcon iconLiteral="fth-pie-chart" iconSize="16"/>
                </StackPane>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Study Distribution" styleClass="card-title"/>
                    <Label text="Time per course" styleClass="text-small"/>
                </VBox>
            </HBox>
            <VBox styleClass="card-body" VBox.vgrow="ALWAYS" alignment="CENTER">
                <PieChart fx:id="distributionChart" prefHeight="250" legendVisible="true"
                          labelsVisible="false"/>
            </VBox>
        </VBox>
    </HBox>

    <!-- Progress Over Time -->
    <VBox styleClass="card">
        <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
            <StackPane styleClass="stat-icon-box, warning" prefWidth="36" prefHeight="36">
                <FontIcon iconLiteral="fth-trending-up" iconSize="16"/>
            </StackPane>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="Progress Over Time" styleClass="card-title"/>
                <Label text="Tasks completed and study hours trend" styleClass="text-small"/>
            </VBox>
        </HBox>
        <VBox styleClass="card-body">
            <LineChart fx:id="progressChart" prefHeight="200" legendVisible="true">
                <xAxis>
                    <CategoryAxis side="BOTTOM"/>
                </xAxis>
                <yAxis>
                    <NumberAxis side="LEFT"/>
                </yAxis>
            </LineChart>
        </VBox>
    </VBox>
</VBox>
