<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.WellbeingController"
      spacing="24" style="-fx-background-color: #020617;">

    <padding>
        <Insets top="0" right="0" bottom="24" left="0"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Wellbeing &amp; Mindfulness" styleClass="text-heading"/>
            <Label text="Track your mental health and wellness habits" styleClass="text-muted"/>
        </VBox>
        <Button text="Log Mood" styleClass="btn-primary" onAction="#showMoodDialog">
            <graphic>
                <FontIcon iconLiteral="fth-smile" iconSize="16" iconColor="white"/>
            </graphic>
        </Button>
    </HBox>

    <!-- Today's Wellbeing Summary -->
    <HBox spacing="16">
        <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, success" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-smile" iconSize="18"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="moodLabel" text="Good" styleClass="stat-value"/>
                    <Label text="Today's Mood" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, primary" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-moon" iconSize="18"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="sleepLabel" text="7.5h" styleClass="stat-value"/>
                    <Label text="Sleep Last Night" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, warning" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-activity" iconSize="18"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="stressLabel" text="Low" styleClass="stat-value"/>
                    <Label text="Stress Level" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, accent" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-zap" iconSize="18"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="energyLabel" text="High" styleClass="stat-value"/>
                    <Label text="Energy Level" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>
    </HBox>

    <!-- Main Content Grid -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Left Column -->
        <VBox spacing="20" HBox.hgrow="ALWAYS">
            <!-- Mood Tracker Week View -->
            <VBox styleClass="card" spacing="0">
                <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box, success" prefWidth="36" prefHeight="36">
                        <FontIcon iconLiteral="fth-trending-up" iconSize="16"/>
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Mood This Week" styleClass="card-title"/>
                        <Label text="Track your emotional wellbeing" styleClass="text-small"/>
                    </VBox>
                </HBox>
                <HBox styleClass="card-body" spacing="12" alignment="CENTER">
                    <VBox fx:id="moodWeekBox" spacing="8" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <!-- Habits Tracker -->
            <VBox styleClass="card" spacing="0" VBox.vgrow="ALWAYS">
                <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box, primary" prefWidth="36" prefHeight="36">
                        <FontIcon iconLiteral="fth-check-square" iconSize="16"/>
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Daily Habits" styleClass="card-title"/>
                        <Label text="Build healthy routines" styleClass="text-small"/>
                    </VBox>
                    <Button text="Add Habit" styleClass="btn-secondary" style="-fx-font-size: 11px;">
                        <graphic>
                            <FontIcon iconLiteral="fth-plus" iconSize="12"/>
                        </graphic>
                    </Button>
                </HBox>
                <VBox styleClass="card-body" spacing="0" VBox.vgrow="ALWAYS">
                    <VBox fx:id="habitsBox" spacing="0"/>
                </VBox>
            </VBox>
        </VBox>

        <!-- Right Column -->
        <VBox spacing="20" prefWidth="360">
            <!-- Mindfulness Sessions -->
            <VBox styleClass="card" spacing="0">
                <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box, warning" prefWidth="36" prefHeight="36">
                        <FontIcon iconLiteral="fth-sunrise" iconSize="16"/>
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Mindfulness" styleClass="card-title"/>
                        <Label text="Quick meditation sessions" styleClass="text-small"/>
                    </VBox>
                </HBox>
                <VBox styleClass="card-body" spacing="12">
                    <VBox fx:id="mindfulnessBox" spacing="10"/>
                </VBox>
            </VBox>

            <!-- Sleep Log -->
            <VBox styleClass="card" spacing="0" VBox.vgrow="ALWAYS">
                <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box, primary" prefWidth="36" prefHeight="36">
                        <FontIcon iconLiteral="fth-moon" iconSize="16"/>
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Sleep Log" styleClass="card-title"/>
                        <Label text="This week's sleep pattern" styleClass="text-small"/>
                    </VBox>
                </HBox>
                <VBox styleClass="card-body" spacing="0" VBox.vgrow="ALWAYS">
                    <VBox fx:id="sleepLogBox" spacing="8"/>
                </VBox>
            </VBox>
        </VBox>
    </HBox>
</VBox>

