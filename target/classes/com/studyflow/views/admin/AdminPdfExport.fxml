<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.AdminPdfExportController"
      spacing="24" style="-fx-background-color: #020617;">
    <padding><Insets top="0" right="0" bottom="24" left="0"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="PDF Export" styleClass="text-heading"/>
            <Label text="Generate and print user reports as PDF documents" styleClass="text-muted"/>
        </VBox>
    </HBox>

    <!-- Export Options -->
    <HBox spacing="16">
        <VBox styleClass="stat-card" alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS"
              style="-fx-cursor: hand;" onMouseClicked="#exportUserList">
            <StackPane styleClass="stat-icon-box, primary" prefWidth="48" prefHeight="48">
                <FontIcon iconLiteral="fth-users" iconSize="24"/>
            </StackPane>
            <Label text="User List" styleClass="text-body" style="-fx-font-weight: 600;"/>
            <Label text="Export all users to PDF" styleClass="text-small"/>
        </VBox>

        <VBox styleClass="stat-card" alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS"
              style="-fx-cursor: hand;" onMouseClicked="#exportAuditLog">
            <StackPane styleClass="stat-icon-box, warning" prefWidth="48" prefHeight="48">
                <FontIcon iconLiteral="fth-file-text" iconSize="24"/>
            </StackPane>
            <Label text="Audit Log" styleClass="text-body" style="-fx-font-weight: 600;"/>
            <Label text="Export activity log to PDF" styleClass="text-small"/>
        </VBox>

        <VBox styleClass="stat-card" alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS"
              style="-fx-cursor: hand;" onMouseClicked="#exportBannedUsers">
            <StackPane styleClass="stat-icon-box, danger" prefWidth="48" prefHeight="48">
                <FontIcon iconLiteral="fth-user-x" iconSize="24"/>
            </StackPane>
            <Label text="Banned Users" styleClass="text-body" style="-fx-font-weight: 600;"/>
            <Label text="Export banned users report" styleClass="text-small"/>
        </VBox>
    </HBox>

    <!-- Status -->
    <VBox styleClass="card">
        <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
            <StackPane styleClass="stat-icon-box, success" prefWidth="36" prefHeight="36">
                <FontIcon iconLiteral="fth-printer" iconSize="16"/>
            </StackPane>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="Export Status" styleClass="card-title"/>
                <Label text="Click any card above to generate a PDF" styleClass="text-small"/>
            </VBox>
        </HBox>
        <VBox styleClass="card-body" alignment="CENTER" spacing="16" minHeight="200">
            <Label fx:id="statusLabel" text="Ready to export" styleClass="text-muted"
                   style="-fx-font-size: 16px;"/>
            <Label fx:id="filePathLabel" text="" styleClass="text-small"
                   style="-fx-text-fill: #A78BFA;"/>
        </VBox>
    </VBox>
</VBox>
