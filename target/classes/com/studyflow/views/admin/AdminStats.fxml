<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.admin.AdminStatsController"
      spacing="20" styleClass="landing-page">
    <padding>
        <Insets top="8" right="8" bottom="24" left="8"/>
    </padding>

    <VBox spacing="6">
        <Label text="Admin Stats" styleClass="text-heading"/>
        <Label text="Indicateurs rapides pour le pilotage du back office." styleClass="text-muted"/>
    </VBox>

    <HBox spacing="16">
        <VBox styleClass="stat-card, admin-stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <Label text="Users Count" styleClass="stat-label"/>
            <Label fx:id="usersCountLabel" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card, admin-stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <Label text="Admin Rate" styleClass="stat-label"/>
            <Label fx:id="adminRateLabel" text="0%" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card, admin-stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <Label text="Average Sleep" styleClass="stat-label"/>
            <Label fx:id="avgSleepLabel" text="0.0h" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card, admin-stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <Label text="Average Energy" styleClass="stat-label"/>
            <Label fx:id="avgEnergyLabel" text="0.0/10" styleClass="stat-value"/>
        </VBox>
    </HBox>

    <VBox styleClass="card, admin-panel" spacing="14">
        <padding>
            <Insets top="18" right="18" bottom="18" left="18"/>
        </padding>
        <Label text="Highlights" styleClass="card-title"/>
        <VBox fx:id="highlightsBox" spacing="12"/>
    </VBox>
</VBox>
