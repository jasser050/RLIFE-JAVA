<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.AdminUsersController"
      spacing="24" style="-fx-background-color: #020617;">
    <padding><Insets top="0" right="0" bottom="24" left="0"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="User Management" styleClass="text-heading"/>
            <Label text="View, ban, and manage platform users" styleClass="text-muted"/>
        </VBox>
        <Label fx:id="userCountLabel" text="0 users" styleClass="font-size-preview"/>
    </HBox>

    <!-- User Cards Container -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                styleClass="auth-scroll">
        <VBox fx:id="userCardsContainer" spacing="10">
            <padding><Insets top="4" right="4" bottom="4" left="4"/></padding>
        </VBox>
    </ScrollPane>
</VBox>
