<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.AdminMainController"
      styleClass="app-container">

    <HBox fx:id="titleBar" styleClass="title-bar" alignment="CENTER_LEFT"
          onMousePressed="#onTitleBarPressed" onMouseDragged="#onTitleBarDragged">
        <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
            <padding><Insets left="16"/></padding>
            <StackPane styleClass="title-bar-logo">
                <FontIcon iconLiteral="fth-shield" iconSize="14" iconColor="white"/>
            </StackPane>
            <Label text="RLIFE" styleClass="title-bar-title"/>
            <Label text="-" style="-fx-text-fill: #475569;"/>
            <Label text="Administration" styleClass="title-bar-subtitle"/>
        </HBox>
        <HBox alignment="CENTER_RIGHT" styleClass="window-controls">
            <Button fx:id="btnMinimize" styleClass="window-btn, minimize-btn" onAction="#minimizeWindow">
                <graphic><FontIcon iconLiteral="fth-minus" iconSize="14"/></graphic>
            </Button>
            <Button fx:id="btnMaximize" styleClass="window-btn, maximize-btn" onAction="#maximizeWindow">
                <graphic><FontIcon fx:id="maximizeIcon" iconLiteral="fth-square" iconSize="12"/></graphic>
            </Button>
            <Button fx:id="btnClose" styleClass="window-btn, close-btn" onAction="#closeWindow">
                <graphic><FontIcon iconLiteral="fth-x" iconSize="14"/></graphic>
            </Button>
        </HBox>
    </HBox>

    <BorderPane VBox.vgrow="ALWAYS" styleClass="root">
        <left>
            <VBox styleClass="sidebar" spacing="0">
                <HBox styleClass="sidebar-header" alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="sidebar-logo">
                        <FontIcon iconLiteral="fth-shield" iconSize="20" iconColor="white"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="Admin Panel" styleClass="sidebar-title"/>
                        <Label text="Platform Management" styleClass="sidebar-subtitle"/>
                    </VBox>
                </HBox>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" styleClass="nav-scroll">
                    <VBox styleClass="sidebar-nav" spacing="4">
                        <Label text="GENERAL" styleClass="nav-section-title"/>

                        <Button fx:id="btnAdminDashboard" styleClass="nav-button, active"
                                onAction="#showAdminDashboard" maxWidth="Infinity">
                            <graphic><FontIcon iconLiteral="fth-home" iconSize="18"/></graphic>
                            <text>Dashboard</text>
                        </Button>

                        <Label text="MANAGEMENT" styleClass="nav-section-title">
                            <VBox.margin><Insets top="16"/></VBox.margin>
                        </Label>

                        <Button fx:id="btnMatieres" styleClass="nav-button"
                                onAction="#showMatieres" maxWidth="Infinity">
                            <graphic><FontIcon iconLiteral="fth-book-open" iconSize="18"/></graphic>
                            <text>Courses</text>
                        </Button>



                        <Label text="ANALYTICS" styleClass="nav-section-title">
                            <VBox.margin><Insets top="16"/></VBox.margin>
                        </Label>

                        <Button fx:id="btnStats" styleClass="nav-button"
                                onAction="#showStats" maxWidth="Infinity">
                            <graphic><FontIcon iconLiteral="fth-bar-chart-2" iconSize="18"/></graphic>
                            <text>Statistics</text>
                        </Button>

                        <Label text="SYSTEM" styleClass="nav-section-title">
                            <VBox.margin><Insets top="16"/></VBox.margin>
                        </Label>

                        <Button fx:id="btnSettings" styleClass="nav-button"
                                onAction="#showSettings" maxWidth="Infinity">
                            <graphic><FontIcon iconLiteral="fth-settings" iconSize="18"/></graphic>
                            <text>Settings</text>
                        </Button>
                    </VBox>
                </ScrollPane>

                <HBox styleClass="sidebar-header sidebar-user-row" alignment="CENTER_LEFT" spacing="12"
                      style="-fx-cursor: hand;">
                    <StackPane styleClass="avatar">
                        <Label fx:id="sidebarAvatar" text="AD" styleClass="avatar-text"/>
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="sidebarUserName" text="Admin" styleClass="sidebar-title"
                               style="-fx-font-size: 14px;"/>
                        <Label fx:id="sidebarUserSub" text="Administrator" styleClass="sidebar-subtitle"/>
                    </VBox>
                    <Button styleClass="btn-ghost" style="-fx-padding: 8;" onAction="#handleLogout">
                        <graphic><FontIcon iconLiteral="fth-log-out" iconSize="18"/></graphic>
                    </Button>
                </HBox>
            </VBox>
        </left>

        <center>
            <VBox styleClass="main-content">
                <HBox styleClass="topbar" alignment="CENTER_LEFT">
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox alignment="CENTER_RIGHT" spacing="8">
                        <Button styleClass="topbar-button">
                            <graphic><FontIcon iconLiteral="fth-bell" iconSize="20"/></graphic>
                        </Button>
                        <Button fx:id="themeToggleButton" styleClass="topbar-button" onAction="#toggleTheme">
                            <graphic><FontIcon fx:id="themeToggleIcon" iconLiteral="fth-sun" iconSize="20"/></graphic>
                        </Button>
                        <Label text="ADMIN" style="-fx-background-color: #FB7185;
                            -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold;
                            -fx-padding: 4 10; -fx-background-radius: 20;"/>
                    </HBox>
                </HBox>
                <ScrollPane fx:id="contentScroll" fitToWidth="true" fitToHeight="true"
                            hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
                    <StackPane fx:id="contentArea" styleClass="content-area"/>
                </ScrollPane>
            </VBox>
        </center>
    </BorderPane>
</VBox>
