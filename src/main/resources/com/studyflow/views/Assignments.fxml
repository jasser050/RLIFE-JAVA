<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.AssignmentsController"
      spacing="24" style="-fx-background-color: #020617;">

    <padding>
        <Insets top="0" right="0" bottom="24" left="0"/>
    </padding>

    <!-- Page Header -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Assignments &amp; Tasks" styleClass="text-heading"/>
            <Label text="Track and manage your academic tasks" styleClass="text-muted"/>
        </VBox>
        <TextField promptText="Search tasks..." styleClass="search-field" prefWidth="240"/>
        <Button text="New Assignment" styleClass="btn-primary" onAction="#showNewAssignmentDialog">
            <graphic>
                <FontIcon iconLiteral="fth-plus" iconSize="16" iconColor="white"/>
            </graphic>
        </Button>
    </HBox>

    <!-- Stats Row -->
    <HBox spacing="16">
        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, danger" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-alert-circle" iconSize="20"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="overdueLabel" text="3" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                    <Label text="Overdue" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, warning" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-clock" iconSize="20"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="dueSoonLabel" text="5" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                    <Label text="Due This Week" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, primary" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-loader" iconSize="20"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="inProgressLabel" text="4" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                    <Label text="In Progress" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, success" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-check-circle" iconSize="20"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="completedLabel" text="28" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                    <Label text="Completed" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>
    </HBox>

    <!-- Filter Tabs -->
    <HBox spacing="8">
        <Label fx:id="filterAll" text="All Tasks" styleClass="badge, primary"
               style="-fx-cursor: hand; -fx-padding: 8 16;"/>
        <Label fx:id="filterPending" text="Pending" styleClass="badge"
               style="-fx-cursor: hand; -fx-padding: 8 16; -fx-background-color: #1E293B; -fx-text-fill: #94A3B8;"/>
        <Label fx:id="filterInProgress" text="In Progress" styleClass="badge"
               style="-fx-cursor: hand; -fx-padding: 8 16; -fx-background-color: #1E293B; -fx-text-fill: #94A3B8;"/>
        <Label fx:id="filterCompleted" text="Completed" styleClass="badge"
               style="-fx-cursor: hand; -fx-padding: 8 16; -fx-background-color: #1E293B; -fx-text-fill: #94A3B8;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="High Priority" styleClass="badge, danger" style="-fx-cursor: hand; -fx-padding: 8 16;"/>
        <Label text="Medium" styleClass="badge, warning" style="-fx-cursor: hand; -fx-padding: 8 16;"/>
        <Label text="Low" styleClass="badge, success" style="-fx-cursor: hand; -fx-padding: 8 16;"/>
    </HBox>

    <!-- Assignments List -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <HBox styleClass="card-header" alignment="CENTER_LEFT">
            <Label text="All Assignments" styleClass="card-title" HBox.hgrow="ALWAYS"/>
            <Label fx:id="taskCountLabel" text="12 tasks" styleClass="text-muted"/>
        </HBox>
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
            <VBox fx:id="assignmentsList" spacing="2" style="-fx-padding: 8;">
                <!-- Assignment items will be added dynamically -->
            </VBox>
        </ScrollPane>
    </VBox>
</VBox>

