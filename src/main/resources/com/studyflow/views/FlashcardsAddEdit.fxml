<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:id="formView" visible="false" managed="false"
      style="-fx-background-color:#020617;">

    <!-- Form header -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-padding:24 28 20 28;-fx-border-color:#1E293B;-fx-border-width:0 0 1 0;">
        <Button onAction="#handleCancel"
                style="-fx-background-color:#1E293B;-fx-text-fill:#94A3B8;
                       -fx-font-size:12px;-fx-background-radius:10;-fx-cursor:hand;
                       -fx-padding:8 14;-fx-border-color:#334155;-fx-border-radius:10;-fx-border-width:1;">
            <graphic><FontIcon iconLiteral="fth-arrow-left" iconSize="14" iconColor="#94A3B8"/></graphic>
        </Button>
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label fx:id="formTitle" text="New Flashcard" styleClass="text-heading"/>
            <Label text="Fill in the question and answer for your flashcard" styleClass="text-muted"/>
        </VBox>
        <!-- Character counter for quick overview -->
        <Label fx:id="formCompletionLabel" text="0% complete"
               style="-fx-background-color:#1E293B;-fx-text-fill:#64748B;
                      -fx-font-size:11px;-fx-font-weight:700;
                      -fx-padding:6 14;-fx-background-radius:20;"/>
    </HBox>

    <!-- Form body -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color:transparent;-fx-background:transparent;">
        <VBox spacing="20" style="-fx-padding:28;">

            <!-- Title -->
            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <FontIcon iconLiteral="fth-tag" iconSize="13" iconColor="#A78BFA"/>
                    <Label text="Card Title" style="-fx-text-fill:#CBD5E1;-fx-font-size:13px;-fx-font-weight:600;"/>
                    <Label text=" *" style="-fx-text-fill:#FB7185;-fx-font-weight:700;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="titleCharCount" text="0/80"
                           style="-fx-text-fill:#334155;-fx-font-size:10px;"/>
                </HBox>
                <TextField fx:id="fieldTitre" promptText="e.g. Binary Search, Ohm's Law…"
                           style="-fx-background-color:#1E293B;-fx-text-fill:#F8FAFC;
                                  -fx-prompt-text-fill:#475569;-fx-border-color:#334155;
                                  -fx-border-radius:10;-fx-background-radius:10;
                                  -fx-padding:11 16;-fx-font-size:13px;"/>
            </VBox>

            <!-- Question -->
            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <FontIcon iconLiteral="fth-help-circle" iconSize="13" iconColor="#38BDF8"/>
                    <Label text="Question" style="-fx-text-fill:#CBD5E1;-fx-font-size:13px;-fx-font-weight:600;"/>
                    <Label text=" *" style="-fx-text-fill:#FB7185;-fx-font-weight:700;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="questionCharCount" text="0/500"
                           style="-fx-text-fill:#334155;-fx-font-size:10px;"/>
                </HBox>
                <TextArea fx:id="fieldQuestion" promptText="Write your question here…"
                          prefRowCount="3"
                          style="-fx-background-color:#1E293B;-fx-text-fill:#F8FAFC;
                                 -fx-border-color:#334155;-fx-border-radius:10;
                                 -fx-background-radius:10;-fx-font-size:13px;"/>
            </VBox>

            <!-- Answer -->
            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <FontIcon iconLiteral="fth-check-square" iconSize="13" iconColor="#34D399"/>
                    <Label text="Answer" style="-fx-text-fill:#CBD5E1;-fx-font-size:13px;-fx-font-weight:600;"/>
                    <Label text=" *" style="-fx-text-fill:#FB7185;-fx-font-weight:700;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="answerCharCount" text="0/500"
                           style="-fx-text-fill:#334155;-fx-font-size:10px;"/>
                </HBox>
                <TextArea fx:id="fieldReponse" promptText="Write the answer here…"
                          prefRowCount="3"
                          style="-fx-background-color:#1E293B;-fx-text-fill:#F8FAFC;
                                 -fx-border-color:#334155;-fx-border-radius:10;
                                 -fx-background-radius:10;-fx-font-size:13px;"/>
            </VBox>

            <!-- Extra Notes -->
            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <FontIcon iconLiteral="fth-align-left" iconSize="13" iconColor="#FB923C"/>
                    <Label text="Extra Notes (optional)" style="-fx-text-fill:#CBD5E1;-fx-font-size:13px;-fx-font-weight:600;"/>
                </HBox>
                <TextArea fx:id="fieldDescription" promptText="Add hints, mnemonics, or context…"
                          prefRowCount="2"
                          style="-fx-background-color:#1E293B;-fx-text-fill:#F8FAFC;
                                 -fx-border-color:#334155;-fx-border-radius:10;
                                 -fx-background-radius:10;-fx-font-size:13px;"/>
            </VBox>

            <!-- Difficulty + Status -->
            <HBox spacing="16">
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <FontIcon iconLiteral="fth-bar-chart-2" iconSize="13" iconColor="#FBBF24"/>
                        <Label text="Difficulty" style="-fx-text-fill:#CBD5E1;-fx-font-size:13px;-fx-font-weight:600;"/>
                        <Label text=" *" style="-fx-text-fill:#FB7185;-fx-font-weight:700;"/>
                    </HBox>
                    <ComboBox fx:id="combDifficulte" promptText="Select difficulty…" maxWidth="Infinity"
                              style="-fx-background-color:#1E293B;-fx-border-color:#334155;
                                     -fx-border-radius:10;-fx-background-radius:10;-fx-font-size:13px;"/>
                </VBox>
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <FontIcon iconLiteral="fth-activity" iconSize="13" iconColor="#A78BFA"/>
                        <Label text="Status" style="-fx-text-fill:#CBD5E1;-fx-font-size:13px;-fx-font-weight:600;"/>
                        <Label text=" *" style="-fx-text-fill:#FB7185;-fx-font-weight:700;"/>
                    </HBox>
                    <ComboBox fx:id="combEtat" promptText="Select status…" maxWidth="Infinity"
                              style="-fx-background-color:#1E293B;-fx-border-color:#334155;
                                     -fx-border-radius:10;-fx-background-radius:10;-fx-font-size:13px;"/>
                </VBox>
            </HBox>

        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <HBox spacing="12" alignment="CENTER_RIGHT"
          style="-fx-padding:18 28 22 28;-fx-border-color:#1E293B;-fx-border-width:1 0 0 0;">
        <Button text="Cancel" onAction="#handleCancel"
                style="-fx-background-color:#1E293B;-fx-text-fill:#94A3B8;
                       -fx-font-size:13px;-fx-font-weight:600;
                       -fx-background-radius:10;-fx-cursor:hand;
                       -fx-padding:11 26;-fx-border-color:#334155;
                       -fx-border-radius:10;-fx-border-width:1;"/>
        <Button text="Save Flashcard" onAction="#handleSave"
                style="-fx-background-color:linear-gradient(to right,#7C3AED,#6D28D9);
                       -fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:700;
                       -fx-background-radius:10;-fx-cursor:hand;-fx-padding:11 30;
                       -fx-effect:dropshadow(gaussian,rgba(124,58,237,0.5),12,0,0,4);"/>
    </HBox>
</VBox>
