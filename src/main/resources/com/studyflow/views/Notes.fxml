<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.studyflow.controllers.MyPetController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            styleClass="landing-scroll">
    <content>
        <VBox spacing="22" styleClass="wellbeing-page">
            <padding>
                <Insets top="0" right="0" bottom="24" left="0"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="wellbeing-hero">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="My Pet" styleClass="text-heading"/>
                    <Label text="Adopt, feed, evolve and manage your RLIFE companion" styleClass="wellbeing-subtitle"/>
                </VBox>
                <Button text="Pet Metaverse" styleClass="btn-primary" onAction="#handleOpenMetaverse"/>
            </HBox>

            <Label fx:id="globalMessageLabel"
                   text=""
                   visible="false"
                   managed="false"
                   styleClass="text-small"/>

            <HBox spacing="16">
                <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <StackPane styleClass="stat-icon-box, primary" prefWidth="40" prefHeight="40"/>
                        <VBox spacing="2">
                            <Label fx:id="petCountLabel" text="0" styleClass="stat-value"/>
                            <Label text="Companions" styleClass="stat-label"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <StackPane styleClass="stat-icon-box, warning" prefWidth="40" prefHeight="40"/>
                        <VBox spacing="2">
                            <Label fx:id="coinsLabel" text="0" styleClass="stat-value"/>
                            <Label text="Coins" styleClass="stat-label"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <StackPane styleClass="stat-icon-box, success" prefWidth="40" prefHeight="40"/>
                        <VBox spacing="2">
                            <Label fx:id="moodSummaryLabel" text="No pet yet" styleClass="stat-value"/>
                            <Label text="Mood" styleClass="stat-label"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <StackPane styleClass="stat-icon-box, accent" prefWidth="40" prefHeight="40"/>
                        <VBox spacing="2">
                            <Label fx:id="evolutionSummaryLabel" text="Ready to adopt" styleClass="stat-value"/>
                            <Label text="Evolution" styleClass="stat-label"/>
                        </VBox>
                    </HBox>
                </VBox>
            </HBox>

            <VBox fx:id="chooseSection" spacing="18" styleClass="card">
                <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="10">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Choose Your Companion" styleClass="card-title"/>
                        <Label text="Pick a pet type, then give it a name." styleClass="text-small"/>
                    </VBox>
                </HBox>
                <VBox styleClass="card-body" spacing="18">
                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="pet-selection-summary">
                        <VBox spacing="2">
                            <Label fx:id="selectedPetTypeLabel" text="Cat" styleClass="pet-selected-title"/>
                            <Label fx:id="selectedPetHintLabel" text="Playful - Quick learner" styleClass="pet-selected-subtitle"/>
                        </VBox>
                    </HBox>
                    <FlowPane fx:id="adoptPetGrid" hgap="16" vgap="16" prefWrapLength="960"/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <TextField fx:id="petNameField" promptText="Enter companion name" prefWidth="280"/>
                        <Button text="Adopt Pet" styleClass="btn-primary" onAction="#handleAdoptPet"/>
                    </HBox>
                </VBox>
            </VBox>

            <VBox fx:id="manageSection" spacing="20" visible="false" managed="false">
                <HBox spacing="20">
                    <VBox styleClass="card, pet-hero-card" spacing="0" HBox.hgrow="ALWAYS">
                        <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="10">
                            <Label text="Companion" styleClass="card-title"/>
                        </HBox>
                        <VBox styleClass="card-body" spacing="16" alignment="TOP_CENTER">
                            <StackPane styleClass="pet-hero-image-shell" minWidth="240" prefWidth="240" maxWidth="240" minHeight="240" prefHeight="240" maxHeight="240">
                                <ImageView fx:id="petImageView" fitWidth="224" fitHeight="224" preserveRatio="true"/>
                            </StackPane>
                            <VBox spacing="6" maxWidth="260">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label fx:id="petDisplayNameLabel" text="Luna" styleClass="pet-display-name"/>
                                    <Label fx:id="petRarityBadge" text="Rare" styleClass="pet-rarity-badge"/>
                                </HBox>
                                <Label fx:id="petMetaLabel" text="Level 1 - Happy - Starter" styleClass="text-muted"/>
                                <HBox spacing="8">
                                    <Label text="Type" styleClass="pet-chip-label"/>
                                    <Label fx:id="currentTypeBadge" text="Cat" styleClass="pet-chip-value"/>
                                </HBox>
                                <HBox spacing="8">
                                    <Label text="Personality" styleClass="pet-chip-label"/>
                                    <Label fx:id="petPersonalityLabel" text="Playful" styleClass="pet-chip-value"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </VBox>

                    <VBox styleClass="card" spacing="0" HBox.hgrow="ALWAYS">
                        <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="10">
                            <Label text="Status and Care" styleClass="card-title"/>
                        </HBox>
                        <VBox styleClass="card-body" spacing="16">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <TextField fx:id="renameField" promptText="Rename pet" HBox.hgrow="ALWAYS"/>
                                <Button text="Rename" styleClass="btn-secondary" onAction="#handleRenamePet"/>
                            </HBox>

                            <VBox spacing="10">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="Hunger" styleClass="pet-stat-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="hungerValueLabel" text="0/100" styleClass="pet-stat-value"/>
                                </HBox>
                                <ProgressBar fx:id="hungerBar" progress="0" styleClass="pet-progress-hunger"/>

                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="Happiness" styleClass="pet-stat-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="happinessValueLabel" text="0/100" styleClass="pet-stat-value"/>
                                </HBox>
                                <ProgressBar fx:id="happinessBar" progress="0" styleClass="pet-progress-happiness"/>

                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="Energy" styleClass="pet-stat-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="energyValueLabel" text="0/100" styleClass="pet-stat-value"/>
                                </HBox>
                                <ProgressBar fx:id="energyBar" progress="0" styleClass="pet-progress-energy"/>

                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="Health" styleClass="pet-stat-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="healthValueLabel" text="0/100" styleClass="pet-stat-value"/>
                                </HBox>
                                <ProgressBar fx:id="healthBar" progress="0" styleClass="pet-progress-health"/>

                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="XP" styleClass="pet-stat-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="xpValueLabel" text="0 / 100" styleClass="pet-stat-value"/>
                                </HBox>
                                <ProgressBar fx:id="xpBar" progress="0" styleClass="pet-progress-xp"/>
                            </VBox>

                            <VBox spacing="12">
                                <Label text="Feeding" styleClass="text-subheading"/>
                                <HBox spacing="10">
                                    <Button text="Basic 50" styleClass="btn-secondary" onAction="#handleFeedBasic"/>
                                    <Button text="Premium 120" styleClass="btn-secondary" onAction="#handleFeedPremium"/>
                                    <Button text="Deluxe 200" styleClass="btn-secondary" onAction="#handleFeedDeluxe"/>
                                </HBox>
                            </VBox>

                            <VBox spacing="12">
                                <Label text="Actions" styleClass="text-subheading"/>
                                <HBox spacing="10">
                                    <Button text="Study +35 coins" styleClass="btn-primary" onAction="#handleActionStudy"/>
                                    <Button text="Play" styleClass="btn-secondary" onAction="#handleActionPlay"/>
                                    <Button text="Rest" styleClass="btn-secondary" onAction="#handleActionRest"/>
                                    <Button text="Clean" styleClass="btn-secondary" onAction="#handleActionClean"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </VBox>
                </HBox>

                <HBox spacing="20">
                    <VBox styleClass="card" spacing="0" HBox.hgrow="ALWAYS">
                        <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="10">
                            <Label text="Recent Events" styleClass="card-title"/>
                        </HBox>
                        <VBox fx:id="eventListBox" styleClass="card-body" spacing="10"/>
                    </VBox>

                    <VBox styleClass="card" spacing="0" HBox.hgrow="ALWAYS">
                        <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="10">
                            <Label text="Achievements" styleClass="card-title"/>
                        </HBox>
                        <FlowPane fx:id="achievementsPane" styleClass="card-body" hgap="12" vgap="12" prefWrapLength="520"/>
                    </VBox>
                </HBox>

                <VBox styleClass="card" spacing="0">
                    <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="10">
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Pet Metaverse" styleClass="card-title"/>
                            <Label text="Open the shared garden world for your companion." styleClass="text-small"/>
                        </VBox>
                        <Button text="Open" styleClass="btn-primary" onAction="#handleOpenMetaverse"/>
                    </HBox>
                    <VBox styleClass="card-body" spacing="12">
                        <Label text="Use the metaverse to explore the garden, inspect your companion, and keep the same pet logic in an immersive view."
                               wrapText="true"
                               styleClass="text-small"/>
                    </VBox>
                </VBox>

                <VBox styleClass="card" spacing="0">
                    <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="10">
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Change Companion Type" styleClass="card-title"/>
                            <Label text="Switch your companion design for 300 coins." styleClass="text-small"/>
                        </VBox>
                        <Button fx:id="changeTypeButton" text="Apply Change" styleClass="btn-primary" onAction="#handleChangeType"/>
                    </HBox>
                    <VBox styleClass="card-body" spacing="16">
                        <FlowPane fx:id="changeTypeGrid" hgap="16" vgap="16" prefWrapLength="960"/>
                    </VBox>
                </VBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
