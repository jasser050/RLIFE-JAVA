<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.studyflow.controllers.AdminDashboardController"
            fitToWidth="true" hbarPolicy="NEVER"
            styleClass="content-scroll">

    <VBox spacing="28" styleClass="content-padding">
        <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

        <!-- Page Header -->
        <VBox spacing="6">
            <Label text="Admin Dashboard" styleClass="page-title"/>
            <Label text="Platform overview and key metrics" styleClass="page-subtitle"/>
        </VBox>

        <!-- Stat Cards Row -->
        <HBox spacing="16">

            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box primary">
                        <FontIcon iconLiteral="fth-users" iconSize="20"/>
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Total Users" styleClass="stat-label"/>
                        <Label fx:id="totalUsersLabel" text="—" styleClass="stat-value"/>
                    </VBox>
                </HBox>
                <Label fx:id="newUsersLabel" text="+0 this week" styleClass="stat-change success"/>
            </VBox>

            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box warning">
                        <FontIcon iconLiteral="fth-book-open" iconSize="20"/>
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Total Courses" styleClass="stat-label"/>
                        <Label fx:id="totalCoursesLabel" text="—" styleClass="stat-value"/>
                    </VBox>
                </HBox>
                <Label text="Across all subjects" styleClass="stat-change"/>
            </VBox>

            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box accent">
                        <FontIcon iconLiteral="fth-layers" iconSize="20"/>
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Flashcard Decks" styleClass="stat-label"/>
                        <Label fx:id="totalDecksLabel" text="—" styleClass="stat-value"/>
                    </VBox>
                </HBox>
                <Label text="Active study decks" styleClass="stat-change"/>
            </VBox>

            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="stat-icon-box success">
                        <FontIcon iconLiteral="fth-check-circle" iconSize="20"/>
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Assignments Done" styleClass="stat-label"/>
                        <Label fx:id="totalAssignmentsLabel" text="—" styleClass="stat-value"/>
                    </VBox>
                </HBox>
                <Label text="Completed this month" styleClass="stat-change"/>
            </VBox>

        </HBox>

        <!-- Users Table -->
        <VBox styleClass="card" spacing="16">
            <HBox alignment="CENTER_LEFT">
                <Label text="Recent Users" styleClass="card-title" HBox.hgrow="ALWAYS"/>
                <Button text="View All" styleClass="btn-ghost" onAction="#viewAllUsers"/>
            </HBox>

            <TableView fx:id="usersTable" styleClass="data-table" prefHeight="300">
                <columns>
                    <TableColumn fx:id="colId"       text="ID"         prefWidth="60"/>
                    <TableColumn fx:id="colName"     text="Full Name"  prefWidth="180"/>
                    <TableColumn fx:id="colEmail"    text="Email"      prefWidth="220"/>
                    <TableColumn fx:id="colUsername" text="Username"   prefWidth="140"/>
                    <TableColumn fx:id="colCoins"    text="Coins"      prefWidth="80"/>
                    <TableColumn fx:id="colActions"  text="Actions"    prefWidth="120"/>
                </columns>
                <placeholder>
                    <Label text="No users found." styleClass="auth-subtitle"/>
                </placeholder>
            </TableView>
        </VBox>

    </VBox>
</ScrollPane>
