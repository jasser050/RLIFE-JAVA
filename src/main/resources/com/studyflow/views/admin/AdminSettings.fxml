<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.admin.AdminSettingsController"
      spacing="20" styleClass="landing-page">
    <padding>
        <Insets top="8" right="8" bottom="24" left="8"/>
    </padding>

    <VBox spacing="6">
        <Label text="Admin Settings" styleClass="text-heading"/>
        <Label text="Configuration de l'espace administrateur." styleClass="text-muted"/>
    </VBox>

    <VBox styleClass="card, admin-panel" spacing="14">
        <padding>
            <Insets top="18" right="18" bottom="18" left="18"/>
        </padding>
        <Label text="Current Mode" styleClass="stat-label"/>
        <Label fx:id="currentModeLabel" text="Back Office Active" styleClass="card-title"/>
        <Label text="Routing Rule" styleClass="stat-label"/>
        <Label fx:id="routingRuleLabel" text="Email suffix @rlife.com" styleClass="text-body"/>
        <Label text="Current Admin Email" styleClass="stat-label"/>
        <Label fx:id="adminEmailLabel" text="admin@rlife.com" styleClass="text-body"/>
    </VBox>
</VBox>
