<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.AdminRatingsController"
      spacing="24" style="-fx-background-color: #020617;">
    <padding><Insets top="0" right="0" bottom="24" left="0"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Deck Ratings" styleClass="text-heading"/>
            <Label text="See who rated each deck and how difficult they found it." styleClass="text-muted"/>
        </VBox>

        <Button text="Refresh" onAction="#refreshRatings" styleClass="admin-export-btn">
            <graphic>
                <FontIcon iconLiteral="fth-refresh-cw" iconSize="14" iconColor="white"/>
            </graphic>
        </Button>
    </HBox>

    <HBox spacing="16">
        <VBox styleClass="stat-card" spacing="14" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <StackPane styleClass="stat-icon-box, primary" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-star" iconSize="18"/>
                </StackPane>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
            <VBox spacing="4">
                <Label fx:id="totalRatingsLabel" text="0" styleClass="stat-value"/>
                <Label text="Total Ratings" styleClass="stat-label"/>
            </VBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="14" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <StackPane styleClass="stat-icon-box, accent" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-users" iconSize="18"/>
                </StackPane>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
            <VBox spacing="4">
                <Label fx:id="uniqueStudentsLabel" text="0" styleClass="stat-value"/>
                <Label text="Students Who Rated" styleClass="stat-label"/>
            </VBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="14" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <StackPane styleClass="stat-icon-box, danger" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-alert-triangle" iconSize="18"/>
                </StackPane>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
            <VBox spacing="4">
                <Label fx:id="lowRatingsLabel" text="0" styleClass="stat-value"/>
                <Label text="Ratings 1 to 3" styleClass="stat-label"/>
            </VBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="14" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <StackPane styleClass="stat-icon-box, success" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-bar-chart-2" iconSize="18"/>
                </StackPane>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>
            <VBox spacing="4">
                <Label fx:id="averageLabel" text="-" styleClass="stat-value"/>
                <Label text="Average Rating" styleClass="stat-label"/>
            </VBox>
        </VBox>
    </HBox>

    <VBox styleClass="card">
        <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
            <StackPane styleClass="stat-icon-box, primary" prefWidth="36" prefHeight="36">
                <FontIcon iconLiteral="fth-list" iconSize="16"/>
            </StackPane>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="Rating History" styleClass="card-title"/>
                <Label text="Student, deck, stars, comment and timestamp." styleClass="text-small"/>
            </VBox>
        </HBox>

        <VBox styleClass="card-body">
            <TableView fx:id="ratingsTable" prefHeight="560" styleClass="admin-table">
                <columns>
                    <TableColumn fx:id="colStudent" text="Student" prefWidth="180"/>
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="220"/>
                    <TableColumn fx:id="colDeck" text="Deck" prefWidth="170"/>
                    <TableColumn fx:id="colSubject" text="Subject" prefWidth="120"/>
                    <TableColumn fx:id="colStars" text="Rating" prefWidth="150"/>
                    <TableColumn fx:id="colComment" text="Comment / Meaning" prefWidth="220"/>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="145"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</VBox>
