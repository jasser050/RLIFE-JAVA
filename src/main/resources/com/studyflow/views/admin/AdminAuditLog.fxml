<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.AdminAuditLogController"
      spacing="24">
    <padding><Insets top="0" right="0" bottom="24" left="0"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Audit Log" styleClass="text-heading"/>
            <Label text="Track all user registrations and moderation actions" styleClass="text-muted"/>
        </VBox>
        <Label fx:id="logCountLabel" text="0 entries" styleClass="font-size-preview"/>
    </HBox>

    <!-- Audit Log Cards Container -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                styleClass="auth-scroll">
        <VBox fx:id="logCardsContainer" spacing="8">
            <padding><Insets top="4" right="4" bottom="4" left="4"/></padding>
        </VBox>
    </ScrollPane>
</VBox>
