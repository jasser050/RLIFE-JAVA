<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.AdminProjectsController"
      spacing="24">
    <padding>
        <Insets top="0" right="0" bottom="24" left="0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Users And Projects" styleClass="text-heading"/>
            <Label text="Browse each user and the projects they own in a card-based admin view." styleClass="text-muted"/>
        </VBox>
        <HBox spacing="10">
            <VBox styleClass="mini-stat-card, mini-stat-violet">
                <Label fx:id="userCountLabel" text="0" styleClass="mini-stat-value"/>
                <Label text="Users" styleClass="mini-stat-label"/>
            </VBox>
            <VBox styleClass="mini-stat-card, mini-stat-amber">
                <Label fx:id="projectCountLabel" text="0" styleClass="mini-stat-value"/>
                <Label text="Projects" styleClass="mini-stat-label"/>
            </VBox>
        </HBox>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" styleClass="auth-scroll">
        <VBox fx:id="userProjectGroupsContainer" spacing="18">
            <padding>
                <Insets top="4" right="4" bottom="4" left="4"/>
            </padding>
        </VBox>
    </ScrollPane>
</VBox>
