<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.AdminDashboardController"
      spacing="24" style="-fx-background-color: #020617;">
    <padding><Insets top="0" right="0" bottom="24" left="0"/></padding>

    <!-- Header with PDF export -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Admin Dashboard" styleClass="text-heading"/>
            <Label text="Overview of your platform and user activity" styleClass="text-muted"/>
        </VBox>

        <!-- PDF Export dropdown -->
        <MenuButton text="Export PDF" styleClass="admin-export-btn">
            <graphic><FontIcon iconLiteral="fth-download" iconSize="14" iconColor="white"/></graphic>
            <items>
                <MenuItem text="User List" onAction="#exportUserListPdf">
                    <graphic><FontIcon iconLiteral="fth-users" iconSize="14"/></graphic>
                </MenuItem>
                <MenuItem text="Banned Users" onAction="#exportBannedPdf">
                    <graphic><FontIcon iconLiteral="fth-user-x" iconSize="14"/></graphic>
                </MenuItem>
                <MenuItem text="Audit Log" onAction="#exportAuditPdf">
                    <graphic><FontIcon iconLiteral="fth-file-text" iconSize="14"/></graphic>
                </MenuItem>
            </items>
        </MenuButton>

        <HBox styleClass="card" alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 12 16;">
            <StackPane styleClass="stat-icon-box, danger" prefWidth="40" prefHeight="40">
                <FontIcon iconLiteral="fth-shield" iconSize="18"/>
            </StackPane>
            <VBox spacing="2">
                <Label text="Admin" styleClass="stat-value" style="-fx-font-size: 18px;"/>
                <Label text="Full Access" styleClass="text-small"/>
            </VBox>
        </HBox>
    </HBox>

    <!-- Stats Cards Row -->
    <HBox spacing="16">
        <VBox styleClass="stat-card" spacing="16" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <StackPane styleClass="stat-icon-box, primary" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-users" iconSize="20"/>
                </StackPane>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Total" styleClass="badge, primary"/>
            </HBox>
            <VBox spacing="4">
                <Label fx:id="totalUsersLabel" text="0" styleClass="stat-value"/>
                <Label text="Registered Users" styleClass="stat-label"/>
            </VBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="16" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <StackPane styleClass="stat-icon-box, success" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-user-check" iconSize="20"/>
                </StackPane>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Active" styleClass="badge, success"/>
            </HBox>
            <VBox spacing="4">
                <Label fx:id="activeUsersLabel" text="0" styleClass="stat-value"/>
                <Label text="Active Users" styleClass="stat-label"/>
            </VBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="16" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <StackPane styleClass="stat-icon-box, danger" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-user-x" iconSize="20"/>
                </StackPane>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Banned" styleClass="badge, danger"/>
            </HBox>
            <VBox spacing="4">
                <Label fx:id="bannedUsersLabel" text="0" styleClass="stat-value"/>
                <Label text="Banned Users" styleClass="stat-label"/>
            </VBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="16" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <StackPane styleClass="stat-icon-box, warning" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-user-plus" iconSize="20"/>
                </StackPane>
            </HBox>
            <VBox spacing="4">
                <Label fx:id="newUsersLabel" text="0" styleClass="stat-value"/>
                <Label text="New This Month" styleClass="stat-label"/>
            </VBox>
        </VBox>
    </HBox>

    <!-- User Registrations Chart — full-width featured card -->
    <VBox styleClass="card">
        <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
            <StackPane styleClass="stat-icon-box, primary" prefWidth="40" prefHeight="40">
                <FontIcon iconLiteral="fth-bar-chart-2" iconSize="18"/>
            </StackPane>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="User Registrations" styleClass="card-title" style="-fx-font-size: 17px;"/>
                <Label text="Monthly sign-up trend across the platform" styleClass="text-small"/>
            </VBox>
            <Label styleClass="badge, primary" text="Monthly" style="-fx-padding: 4 12;"/>
        </HBox>
        <VBox styleClass="card-body" VBox.vgrow="ALWAYS" style="-fx-padding: 8 16 16 16;">
            <BarChart fx:id="registrationsChart" legendVisible="false"
                      prefHeight="300" minHeight="260" barGap="2" categoryGap="20"
                      animated="true" style="-fx-padding: 0;">
                <xAxis><CategoryAxis side="BOTTOM" tickLabelRotation="-30"/></xAxis>
                <yAxis><NumberAxis side="LEFT" autoRanging="true" minorTickVisible="false"/></yAxis>
            </BarChart>
        </VBox>
    </VBox>

    <!-- Gender Distribution — dedicated full-width card with big pie chart -->
    <VBox styleClass="card">
        <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
            <StackPane styleClass="stat-icon-box, accent" prefWidth="36" prefHeight="36">
                <FontIcon iconLiteral="fth-pie-chart" iconSize="16"/>
            </StackPane>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="Gender Distribution" styleClass="card-title"/>
                <Label text="Platform user demographics breakdown" styleClass="text-small"/>
            </VBox>
        </HBox>
        <VBox styleClass="card-body" alignment="CENTER">
            <PieChart fx:id="genderChart" legendVisible="true"
                      prefHeight="380" minHeight="350"
                      labelsVisible="true" labelLineLength="25"
                      clockwise="true" startAngle="90"/>
        </VBox>
    </VBox>

    <!-- Activity Breakdown — Active vs Banned bar + Growth area chart -->
    <HBox spacing="16">
        <VBox styleClass="card" HBox.hgrow="ALWAYS">
            <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, success" prefWidth="36" prefHeight="36">
                    <FontIcon iconLiteral="fth-activity" iconSize="16"/>
                </StackPane>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="User Status" styleClass="card-title"/>
                    <Label text="Active vs Banned breakdown" styleClass="text-small"/>
                </VBox>
            </HBox>
            <VBox styleClass="card-body" VBox.vgrow="ALWAYS">
                <BarChart fx:id="activityChart" legendVisible="true"
                          prefHeight="220" barGap="4" categoryGap="30">
                    <xAxis><CategoryAxis side="BOTTOM"/></xAxis>
                    <yAxis><NumberAxis side="LEFT" autoRanging="true"/></yAxis>
                </BarChart>
            </VBox>
        </VBox>

        <VBox styleClass="card" HBox.hgrow="ALWAYS">
            <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, warning" prefWidth="36" prefHeight="36">
                    <FontIcon iconLiteral="fth-trending-up" iconSize="16"/>
                </StackPane>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Growth Trend" styleClass="card-title"/>
                    <Label text="Cumulative user registrations" styleClass="text-small"/>
                </VBox>
            </HBox>
            <VBox styleClass="card-body" VBox.vgrow="ALWAYS">
                <AreaChart fx:id="growthChart" legendVisible="false"
                           prefHeight="220" createSymbols="true">
                    <xAxis><CategoryAxis side="BOTTOM"/></xAxis>
                    <yAxis><NumberAxis side="LEFT" autoRanging="true"/></yAxis>
                </AreaChart>
            </VBox>
        </VBox>
    </HBox>

    <!-- Recent Users Table -->
    <VBox styleClass="card">
        <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
            <StackPane styleClass="stat-icon-box, primary" prefWidth="36" prefHeight="36">
                <FontIcon iconLiteral="fth-users" iconSize="16"/>
            </StackPane>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="Recent Users" styleClass="card-title"/>
                <Label text="Latest registered accounts" styleClass="text-small"/>
            </VBox>
        </HBox>
        <VBox styleClass="card-body">
            <TableView fx:id="recentUsersTable" prefHeight="200" styleClass="admin-table">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colName" text="Name" prefWidth="160"/>
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="220"/>
                    <TableColumn fx:id="colGender" text="Gender" prefWidth="80"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                    <TableColumn fx:id="colDate" text="Joined" prefWidth="150"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</VBox>
