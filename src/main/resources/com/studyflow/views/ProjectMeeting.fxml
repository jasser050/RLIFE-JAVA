<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.ProjectMeetingController"
      spacing="18"
      styleClass="page-section">

    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="projects-toolbar">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Project Meeting" styleClass="text-heading"/>
            <Label fx:id="meetingHintLabel" text="Open a shared Jitsi room for the current project." styleClass="text-muted" wrapText="true"/>
        </VBox>
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button fx:id="shareMeetingButton" text="Share Meeting" onAction="#handleShareMeeting" styleClass="btn-primary">
                <graphic>
                    <FontIcon iconLiteral="fth-send" iconSize="15"/>
                </graphic>
            </Button>
            <Button fx:id="reloadMeetingButton" text="Reload" onAction="#handleReloadMeeting" styleClass="btn-secondary">
                <graphic>
                    <FontIcon iconLiteral="fth-refresh-cw" iconSize="15"/>
                </graphic>
            </Button>
            <Button fx:id="backToProjectsButton" text="Back To Projects" onAction="#handleBackToProjects" styleClass="btn-secondary">
                <graphic>
                    <FontIcon iconLiteral="fth-arrow-left" iconSize="15"/>
                </graphic>
            </Button>
        </HBox>
    </HBox>

    <HBox spacing="16">
        <VBox styleClass="card" spacing="6" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="16" right="18" bottom="16" left="18"/>
            </padding>
            <Label text="Project" styleClass="form-label"/>
            <Label fx:id="meetingProjectTitleLabel" text="Project title" styleClass="card-title" wrapText="true"/>
            <Label fx:id="meetingProjectMetaLabel" text="Project access" styleClass="text-muted"/>
        </VBox>
        <VBox styleClass="card" spacing="6" prefWidth="260">
            <padding>
                <Insets top="16" right="18" bottom="16" left="18"/>
            </padding>
            <Label text="Room Name" styleClass="form-label"/>
            <Label fx:id="meetingRoomLabel" text="rlife-project-room" styleClass="item-desc" wrapText="true"/>
        </VBox>
    </HBox>

    <Label fx:id="meetingShareStatusLabel" text="Share this meeting with the users already added to the project." styleClass="text-muted" wrapText="true"/>

    <StackPane VBox.vgrow="ALWAYS" styleClass="card">
        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>
        <WebView fx:id="meetingWebView" minHeight="620" prefHeight="720" />
    </StackPane>
</VBox>
