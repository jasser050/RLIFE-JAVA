<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.web.*?>
<?import javafx.scene.SubScene?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.RegisterController"
      styleClass="app-container">

    <!-- ══════════ TITLE BAR ══════════ -->
    <HBox styleClass="title-bar" alignment="CENTER_LEFT" spacing="0"
          onMousePressed="#onDragStart" onMouseDragged="#onDragged">
        <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
            <padding><Insets left="16"/></padding>
            <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                <image><Image url="@../images/logo.png"/></image>
            </ImageView>
            <Label text="RLife" styleClass="title-bar-title"/>
            <Label text="—" style="-fx-text-fill: #475569;"/>
            <Label fx:id="titleBarSubtitle" text="Create Account" styleClass="title-bar-subtitle"/>
        </HBox>
        <HBox alignment="CENTER_RIGHT" spacing="0">
            <Button fx:id="themeBtn" styleClass="theme-toggle-btn" onAction="#toggleTheme">
                <graphic><FontIcon iconLiteral="fth-sun" iconSize="13"/></graphic>
            </Button>
            <HBox styleClass="window-controls" spacing="0">
                <Button styleClass="window-btn, minimize-btn" onAction="#minimizeWindow">
                    <graphic><FontIcon iconLiteral="fth-minus" iconSize="14"/></graphic>
                </Button>
                <Button styleClass="window-btn, maximize-btn" onAction="#maximizeWindow">
                    <graphic><FontIcon iconLiteral="fth-square" iconSize="12"/></graphic>
                </Button>
                <Button styleClass="window-btn, close-btn" onAction="#closeWindow">
                    <graphic><FontIcon iconLiteral="fth-x" iconSize="14"/></graphic>
                </Button>
            </HBox>
        </HBox>
    </HBox>

    <!-- ══════════ CONTENT ══════════ -->
    <HBox VBox.vgrow="ALWAYS" spacing="0">

        <!-- ─── LEFT: Wizard Form ─── -->
        <VBox styleClass="auth-left-panel" HBox.hgrow="SOMETIMES" minWidth="520" maxWidth="580">
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" styleClass="auth-scroll">
                <VBox spacing="0" alignment="TOP_CENTER">
                    <padding><Insets top="28" right="48" bottom="28" left="48"/></padding>

                    <!-- Logo -->
                    <ImageView fitWidth="72" fitHeight="72" preserveRatio="true">
                        <image><Image url="@../images/logo.png"/></image>
                    </ImageView>
                    <VBox.margin><Insets bottom="6"/></VBox.margin>
                    <Label text="RLife" styleClass="auth-brand-label"/>
                    <VBox.margin><Insets bottom="18"/></VBox.margin>

                    <!-- Step indicator -->
                    <HBox alignment="CENTER" spacing="0" styleClass="wizard-step-row">
                        <VBox alignment="CENTER" spacing="6" styleClass="wizard-step">
                            <StackPane styleClass="wizard-step-circle, wizard-step-active" fx:id="stepCircle1">
                                <Label text="1" styleClass="wizard-step-num"/>
                            </StackPane>
                            <Label text="Account" styleClass="wizard-step-label, wizard-step-label-active" fx:id="stepLabel1"/>
                        </VBox>
                        <StackPane styleClass="wizard-connector" fx:id="connector1" HBox.hgrow="ALWAYS"/>
                        <VBox alignment="CENTER" spacing="6" styleClass="wizard-step">
                            <StackPane styleClass="wizard-step-circle" fx:id="stepCircle2">
                                <Label text="2" styleClass="wizard-step-num"/>
                            </StackPane>
                            <Label text="Preferences" styleClass="wizard-step-label" fx:id="stepLabel2"/>
                        </VBox>
                        <StackPane styleClass="wizard-connector" fx:id="connector2" HBox.hgrow="ALWAYS"/>
                        <VBox alignment="CENTER" spacing="6" styleClass="wizard-step">
                            <StackPane styleClass="wizard-step-circle" fx:id="stepCircle3">
                                <Label text="3" styleClass="wizard-step-num"/>
                            </StackPane>
                            <Label text="Avatar" styleClass="wizard-step-label" fx:id="stepLabel3"/>
                        </VBox>
                        <StackPane styleClass="wizard-connector" fx:id="connector3" HBox.hgrow="ALWAYS"/>
                        <VBox alignment="CENTER" spacing="6" styleClass="wizard-step">
                            <StackPane styleClass="wizard-step-circle" fx:id="stepCircle4">
                                <Label text="4" styleClass="wizard-step-num"/>
                            </StackPane>
                            <Label text="Face ID" styleClass="wizard-step-label" fx:id="stepLabel4"/>
                        </VBox>
                    </HBox>
                    <VBox.margin><Insets bottom="26"/></VBox.margin>

                    <!-- Error label (shared) -->
                    <Label fx:id="errorLabel" styleClass="auth-error" managed="false" visible="false"
                           wrapText="true" maxWidth="Infinity"/>
                    <VBox.margin><Insets bottom="10"/></VBox.margin>

                    <!-- ══ STEP 1: Account ══ -->
                    <VBox fx:id="step1Panel" spacing="0" maxWidth="Infinity">
                        <Label text="Create your account" styleClass="auth-title"/>
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                        <Label text="Start your learning journey today" styleClass="auth-subtitle"/>
                        <VBox.margin><Insets bottom="22"/></VBox.margin>

                        <HBox spacing="14">
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="First name" styleClass="auth-field-label"/>
                                <TextField fx:id="firstNameField" styleClass="auth-field" promptText="John"/>
                            </VBox>
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Last name" styleClass="auth-field-label"/>
                                <TextField fx:id="lastNameField" styleClass="auth-field" promptText="Doe"/>
                            </VBox>
                        </HBox>
                        <VBox.margin><Insets bottom="16"/></VBox.margin>

                        <VBox spacing="8">
                            <Label text="Username" styleClass="auth-field-label"/>
                            <TextField fx:id="usernameField" styleClass="auth-field" promptText="johndoe123"/>
                        </VBox>
                        <VBox.margin><Insets bottom="16"/></VBox.margin>

                        <VBox spacing="8">
                            <Label text="Email address" styleClass="auth-field-label"/>
                            <TextField fx:id="emailField" styleClass="auth-field" promptText="you@university.edu"/>
                        </VBox>
                        <VBox.margin><Insets bottom="16"/></VBox.margin>

                        <VBox spacing="8">
                            <Label text="Password" styleClass="auth-field-label"/>
                            <PasswordField fx:id="passwordField" styleClass="auth-field" promptText="Minimum 6 characters"/>
                        </VBox>
                        <VBox.margin><Insets bottom="16"/></VBox.margin>

                        <VBox spacing="8">
                            <Label text="Confirm password" styleClass="auth-field-label"/>
                            <PasswordField fx:id="confirmPasswordField" styleClass="auth-field" promptText="Repeat your password"/>
                        </VBox>
                        <VBox.margin><Insets bottom="34"/></VBox.margin>

                        <Button text="Next  →" styleClass="auth-btn-primary"
                                maxWidth="Infinity" onAction="#nextStep">
                            <VBox.margin><Insets top="16"/></VBox.margin>
                        </Button>
                        <VBox.margin><Insets bottom="18"/></VBox.margin>

                        <HBox alignment="CENTER" spacing="6">
                            <Label text="Already have an account?" styleClass="auth-muted-text"/>
                            <Button text="Sign in instead" styleClass="auth-link" onAction="#goToLogin"/>
                        </HBox>
                        <VBox.margin><Insets bottom="8"/></VBox.margin>
                        <HBox alignment="CENTER">
                            <Button text="← Back to home" styleClass="auth-link-sm" onAction="#goToLanding"/>
                        </HBox>
                    </VBox>

                    <!-- ══ STEP 2: Preferences ══ -->
                    <VBox fx:id="step2Panel" spacing="0" maxWidth="Infinity" visible="false" managed="false">
                        <Label text="Your preferences" styleClass="auth-title"/>
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                        <Label text="Help us personalise your experience" styleClass="auth-subtitle"/>
                        <VBox.margin><Insets bottom="22"/></VBox.margin>

                        <VBox spacing="8">
                            <Label text="Phone number (optional)" styleClass="auth-field-label"/>
                            <TextField fx:id="phoneField" styleClass="auth-field" promptText="+216 XX XXX XXX"/>
                        </VBox>
                        <VBox.margin><Insets bottom="16"/></VBox.margin>

                        <VBox spacing="8">
                            <Label text="University (optional)" styleClass="auth-field-label"/>
                            <TextField fx:id="universityField" styleClass="auth-field" promptText="e.g. ESPRIT, MIT"/>
                        </VBox>
                        <VBox.margin><Insets bottom="16"/></VBox.margin>

                        <VBox spacing="8">
                            <Label text="Student ID (optional)" styleClass="auth-field-label"/>
                            <TextField fx:id="studentIdField" styleClass="auth-field" promptText="Your student ID"/>
                        </VBox>
                        <VBox.margin><Insets bottom="16"/></VBox.margin>

                        <VBox spacing="10">
                            <Label text="Gender" styleClass="auth-field-label"/>
                            <HBox spacing="20">
                                <RadioButton fx:id="genderMale" text="Male" styleClass="profile-radio"/>
                                <RadioButton fx:id="genderFemale" text="Female" styleClass="profile-radio"/>
                            </HBox>
                        </VBox>
                        <VBox.margin><Insets bottom="34"/></VBox.margin>

                        <HBox spacing="12" alignment="CENTER">
                            <VBox.margin><Insets top="16"/></VBox.margin>
                            <Button text="← Back" styleClass="auth-btn-secondary" onAction="#prevStep" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                            <Button text="Next  →" styleClass="auth-btn-primary" onAction="#nextStep" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        </HBox>
                    </VBox>

                    <!-- ══ STEP 3: Avatar ══ -->
                    <VBox fx:id="step3Panel" spacing="0" maxWidth="Infinity" visible="false" managed="false">
                        <Label text="Choose your avatar" styleClass="auth-title"/>
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                        <Label text="Pick a character that represents you" styleClass="auth-subtitle"/>
                        <VBox.margin><Insets bottom="16"/></VBox.margin>

                        <!-- Selected avatar preview -->
                        <HBox fx:id="avatarPreviewBox" alignment="CENTER_LEFT" spacing="14"
                              visible="false" managed="false" styleClass="wizard-avatar-preview">
                            <StackPane styleClass="wizard-avatar-mini" alignment="CENTER">
                                <Label fx:id="avatarPreviewIcon" text="👤" style="-fx-font-size: 24px;"/>
                            </StackPane>
                            <VBox spacing="3">
                                <Label fx:id="avatarPreviewName" text="" styleClass="wizard-avatar-name"/>
                                <Label text="Selected" style="-fx-text-fill: #22C55E; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            </VBox>
                        </HBox>
                        <VBox.margin><Insets bottom="14"/></VBox.margin>

                        <!-- Avatar gallery — native JavaFX 3D cards, 3 per row -->
                        <ScrollPane fitToWidth="true" prefHeight="440" styleClass="wizard-avatar-scroll"
                                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                            <FlowPane fx:id="avatarContainer" hgap="8" vgap="8"
                                      styleClass="wizard-avatar-flow" prefWrapLength="380">
                            </FlowPane>
                        </ScrollPane>
                        <VBox.margin><Insets bottom="20"/></VBox.margin>

                        <HBox spacing="12" alignment="CENTER">
                            <Button text="← Back" styleClass="auth-btn-secondary" onAction="#prevStep" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                            <Button text="Next  →" styleClass="auth-btn-primary" onAction="#nextStep" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        </HBox>
                    </VBox>

                    <!-- ══ STEP 4: Face ID ══ -->
                    <VBox fx:id="step4Panel" spacing="0" maxWidth="Infinity" visible="false" managed="false">
                        <Label text="Set up Face ID" styleClass="auth-title"/>
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                        <Label text="Add facial recognition for quick sign-in" styleClass="auth-subtitle"/>
                        <VBox.margin><Insets bottom="16"/></VBox.margin>

                        <!-- Face ID WebView -->
                        <StackPane styleClass="wizard-webview-card">
                            <WebView fx:id="faceIdView" prefHeight="460"/>
                        </StackPane>
                        <VBox.margin><Insets bottom="20"/></VBox.margin>

                        <HBox spacing="12" alignment="CENTER">
                            <Button text="← Back" styleClass="auth-btn-secondary" onAction="#prevStep" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                            <Button fx:id="registerBtn" text="Create Account  ✓" styleClass="auth-btn-primary"
                                    onAction="#handleRegister" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>

        <!-- ─── RIGHT: Marketing Panel ─── -->
        <StackPane styleClass="auth-right-panel" HBox.hgrow="ALWAYS">

            <!-- Background glows -->
            <StackPane styleClass="auth-right-glow" mouseTransparent="true"/>
            <StackPane styleClass="mrkt-orb-tr" mouseTransparent="true" StackPane.alignment="TOP_RIGHT"/>
            <StackPane styleClass="mrkt-orb-bl" mouseTransparent="true" StackPane.alignment="BOTTOM_LEFT"/>

            <!-- Marketing content -->
            <VBox alignment="CENTER" spacing="0" maxWidth="360">
                <padding><Insets top="32" right="40" bottom="32" left="40"/></padding>

                <!-- Badge -->
                <HBox alignment="CENTER">
                    <Label text="✦  Free Forever — No Credit Card Needed" styleClass="mrkt-pill mrkt-pill-green"/>
                </HBox>
                <VBox.margin><Insets bottom="24"/></VBox.margin>

                <!-- Headline -->
                <Label text="Your Success" styleClass="mrkt-h1" maxWidth="Infinity" alignment="CENTER"/>
                <VBox.margin><Insets bottom="2"/></VBox.margin>
                <Label text="Starts Here." styleClass="mrkt-h1 mrkt-h1-purple" maxWidth="Infinity" alignment="CENTER"/>
                <VBox.margin><Insets bottom="14"/></VBox.margin>

                <!-- Subtitle -->
                <Label styleClass="mrkt-sub" wrapText="true" textAlignment="CENTER" maxWidth="300"
                       text="Create your free account and unlock everything you need to excel academically."/>
                <VBox.margin><Insets bottom="30"/></VBox.margin>

                <!-- Feature cards -->
                <VBox spacing="10">
                    <HBox styleClass="mrkt-card" spacing="14" alignment="CENTER_LEFT">
                        <StackPane styleClass="mrkt-ic mrkt-ic-purple" prefWidth="42" prefHeight="42" minWidth="42" minHeight="42" maxWidth="42" maxHeight="42">
                            <FontIcon iconLiteral="fth-book-open" iconSize="17" styleClass="mrkt-ico"/>
                        </StackPane>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="AI-Powered Notes" styleClass="mrkt-card-title"/>
                            <Label text="Capture and organize content intelligently" styleClass="mrkt-card-sub"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="mrkt-card" spacing="14" alignment="CENTER_LEFT">
                        <StackPane styleClass="mrkt-ic mrkt-ic-blue" prefWidth="42" prefHeight="42" minWidth="42" minHeight="42" maxWidth="42" maxHeight="42">
                            <FontIcon iconLiteral="fth-calendar" iconSize="17" styleClass="mrkt-ico"/>
                        </StackPane>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Smart Scheduling" styleClass="mrkt-card-title"/>
                            <Label text="Never miss a deadline or exam again" styleClass="mrkt-card-sub"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="mrkt-card" spacing="14" alignment="CENTER_LEFT">
                        <StackPane styleClass="mrkt-ic mrkt-ic-pink" prefWidth="42" prefHeight="42" minWidth="42" minHeight="42" maxWidth="42" maxHeight="42">
                            <FontIcon iconLiteral="fth-trending-up" iconSize="17" styleClass="mrkt-ico"/>
                        </StackPane>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Progress Analytics" styleClass="mrkt-card-title"/>
                            <Label text="Visual insights to maximize performance" styleClass="mrkt-card-sub"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="mrkt-card" spacing="14" alignment="CENTER_LEFT">
                        <StackPane styleClass="mrkt-ic mrkt-ic-teal" prefWidth="42" prefHeight="42" minWidth="42" minHeight="42" maxWidth="42" maxHeight="42">
                            <FontIcon iconLiteral="fth-users" iconSize="17" styleClass="mrkt-ico"/>
                        </StackPane>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Collaborate &amp; Connect" styleClass="mrkt-card-title"/>
                            <Label text="Study groups and shared resources" styleClass="mrkt-card-sub"/>
                        </VBox>
                    </HBox>
                </VBox>
                <VBox.margin><Insets bottom="26"/></VBox.margin>

                <!-- Divider -->
                <StackPane styleClass="mrkt-rule" maxWidth="Infinity" minHeight="1" maxHeight="1"/>
                <VBox.margin><Insets bottom="22"/></VBox.margin>

                <!-- Stats -->
                <HBox alignment="CENTER" spacing="0">
                    <VBox alignment="CENTER" spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Free" styleClass="mrkt-sn"/>
                        <Label text="Forever" styleClass="mrkt-sl"/>
                    </VBox>
                    <StackPane styleClass="mrkt-sep" minWidth="1" maxWidth="1" minHeight="40" maxHeight="40"/>
                    <VBox alignment="CENTER" spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="5 min" styleClass="mrkt-sn"/>
                        <Label text="Quick Setup" styleClass="mrkt-sl"/>
                    </VBox>
                    <StackPane styleClass="mrkt-sep" minWidth="1" maxWidth="1" minHeight="40" maxHeight="40"/>
                    <VBox alignment="CENTER" spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="AI" styleClass="mrkt-sn"/>
                        <Label text="Powered" styleClass="mrkt-sl"/>
                    </VBox>
                </HBox>

            </VBox>
        </StackPane>
    </HBox>
</VBox>
