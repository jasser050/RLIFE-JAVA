<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.AdminController"
      styleClass="app-container">

    <HBox fx:id="titleBar" styleClass="title-bar" alignment="CENTER_LEFT" spacing="0"
          onMousePressed="#onTitleBarPressed" onMouseDragged="#onTitleBarDragged">
        <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
            <padding>
                <Insets left="16"/>
            </padding>
            <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                <image>
                    <Image url="@../images/logo.png"/>
                </image>
            </ImageView>
            <Label text="RLife" styleClass="title-bar-title"/>
            <Label text="—" style="-fx-text-fill: #475569;"/>
            <Label text="Admin Dashboard" styleClass="title-bar-subtitle" style="-fx-text-fill: #F43F5E;"/>
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="0" styleClass="window-controls">
            <Button styleClass="window-btn, minimize-btn" onAction="#minimizeWindow">
                <graphic>
                    <FontIcon iconLiteral="fth-minus" iconSize="14"/>
                </graphic>
            </Button>
            <Button styleClass="window-btn, maximize-btn" onAction="#maximizeWindow">
                <graphic>
                    <FontIcon fx:id="maximizeIcon" iconLiteral="fth-square" iconSize="12"/>
                </graphic>
            </Button>
            <Button styleClass="window-btn, close-btn" onAction="#closeWindow">
                <graphic>
                    <FontIcon iconLiteral="fth-x" iconSize="14"/>
                </graphic>
            </Button>
        </HBox>
    </HBox>

    <BorderPane VBox.vgrow="ALWAYS" styleClass="root">
        <left>
            <VBox styleClass="sidebar" spacing="0" prefWidth="240" minWidth="240">
                <HBox styleClass="sidebar-header" alignment="CENTER_LEFT" spacing="12">
                    <ImageView fx:id="sidebarLogo" fitHeight="44" fitWidth="44" preserveRatio="true" styleClass="sidebar-logo-img"/>
                    <VBox spacing="2">
                        <Label text="RLIFE" styleClass="sidebar-title"/>
                        <Label text="Admin Workspace" styleClass="sidebar-subtitle"/>
                    </VBox>
                </HBox>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" styleClass="nav-scroll">
                    <VBox styleClass="sidebar-nav" spacing="4">
                        <Label text="MAIN" styleClass="nav-section-title"/>

                        <Button fx:id="btnAdminDash" styleClass="nav-button, active"
                                onAction="#showDashboard" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-home" iconSize="18"/>
                            </graphic>
                            <text>Dashboard</text>
                        </Button>

                        <Button fx:id="btnCourses" styleClass="nav-button"
                                onAction="#showCourses" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-book-open" iconSize="18"/>
                            </graphic>
                            <text>Courses</text>
                        </Button>

                        <Button fx:id="btnPlanning" styleClass="nav-button"
                                onAction="#showPlanning" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-calendar" iconSize="18"/>
                            </graphic>
                            <text>Planning</text>
                        </Button>

                        <Label text="STUDY TOOLS" styleClass="nav-section-title">
                            <VBox.margin>
                                <Insets top="16"/>
                            </VBox.margin>
                        </Label>

                        <Button fx:id="btnRevisions" styleClass="nav-button"
                                onAction="#showRevisions" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-layers" iconSize="18"/>
                            </graphic>
                            <text>Decks</text>
                        </Button>

                        <Button fx:id="btnProjects" styleClass="nav-button"
                                onAction="#showProjects" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-users" iconSize="18"/>
                            </graphic>
                            <text>Projects</text>
                        </Button>

                        <Button fx:id="btnNotes" styleClass="nav-button"
                                onAction="#showNotes" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-file-text" iconSize="18"/>
                            </graphic>
                            <text>Notes</text>
                        </Button>

                        <Label text="WELLNESS" styleClass="nav-section-title">
                            <VBox.margin>
                                <Insets top="16"/>
                            </VBox.margin>
                        </Label>

                        <Button fx:id="btnStressQuestions" styleClass="nav-button"
                                onAction="#showStressQuestions" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-help-circle" iconSize="18"/>
                            </graphic>
                            <text>Stress Questions</text>
                        </Button>

                        <Button fx:id="btnRecommendations" styleClass="nav-button"
                                onAction="#showRecommendations" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-activity" iconSize="18"/>
                            </graphic>
                            <text>Recommendations</text>
                        </Button>

                        <Button fx:id="btnStats" styleClass="nav-button"
                                onAction="#showStats" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-bar-chart-2" iconSize="18"/>
                            </graphic>
                            <text>Statistics</text>
                        </Button>

                        <Label text="ADMIN TOOLS" styleClass="nav-section-title">
                            <VBox.margin>
                                <Insets top="16"/>
                            </VBox.margin>
                        </Label>

                        <Button fx:id="btnAdminUsers" styleClass="nav-button"
                                onAction="#showUsers" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-user-check" iconSize="18"/>
                            </graphic>
                            <text>Users</text>
                        </Button>

                        <Button fx:id="btnAdminAudit" styleClass="nav-button"
                                onAction="#showAuditLog" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-shield" iconSize="18"/>
                            </graphic>
                            <text>Audit Log</text>
                        </Button>

                        <Button fx:id="btnAdminAI" styleClass="nav-button"
                                onAction="#showAI" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-cpu" iconSize="18"/>
                            </graphic>
                            <text>AI Agent</text>
                        </Button>
                    </VBox>
                </ScrollPane>

                <HBox fx:id="userProfileRow" styleClass="sidebar-header sidebar-user-row" alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="avatar"
                               style="-fx-background-color: linear-gradient(to bottom right, #DC2626, #7C3AED);">
                        <Label fx:id="sidebarAvatar" text="AD" styleClass="avatar-text"/>
                    </StackPane>
                    <VBox fx:id="userInfoBox" spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="sidebarUserName" text="Administrator" styleClass="sidebar-title" style="-fx-font-size: 14px;"/>
                        <Label fx:id="sidebarUserSub" text="admin@rlife.com" styleClass="sidebar-subtitle"/>
                    </VBox>
                    <Button styleClass="btn-ghost" style="-fx-padding: 8;" onAction="#handleLogout">
                        <graphic>
                            <FontIcon iconLiteral="fth-log-out" iconSize="18"/>
                        </graphic>
                    </Button>
                </HBox>
            </VBox>
        </left>

        <center>
            <VBox styleClass="main-content">
                <HBox styleClass="topbar" alignment="CENTER_LEFT">
                    <HBox alignment="CENTER_LEFT" spacing="16" HBox.hgrow="ALWAYS">
                        <StackPane>
                            <TextField fx:id="searchField" styleClass="search-field"
                                       promptText="Search registered users from admin views..."/>
                            <FontIcon iconLiteral="fth-search" iconSize="18"
                                      style="-fx-icon-color: #64748B;"
                                      StackPane.alignment="CENTER_LEFT"
                                      translateX="12"/>
                        </StackPane>
                    </HBox>

                    <HBox alignment="CENTER_RIGHT" spacing="8">
                        <Label text="ADMIN MODE" styleClass="badge, danger"
                               style="-fx-padding: 6 14; -fx-font-size: 11px;"/>
                    </HBox>
                </HBox>

                <ScrollPane fx:id="contentScroll" fitToWidth="true" fitToHeight="true"
                            hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
                    <StackPane fx:id="contentArea" styleClass="content-area"/>
                </ScrollPane>
            </VBox>
        </center>
    </BorderPane>
</VBox>
