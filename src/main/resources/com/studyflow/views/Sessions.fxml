<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.SessionsController"
      spacing="24" style="-fx-background-color: #020617;">

    <padding>
        <Insets top="0" right="0" bottom="24" left="0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4">
            <Label text="Sessions" styleClass="text-heading"/>
            <Label text="Manage all sessions stored in rl_5" styleClass="text-muted"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="sessionsCountLabel" text="0 sessions" styleClass="text-muted"/>
        <Button text="Back to Planning" styleClass="btn-secondary" onAction="#handleBackToPlanning">
            <graphic>
                <FontIcon iconLiteral="fth-arrow-left" iconSize="16"/>
            </graphic>
        </Button>
        <Button text="Add Session" styleClass="btn-primary" onAction="#handleAddSession">
            <graphic>
                <FontIcon iconLiteral="fth-plus" iconSize="16" iconColor="white"/>
            </graphic>
        </Button>
    </HBox>

    <VBox fx:id="formCard" styleClass="card" spacing="0">
        <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
            <StackPane styleClass="stat-icon-box, accent" prefWidth="36" prefHeight="36">
                <FontIcon iconLiteral="fth-edit-3" iconSize="16"/>
            </StackPane>
            <VBox spacing="2">
                <Label fx:id="formTitleLabel" text="Add Session" styleClass="card-title"/>
                <Label fx:id="formSubtitleLabel" text="Create a new session without leaving this page" styleClass="text-small"/>
            </VBox>
        </HBox>

        <VBox styleClass="card-body" spacing="18">
            <Label fx:id="formMessageLabel" managed="false" visible="false"/>

            <GridPane hgap="16" vgap="14">
                <columnConstraints>
                    <ColumnConstraints hgrow="NEVER" minWidth="120"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <HBox alignment="CENTER_LEFT" spacing="4" GridPane.rowIndex="0" GridPane.columnIndex="0">
                    <Label text="Title" styleClass="text-body"/>
                    <Label text="*" style="-fx-text-fill: #FB7185; -fx-font-size: 15px; -fx-font-weight: 700;"/>
                </HBox>
                <TextField fx:id="titleField" promptText="Enter session title" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <HBox alignment="CENTER_LEFT" spacing="4" GridPane.rowIndex="1" GridPane.columnIndex="0">
                    <Label text="Type" styleClass="text-body"/>
                    <Label text="*" style="-fx-text-fill: #FB7185; -fx-font-size: 15px; -fx-font-weight: 700;"/>
                </HBox>
                <ComboBox fx:id="typeComboBox" promptText="Select session type" maxWidth="1.7976931348623157E308" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Description" styleClass="text-body" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextArea fx:id="descriptionArea" promptText="Add a short description" prefRowCount="4" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </GridPane>

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button fx:id="cancelButton" text="Cancel" styleClass="btn-secondary" onAction="#handleCancelForm"/>
                <Button fx:id="saveButton" text="Save Session" styleClass="btn-primary" onAction="#handleSaveSession">
                    <graphic>
                        <FontIcon iconLiteral="fth-save" iconSize="16" iconColor="white"/>
                    </graphic>
                </Button>
            </HBox>
        </VBox>
    </VBox>

    <VBox styleClass="card" spacing="0">
        <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
            <StackPane styleClass="stat-icon-box, primary" prefWidth="36" prefHeight="36">
                <FontIcon iconLiteral="fth-calendar" iconSize="16"/>
            </StackPane>
            <VBox spacing="2">
                <Label text="Global Sessions View" styleClass="card-title"/>
                <Label text="List of sessions with edit and delete actions" styleClass="text-small"/>
            </VBox>
        </HBox>

        <TableView fx:id="sessionsTable" VBox.vgrow="ALWAYS" style="-fx-fixed-cell-size: 58;">
            <columns>
                <TableColumn fx:id="titleColumn" text="Title" prefWidth="260"/>
                <TableColumn fx:id="typeColumn" text="Type" prefWidth="200"/>
                <TableColumn fx:id="createdColumn" text="Created At" prefWidth="220"/>
                <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="260"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
