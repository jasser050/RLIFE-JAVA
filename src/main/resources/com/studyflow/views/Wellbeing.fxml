<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.studyflow.controllers.WellbeingController"
            fitToWidth="true"
            styleClass="landing-scroll">
    <content>
        <VBox spacing="22" styleClass="wellbeing-page">
            <padding>
                <Insets top="0" right="0" bottom="24" left="0"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="wellbeing-hero">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Stress &amp; Wellbeing" styleClass="text-heading"/>
                    <Label text="Track your mental health and find ways to relax" styleClass="wellbeing-subtitle"/>
                </VBox>
                <Button text="Take Assessment" styleClass="btn-secondary" onAction="#handleOpenQuiz">
                    <graphic>
                        <FontIcon iconLiteral="fth-clipboard" iconSize="15" iconColor="#E2E8F0"/>
                    </graphic>
                </Button>
                <Button text="Coping Tools" styleClass="btn-secondary" onAction="#handleOpenCopingTools">
                    <graphic>
                        <FontIcon iconLiteral="fth-heart" iconSize="15" iconColor="#E2E8F0"/>
                    </graphic>
                </Button>
                <Button text="Daily Check-in" styleClass="btn-primary" onAction="#handleOpenCheckin">
                    <graphic>
                        <FontIcon iconLiteral="fth-plus" iconSize="15" iconColor="white"/>
                    </graphic>
                </Button>
            </HBox>
            <Label fx:id="globalMessageLabel"
                   text=""
                   visible="false"
                   managed="false"
                   styleClass="text-small"/>

            <HBox fx:id="statsSection" spacing="16">
                <VBox styleClass="wellbeing-kpi-card, stress" spacing="8" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <StackPane styleClass="wellbeing-kpi-icon, stress-icon">
                            <FontIcon iconLiteral="fth-smile" iconSize="16"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label fx:id="avgStressLabel" text="0/10" styleClass="wellbeing-kpi-value"/>
                            <Label text="Avg. Stress Level" styleClass="wellbeing-kpi-label"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox styleClass="wellbeing-kpi-card, energy" spacing="8" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <StackPane styleClass="wellbeing-kpi-icon, energy-icon">
                            <FontIcon iconLiteral="fth-zap" iconSize="16"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label fx:id="avgEnergyLabel" text="0/10" styleClass="wellbeing-kpi-value"/>
                            <Label text="Avg. Energy Level" styleClass="wellbeing-kpi-label"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox styleClass="wellbeing-kpi-card, sleep" spacing="8" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <StackPane styleClass="wellbeing-kpi-icon, sleep-icon">
                            <FontIcon iconLiteral="fth-moon" iconSize="16"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label fx:id="avgSleepLabel" text="0h" styleClass="wellbeing-kpi-value"/>
                            <Label text="Avg. Sleep" styleClass="wellbeing-kpi-label"/>
                        </VBox>
                    </HBox>
                </VBox>
            </HBox>

            <Label fx:id="totalCheckinsLabel" visible="false" managed="false" text="0"/>
            <Label fx:id="moodLabel" visible="false" managed="false" text="Good"/>
            <Label fx:id="sleepLabel" visible="false" managed="false" text="7.5h"/>
            <Label fx:id="stressLabel" visible="false" managed="false" text="Low"/>
            <Label fx:id="energyLabel" visible="false" managed="false" text="High"/>
            <FlowPane fx:id="moodDistributionPane" visible="false" managed="false"/>
            <VBox fx:id="moodWeekBox" visible="false" managed="false"/>
            <VBox fx:id="habitsBox" visible="false" managed="false"/>
            <VBox fx:id="mindfulnessBox" visible="false" managed="false"/>
            <VBox fx:id="sleepLogBox" visible="false" managed="false"/>

            <VBox fx:id="overviewSection" spacing="20" VBox.vgrow="ALWAYS">
                <HBox spacing="20">
                    <VBox styleClass="card, wellbeing-panel" spacing="0" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <HBox styleClass="card-header, wellbeing-panel-header" alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="wellbeing-header-icon">
                                <FontIcon iconLiteral="fth-trending-up" iconSize="16"/>
                            </StackPane>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Stress Trend (Last 10 Days)" styleClass="card-title"/>
                                <Label text="Your latest stress evolution from check-ins" styleClass="text-small"/>
                            </VBox>
                        </HBox>
                        <VBox styleClass="card-body" spacing="10" prefHeight="320" minHeight="320">
                            <BarChart fx:id="stressChart" legendVisible="false" animated="false" categoryGap="10" barGap="4" prefHeight="280">
                                <xAxis>
                                    <CategoryAxis/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis lowerBound="0" upperBound="10" tickUnit="1"/>
                                </yAxis>
                            </BarChart>
                        </VBox>
                    </VBox>

                    <VBox styleClass="card, wellbeing-panel" spacing="0" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <HBox styleClass="card-header, wellbeing-panel-header" alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="wellbeing-header-icon">
                                <FontIcon iconLiteral="fth-clipboard" iconSize="16"/>
                            </StackPane>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Recent Check-ins" styleClass="card-title"/>
                                <Label text="Latest mood records with stress and sleep" styleClass="text-small"/>
                            </VBox>
                            <ComboBox fx:id="overviewSortCombo" prefWidth="160"/>
                            <Button text="View All" styleClass="btn-ghost" onAction="#handleViewAllHistory"/>
                        </HBox>
                        <VBox styleClass="card-body" spacing="10" prefHeight="320" minHeight="320">
                            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="wellbeing-inner-scroll" VBox.vgrow="ALWAYS">
                                <content>
                                    <VBox fx:id="recentCheckinsBox" spacing="10"/>
                                </content>
                            </ScrollPane>
                        </VBox>
                    </VBox>
                </HBox>

                <VBox styleClass="card, wellbeing-panel, wellbeing-tools-preview-shell" spacing="0">
                    <HBox styleClass="card-header, wellbeing-panel-header" alignment="CENTER_LEFT" spacing="10">
                        <StackPane styleClass="wellbeing-header-icon">
                            <FontIcon iconLiteral="fth-heart" iconSize="16"/>
                        </StackPane>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Coping Tools" styleClass="card-title"/>
                            <Label text="Quick exercises to help you relax" styleClass="text-small"/>
                        </VBox>
                        <Button text="View All" styleClass="btn-ghost" onAction="#handleOpenCopingTools"/>
                    </HBox>
                    <VBox styleClass="card-body" spacing="12">
                        <FlowPane fx:id="copingToolsPreviewPane" hgap="16" vgap="16" prefWrapLength="1400"/>
                    </VBox>
                </VBox>

            </VBox>

            <VBox fx:id="toolsSection" styleClass="wellbeing-tools-page" spacing="14" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Coping Tools" styleClass="tools-main-title"/>
                        <Label text="Techniques and exercises to help you manage stress and improve wellbeing" styleClass="tools-main-subtitle"/>
                    </VBox>
                    <Button text="Back to Overview" styleClass="btn-secondary" onAction="#handleBackToOverview"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="wellbeing-quote-controls, tools-control-bar">
                    <Label text="Quote Type" styleClass="text-small"/>
                    <ComboBox fx:id="quoteTypeCombo" prefWidth="140"/>
                    <CheckBox fx:id="quoteEnabledToggle" text="Enable quotes"/>
                    <Button text="Reset position" styleClass="btn-secondary, tools-reset-btn" onAction="#handleResetQuotePosition"/>
                    <Label text="Drag the quote card to any position on screen." styleClass="text-small, tools-control-hint"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Apply" styleClass="btn-secondary" onAction="#handleApplyQuoteSettings"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="tools-highlight-banner">
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Feeling overwhelmed?" styleClass="tools-highlight-title"/>
                        <Label text="Try a quick breathing exercise to help you relax and refocus." styleClass="tools-highlight-subtitle"/>
                    </VBox>
                    <Button text="Go to Breathing Tool" styleClass="btn-secondary, tools-highlight-btn" onAction="#handleStartBreathingTool"/>
                </HBox>

                <VBox spacing="0" styleClass="card, wellbeing-panel">
                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="card-header, wellbeing-panel-header">
                        <StackPane styleClass="wellbeing-tool-icon, tool-icon-mood_camera">
                            <FontIcon iconLiteral="fth-video" iconSize="18"/>
                        </StackPane>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Mood Camera" styleClass="card-title"/>
                            <Label text="Detect your mood from webcam and apply it to daily check-in." styleClass="text-small" wrapText="true"/>
                        </VBox>
                        <Button text="Open Camera" styleClass="btn-secondary" onAction="#handleOpenMoodCameraTool"/>
                    </HBox>
                    <VBox spacing="6" styleClass="card-body">
                        <Label fx:id="cameraMoodResultLabel" text="No mood detected yet." styleClass="text-small"/>
                    </VBox>
                </VBox>

                <FlowPane fx:id="copingToolsPane" hgap="16" vgap="16" prefWrapLength="1250"/>

                <VBox spacing="14" styleClass="tools-tips-shell">
                    <Label text="Quick Wellbeing Tips" styleClass="tools-tips-title"/>
                    <HBox spacing="12">
                        <VBox spacing="4" styleClass="tools-tip-card" HBox.hgrow="ALWAYS">
                            <FontIcon iconLiteral="fth-droplet" styleClass="tools-tip-emoji"/>
                            <Label text="Stay Hydrated" styleClass="tools-tip-title"/>
                            <Label text="Drink at least 8 glasses of water daily" styleClass="tools-tip-desc" wrapText="true"/>
                        </VBox>
                        <VBox spacing="4" styleClass="tools-tip-card" HBox.hgrow="ALWAYS">
                            <FontIcon iconLiteral="fth-activity" styleClass="tools-tip-emoji"/>
                            <Label text="Take Breaks" styleClass="tools-tip-title"/>
                            <Label text="Walk for 5 mins every hour of studying" styleClass="tools-tip-desc" wrapText="true"/>
                        </VBox>
                        <VBox spacing="4" styleClass="tools-tip-card" HBox.hgrow="ALWAYS">
                            <FontIcon iconLiteral="fth-moon" styleClass="tools-tip-emoji"/>
                            <Label text="Sleep Well" styleClass="tools-tip-title"/>
                            <Label text="Aim for 7-8 hours of quality sleep" styleClass="tools-tip-desc" wrapText="true"/>
                        </VBox>
                        <VBox spacing="4" styleClass="tools-tip-card" HBox.hgrow="ALWAYS">
                            <FontIcon iconLiteral="fth-target" styleClass="tools-tip-emoji"/>
                            <Label text="Set Boundaries" styleClass="tools-tip-title"/>
                            <Label text="It's okay to say no sometimes" styleClass="tools-tip-desc" wrapText="true"/>
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>

            <VBox fx:id="inlineToolSection" styleClass="card, wellbeing-panel" spacing="0" visible="false" managed="false">
                <HBox styleClass="card-header, wellbeing-panel-header" alignment="CENTER_LEFT" spacing="10">
                    <StackPane styleClass="wellbeing-header-icon">
                        <FontIcon iconLiteral="fth-play-circle" iconSize="16"/>
                    </StackPane>
                    <Label fx:id="inlineToolTitleLabel" text="Tool" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Back to Coping Tools" styleClass="btn-secondary" onAction="#handleCloseInlineTool"/>
                </HBox>
                <StackPane fx:id="inlineToolHost" styleClass="card-body"/>
            </VBox>

            <VBox fx:id="formSection" styleClass="card, wellbeing-form-shell" visible="false" managed="false" spacing="0">
                <HBox styleClass="card-header, wellbeing-panel-header" alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="wellbeing-header-icon">
                        <FontIcon iconLiteral="fth-edit-3" iconSize="16"/>
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="formTitleLabel" text="Daily Check-in" styleClass="card-title"/>
                        <Label text="How are you feeling today?" styleClass="text-small"/>
                    </VBox>
                    <Button text="Back" styleClass="btn-secondary" onAction="#handleBackToOverview"/>
                </HBox>

                <VBox styleClass="card-body" spacing="20">
                    <VBox spacing="8" styleClass="wellbeing-input-card">
                        <Label text="Mood" styleClass="text-subheading" style="-fx-font-size: 22px;"/>
                        <Label text="Select the emoji that best represents how you're feeling" styleClass="text-small"/>
                        <HBox fx:id="moodButtonsBox" spacing="12" maxWidth="Infinity">
                            <Button text="😃&#10;Great" userData="great" onAction="#handleMoodSelection" styleClass="wellbeing-choice-card, mood-great" HBox.hgrow="ALWAYS"/>
                            <Button text="😊&#10;Good" userData="good" onAction="#handleMoodSelection" styleClass="wellbeing-choice-card, mood-good, selected" HBox.hgrow="ALWAYS"/>
                            <Button text="😐&#10;Okay" userData="okay" onAction="#handleMoodSelection" styleClass="wellbeing-choice-card, mood-okay" HBox.hgrow="ALWAYS"/>
                            <Button text="😰&#10;Stressed" userData="stressed" onAction="#handleMoodSelection" styleClass="wellbeing-choice-card, mood-stressed" HBox.hgrow="ALWAYS"/>
                            <Button text="😪&#10;Tired" userData="tired" onAction="#handleMoodSelection" styleClass="wellbeing-choice-card, mood-tired" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <HBox spacing="18">
                        <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="wellbeing-input-card">
                            <Label text="Stress Level" styleClass="text-subheading" style="-fx-font-size: 18px;"/>
                            <Label text="Rate your current stress (1 = very relaxed, 10 = very stressed)" styleClass="text-small"/>
                            <Slider fx:id="stressSlider" min="1" max="10" value="5" majorTickUnit="1" minorTickCount="0" snapToTicks="true" showTickLabels="true"/>
                            <HBox alignment="CENTER_LEFT">
                                <Label text="Relaxed" styleClass="wellbeing-slider-low"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="stressValueLabel" text="5" styleClass="wellbeing-slider-value"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Stressed" styleClass="wellbeing-slider-high"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="wellbeing-input-card">
                            <Label text="Energy Level" styleClass="text-subheading" style="-fx-font-size: 18px;"/>
                            <Label text="Rate your energy (1 = exhausted, 10 = full of energy)" styleClass="text-small"/>
                            <Slider fx:id="energySlider" min="1" max="10" value="7" majorTickUnit="1" minorTickCount="0" snapToTicks="true" showTickLabels="true"/>
                            <HBox alignment="CENTER_LEFT">
                                <Label text="Exhausted" styleClass="wellbeing-slider-high"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="energyValueLabel" text="7" styleClass="wellbeing-slider-value"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Energized" styleClass="wellbeing-slider-low"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <VBox spacing="10" styleClass="wellbeing-input-card">
                        <Label text="Sleep" styleClass="text-subheading" style="-fx-font-size: 18px;"/>
                        <Label text="How many hours did you sleep last night?" styleClass="text-small"/>
                        <HBox fx:id="sleepButtonsBox" spacing="10">
                            <Button text="4&#10;hrs" userData="4" onAction="#handleSleepSelection" styleClass="wellbeing-sleep-card" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            <Button text="5&#10;hrs" userData="5" onAction="#handleSleepSelection" styleClass="wellbeing-sleep-card" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            <Button text="6&#10;hrs" userData="6" onAction="#handleSleepSelection" styleClass="wellbeing-sleep-card" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            <Button text="7&#10;hrs" userData="7" onAction="#handleSleepSelection" styleClass="wellbeing-sleep-card, selected" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            <Button text="8&#10;hrs" userData="8" onAction="#handleSleepSelection" styleClass="wellbeing-sleep-card" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            <Button text="9&#10;hrs" userData="9" onAction="#handleSleepSelection" styleClass="wellbeing-sleep-card" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            <Button text="10&#10;hrs" userData="10" onAction="#handleSleepSelection" styleClass="wellbeing-sleep-card" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            <Button text="10+&#10;hrs" userData="11" onAction="#handleSleepSelection" styleClass="wellbeing-sleep-card" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="8" styleClass="wellbeing-input-card">
                        <Label text="Notes" styleClass="text-subheading" style="-fx-font-size: 18px;"/>
                        <TextArea fx:id="notesArea" promptText="How are you feeling? What's on your mind?" prefRowCount="4" wrapText="true" styleClass="wellbeing-notes-area"/>
                        <Label fx:id="notesErrorLabel" text="" styleClass="auth-error" visible="false" managed="false"/>
                    </VBox>

                    <HBox spacing="12">
                        <Button fx:id="saveButton" text="Save Check-in" styleClass="btn-primary" onAction="#handleSaveCheckin"/>
                        <Button fx:id="cancelEditButton" text="Cancel" styleClass="btn-secondary" onAction="#handleCancelEdit"/>
                    </HBox>
                </VBox>
            </VBox>

            <VBox fx:id="historySection" spacing="18" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="wellbeing-hero">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Wellbeing / Check-ins" styleClass="text-small"/>
                        <Label text="Check-in History" styleClass="text-heading"/>
                        <Label text="Track your mood, stress, and energy over time" styleClass="text-muted"/>
                    </VBox>
                    <Button text="Back" styleClass="btn-secondary" onAction="#handleBackToOverview"/>
                    <Button text="New Check-in" styleClass="btn-primary" onAction="#handleOpenCheckin"/>
                </HBox>

                <HBox spacing="16">
                    <VBox styleClass="wellbeing-kpi-card, neutral" spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER">
                        <Label fx:id="historyTotalLabel" text="0" styleClass="wellbeing-kpi-value"/>
                        <Label text="Total Check-ins" styleClass="wellbeing-kpi-label"/>
                    </VBox>
                    <VBox styleClass="wellbeing-kpi-card, stress" spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER">
                        <Label fx:id="historyAvgStressLabel" text="0/10" styleClass="wellbeing-kpi-value"/>
                        <Label text="Avg. Stress" styleClass="wellbeing-kpi-label"/>
                    </VBox>
                    <VBox styleClass="wellbeing-kpi-card, energy" spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER">
                        <Label fx:id="historyAvgEnergyLabel" text="0/10" styleClass="wellbeing-kpi-value"/>
                        <Label text="Avg. Energy" styleClass="wellbeing-kpi-label"/>
                    </VBox>
                    <VBox styleClass="wellbeing-kpi-card, sleep" spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER">
                        <Label fx:id="historyAvgSleepLabel" text="0h" styleClass="wellbeing-kpi-value"/>
                        <Label text="Avg. Sleep" styleClass="wellbeing-kpi-label"/>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="card, wellbeing-filter-bar">
                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>
                    <TextField fx:id="historySearchField" promptText="Search mood or notes..." prefWidth="240"/>
                    <ComboBox fx:id="historyMoodFilter" prefWidth="170"/>
                    <ComboBox fx:id="historySortCombo" prefWidth="190"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Refresh" styleClass="btn-secondary" onAction="#handleRefresh"/>
                </HBox>

                <VBox styleClass="card, wellbeing-panel" spacing="0">
                    <HBox styleClass="card-header, wellbeing-panel-header" alignment="CENTER_LEFT" spacing="12">
                        <StackPane styleClass="wellbeing-header-icon">
                            <FontIcon iconLiteral="fth-file-text" iconSize="16"/>
                        </StackPane>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Entries" styleClass="card-title"/>
                            <Label text="Edit or delete each check-in line." styleClass="text-small"/>
                        </VBox>
                    </HBox>
                    <VBox fx:id="historyListBox" styleClass="card-body" spacing="10"/>
                </VBox>
            </VBox>

            <VBox fx:id="quizSection" styleClass="card, wellbeing-form-shell" visible="false" managed="false" spacing="0">
                <HBox styleClass="card-header, wellbeing-panel-header" alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="wellbeing-header-icon">
                        <FontIcon iconLiteral="fth-clipboard" iconSize="16"/>
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Stress Assessment Quiz" styleClass="card-title"/>
                        <Label text="Answer every question to calculate your stress score." styleClass="text-small"/>
                    </VBox>
                    <Button text="Back" styleClass="btn-secondary" onAction="#handleQuizBackToOverview"/>
                </HBox>

                <VBox styleClass="card-body" spacing="20">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Question " styleClass="text-small"/>
                        <Label fx:id="quizCurrentQuestionLabel" text="1" styleClass="text-body"/>
                        <Label text=" / " styleClass="text-small"/>
                        <Label fx:id="quizTotalQuestionsLabel" text="0" styleClass="text-small"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="quizProgressPercentLabel" text="0%" styleClass="text-small"/>
                    </HBox>
                    <ProgressBar fx:id="quizProgressBar" progress="0.0" prefHeight="8.0" maxWidth="Infinity"/>

                    <VBox styleClass="wellbeing-input-card" spacing="12">
                        <Label fx:id="quizQuestionTitleLabel" text="Question 1" styleClass="text-subheading" style="-fx-font-size: 18px;"/>
                        <Label fx:id="quizQuestionTextLabel" text="Question text..." wrapText="true" styleClass="text-body"/>
                    </VBox>

                    <VBox fx:id="quizOptionsBox" spacing="10"/>

                    <HBox spacing="12">
                        <Button fx:id="quizPrevButton" text="Previous" styleClass="btn-secondary" onAction="#handleQuizPrevious"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="quizNextButton" text="Next" styleClass="btn-primary" onAction="#handleQuizNext"/>
                        <Button fx:id="quizSubmitButton" text="Submit Assessment" styleClass="btn-primary" visible="false" managed="false" onAction="#handleQuizSubmit"/>
                    </HBox>
                </VBox>
            </VBox>

            <VBox fx:id="quizModeSection" styleClass="wellbeing-quiz-mode-page" visible="false" managed="false" spacing="26" alignment="TOP_CENTER">
                <VBox alignment="CENTER" spacing="10" styleClass="quiz-mode-hero">
                    <StackPane styleClass="quiz-mode-hero-icon">
                        <FontIcon iconLiteral="fth-clipboard" iconSize="22"/>
                    </StackPane>
                    <Label text="Stress Assessment" styleClass="quiz-mode-hero-title"/>
                    <Label text="Take this quick assessment to understand your current stress level and receive personalized recommendations."
                           styleClass="quiz-mode-hero-subtitle"
                           wrapText="true"/>
                </VBox>

                <VBox styleClass="quiz-mode-shell" spacing="14">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Choisir le mode du quiz" styleClass="card-title"/>
                            <Label text="Choisissez entre quiz simple (admin) et quiz AI." styleClass="text-small"/>
                        </VBox>
                        <Button text="Back" styleClass="btn-secondary" onAction="#handleQuizBackToOverview"/>
                    </HBox>

                    <HBox spacing="12">
                        <Button styleClass="quiz-mode-card, quiz-mode-card-simple"
                                onAction="#handleStartSimpleQuiz"
                                HBox.hgrow="ALWAYS"
                                maxWidth="Infinity">
                            <graphic>
                                <VBox spacing="4" alignment="TOP_LEFT">
                                    <Label text="Quiz Simple" styleClass="quiz-mode-card-title"/>
                                    <Label text="Questions créées par l'admin." styleClass="quiz-mode-card-desc" wrapText="true"/>
                                </VBox>
                            </graphic>
                        </Button>
                        <Button styleClass="quiz-mode-card, quiz-mode-card-ai"
                                onAction="#handleStartAiQuiz"
                                HBox.hgrow="ALWAYS"
                                maxWidth="Infinity">
                            <graphic>
                                <VBox spacing="4" alignment="TOP_LEFT">
                                    <Label text="Quiz AI" styleClass="quiz-mode-card-title"/>
                                    <Label text="Questions AI non répétées pour l'etudiant." styleClass="quiz-mode-card-desc" wrapText="true"/>
                                </VBox>
                            </graphic>
                        </Button>
                    </HBox>
                </VBox>
            </VBox>

            <VBox fx:id="quizResultsSection" styleClass="card, wellbeing-form-shell" visible="false" managed="false" spacing="0">
                <HBox styleClass="card-header, wellbeing-panel-header" alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="wellbeing-header-icon">
                        <FontIcon iconLiteral="fth-check-circle" iconSize="16"/>
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Quiz Results" styleClass="card-title"/>
                        <Label text="Your stress level and personalized recommendations." styleClass="text-small"/>
                    </VBox>
                    <Button text="Back to Dashboard" styleClass="btn-secondary" onAction="#handleQuizBackToOverview"/>
                </HBox>

                <VBox styleClass="card-body" spacing="20">
                    <VBox spacing="8" alignment="CENTER">
                        <Label fx:id="quizResultEmojiLabel" text="🙂" style="-fx-font-size: 46px;"/>
                        <Label fx:id="quizResultTitleLabel" text="Good Results" styleClass="text-heading" style="-fx-font-size: 28px;"/>
                        <Label fx:id="quizResultSubtitleLabel" text="Your stress score is ready." styleClass="text-muted"/>
                    </VBox>

                    <HBox spacing="16">
                        <VBox styleClass="wellbeing-kpi-card, energy" spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Total Score" styleClass="wellbeing-kpi-label"/>
                            <Label fx:id="quizResultScoreLabel" text="0 / 40" styleClass="wellbeing-kpi-value"/>
                        </VBox>
                        <VBox styleClass="wellbeing-kpi-card, stress" spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Stress Level" styleClass="wellbeing-kpi-label"/>
                            <Label fx:id="quizResultLevelLabel" text="Mild" styleClass="wellbeing-kpi-value"/>
                        </VBox>
                    </HBox>

                    <VBox styleClass="wellbeing-input-card" spacing="10">
                        <Label text="Interpretation" styleClass="text-subheading"/>
                        <Label fx:id="quizResultInterpretationLabel" wrapText="true" styleClass="text-body"/>
                    </VBox>

                    <VBox spacing="10">
                        <Label text="Personalized Recommendations" styleClass="text-subheading"/>
                        <VBox fx:id="quizRecommendationsBox" spacing="10"/>
                    </VBox>

                    <VBox spacing="10" styleClass="wellbeing-input-card">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Other AI Recommendations" styleClass="text-subheading"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="quizLoadAiSuggestionsButton"
                                    text="Show AI Suggestions"
                                    styleClass="btn-primary"
                                    onAction="#handleLoadAiSuggestions"/>
                        </HBox>
                        <Label fx:id="quizAiSuggestionsMessageLabel"
                               text="Click the button to generate extra recommendations adapted to your stress result."
                               wrapText="true"
                               styleClass="text-small"/>
                        <VBox fx:id="quizAiSuggestionsBox" spacing="10"/>

                        <VBox fx:id="quizSelectedRecommendationBox"
                              visible="false"
                              managed="false"
                              spacing="6"
                              styleClass="wellbeing-input-card">
                            <Label text="Selected Recommendation" styleClass="text-small"/>
                            <Label fx:id="quizSelectedRecommendationTitleLabel" styleClass="text-subheading"/>
                            <Label fx:id="quizSelectedRecommendationContentLabel" wrapText="true" styleClass="text-body"/>
                        </VBox>
                    </VBox>

                    <HBox spacing="12">
                        <Button text="Retake Quiz" styleClass="btn-primary" onAction="#handleRetakeQuiz"/>
                        <Button text="New Check-in" styleClass="btn-secondary" onAction="#handleOpenCheckin"/>
                    </HBox>
                </VBox>
            </VBox>

            <Separator/>
        </VBox>
    </content>
</ScrollPane>