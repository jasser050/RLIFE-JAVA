<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.AIGeneratorController"
      spacing="0"
      style="-fx-background-color:#0F172A;-fx-background-radius:16;-fx-border-color:#334155;-fx-border-radius:16;-fx-border-width:1;-fx-min-width:480;-fx-max-width:520;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-padding:20 24 16 24;-fx-border-color:#1E293B;-fx-border-width:0 0 1 0;">
        <StackPane prefWidth="36" prefHeight="36"
                   style="-fx-background-color:linear-gradient(to bottom right,#7C3AED,#8B5CF6);-fx-background-radius:10;">
            <FontIcon iconLiteral="fth-cpu" iconSize="16" iconColor="white"/>
        </StackPane>
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="✨  AI Flashcard Generator"
                   style="-fx-text-fill:#F8FAFC;-fx-font-size:15px;-fx-font-weight:800;"/>
            <Label text="Powered by OpenRouter · Mistral 7B"
                   style="-fx-text-fill:#64748B;-fx-font-size:11px;"/>
        </VBox>
    </HBox>

    <!-- Body -->
    <VBox spacing="16" style="-fx-padding:20 24;">

        <!-- Topic input -->
        <VBox spacing="6">
            <Label text="Topic or Text  *"
                   style="-fx-text-fill:#CBD5E1;-fx-font-size:12px;-fx-font-weight:600;"/>
            <TextArea fx:id="topicArea" prefRowCount="4"
                      promptText="e.g. 'Python list comprehensions' or paste any text..."
                      style="-fx-control-inner-background:#1E293B;-fx-background-color:#1E293B;
                             -fx-text-fill:#F8FAFC;-fx-prompt-text-fill:#475569;
                             -fx-border-color:#334155;-fx-border-width:1.5;
                             -fx-border-radius:10;-fx-background-radius:10;-fx-font-size:13px;"/>
        </VBox>

        <!-- Count + Difficulty row -->
        <HBox spacing="14">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Number of cards"
                       style="-fx-text-fill:#CBD5E1;-fx-font-size:12px;-fx-font-weight:600;"/>
                <Spinner fx:id="countSpinner" min="1" max="20" initialValue="5" editable="true"
                         style="-fx-background-color:#1E293B;-fx-border-color:#334155;
                                -fx-border-radius:10;-fx-background-radius:10;-fx-font-size:13px;"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Difficulty"
                       style="-fx-text-fill:#CBD5E1;-fx-font-size:12px;-fx-font-weight:600;"/>
                <ComboBox fx:id="difficultyCombo" maxWidth="Infinity"
                          style="-fx-background-color:#1E293B;-fx-border-color:#334155;
                                 -fx-border-radius:10;-fx-background-radius:10;-fx-font-size:13px;"/>
            </VBox>
        </HBox>

        <!-- Status label -->
        <Label fx:id="statusLabel" text="" wrapText="true"
               style="-fx-text-fill:#94A3B8;-fx-font-size:11px;" visible="false" managed="false"/>

        <!-- Progress bar -->
        <ProgressBar fx:id="progressBar" maxWidth="Infinity" prefHeight="4"
                     style="-fx-accent:#7C3AED;" visible="false" managed="false"/>

    </VBox>

    <!-- Footer buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT"
          style="-fx-padding:12 24 20 24;-fx-border-color:#1E293B;-fx-border-width:1 0 0 0;">
        <Button fx:id="cancelBtn" text="Cancel" onAction="#onCancel"
                style="-fx-background-color:#1E293B;-fx-text-fill:#94A3B8;-fx-font-size:13px;
                       -fx-font-weight:600;-fx-background-radius:10;-fx-cursor:hand;
                       -fx-padding:10 22;-fx-border-color:#334155;-fx-border-radius:10;-fx-border-width:1;"/>
        <Button fx:id="generateBtn" text="✨  Generate" onAction="#onGenerate"
                style="-fx-background-color:linear-gradient(to right,#7C3AED,#6D28D9);
                       -fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:700;
                       -fx-background-radius:10;-fx-cursor:hand;-fx-padding:10 26;"/>
    </HBox>
</VBox>
