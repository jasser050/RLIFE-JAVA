<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.ProjectEditController"
      spacing="16"
      styleClass="page-section">
    <Label text="Edit Project" styleClass="text-heading"/>
    <Label fx:id="feedbackLabel" managed="false" visible="false" maxWidth="Infinity" styleClass="inline-alert, inline-alert-success"/>

    <VBox styleClass="card, form-shell" spacing="12">
        <VBox spacing="6">
            <Label text="Title" styleClass="form-label"/>
            <TextField fx:id="titleField" styleClass="form-input"/>
            <Label fx:id="titleError" styleClass="field-error" visible="false" managed="false"/>
        </VBox>

        <HBox spacing="12">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Start Date" styleClass="form-label"/>
                <DatePicker fx:id="startDatePicker" maxWidth="Infinity" styleClass="form-date"/>
                <Label fx:id="startDateError" styleClass="field-error" visible="false" managed="false"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="End Date" styleClass="form-label"/>
                <DatePicker fx:id="endDatePicker" maxWidth="Infinity" styleClass="form-date"/>
                <Label fx:id="endDateError" styleClass="field-error" visible="false" managed="false"/>
            </VBox>
        </HBox>

        <VBox spacing="6">
            <Label text="Status" styleClass="form-label"/>
            <ComboBox fx:id="statusCombo" maxWidth="Infinity" styleClass="form-combo"/>
        </VBox>

        <VBox spacing="6">
            <HBox alignment="CENTER_LEFT">
                <Label text="Description" styleClass="form-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="descriptionHintLabel" styleClass="text-muted"/>
            </HBox>
            <TextArea fx:id="descriptionArea" styleClass="form-textarea" wrapText="true" promptText="500 characters maximum."/>
        </VBox>

        <HBox spacing="10">
            <Button fx:id="saveButton" text="Save Changes" onAction="#handleSave" styleClass="btn-primary" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            <Button text="Cancel" onAction="#handleCancel" styleClass="btn-secondary"/>
        </HBox>
    </VBox>

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
</VBox>
