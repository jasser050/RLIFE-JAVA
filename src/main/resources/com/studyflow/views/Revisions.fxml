<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.studyflow.controllers.RevisionsController"
           >

    <VBox fx:id="listView" spacing="24">
        <padding>
            <Insets top="0" right="0" bottom="24" left="0"/>
        </padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Flashcards &amp; Revision" style="-fx-text-fill:#F8FAFC;-fx-font-size:22px;-fx-font-weight:800;"/>
                <Label text="Study smarter with spaced repetition" style="-fx-text-fill:#64748B;-fx-font-size:12px;"/>
            </VBox>

            <!-- Search Bar -->
            <HBox alignment="CENTER_LEFT" spacing="10" prefWidth="390"
                  style="-fx-background-color:#1E293B;-fx-border-color:#334155;-fx-border-radius:14;-fx-background-radius:14;-fx-padding:0 14;">
                <FontIcon iconLiteral="fth-search" iconSize="15" iconColor="#94A3B8" mouseTransparent="true"/>
                <TextField fx:id="searchField" promptText="Search decks..." HBox.hgrow="ALWAYS"
                           style="-fx-background-color:transparent;-fx-text-fill:#F8FAFC;-fx-prompt-text-fill:#64748B;-fx-border-color:transparent;-fx-padding:10 0;-fx-font-size:13px;"/>
            </HBox>

            <!-- Sort Combo -->
            <HBox alignment="CENTER_LEFT" spacing="8" prefWidth="180"
                  style="-fx-background-color:#1E293B;-fx-border-color:#334155;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:0 10;">
                <FontIcon iconLiteral="fth-list" iconSize="13" iconColor="#94A3B8"/>
                <ComboBox fx:id="sortCombo" promptText="Sort" HBox.hgrow="ALWAYS"
                          style="-fx-background-color:transparent;-fx-border-color:transparent;-fx-font-size:12px;"/>
            </HBox>

            <!-- Export PDF Button -->
            <Button fx:id="exportPdfBtn" text=" Export PDF" onAction="#exportDecksToPdf"
                    style="-fx-background-color:rgba(244,114,182,0.15);-fx-text-fill:#F472B6;-fx-font-size:12px;-fx-font-weight:700;-fx-background-radius:12;-fx-cursor:hand;-fx-padding:8 16;-fx-border-color:#F472B6;-fx-border-radius:12;-fx-border-width:1.5;">
                <graphic>
                    <FontIcon iconLiteral="fth-file-text" iconSize="14" iconColor="#F472B6"/>
                </graphic>
                <tooltip>
                    <Tooltip text="Download decks list as PDF"/>
                </tooltip>
            </Button>

            <!-- Create Button -->
            <Button text=" Create Deck" onAction="#showAddView"
                    style="-fx-background-color:linear-gradient(to right,#7C3AED,#6D28D9);-fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:700;-fx-background-radius:12;-fx-cursor:hand;-fx-padding:9 20;">
                <graphic>
                    <FontIcon iconLiteral="fth-plus" iconSize="14" iconColor="white"/>
                </graphic>
            </Button>
        </HBox>

        <!-- Stats Cards -->
        <HBox spacing="16">
            <VBox style="-fx-background-color:#0F172A;-fx-background-radius:16;-fx-border-color:#1E293B;-fx-border-radius:16;-fx-border-width:1;-fx-padding:14 18;" spacing="6" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane prefWidth="38" prefHeight="38" style="-fx-background-color:rgba(139,92,246,0.15);-fx-background-radius:12;">
                        <FontIcon iconLiteral="fth-layers" iconSize="18" iconColor="#A78BFA"/>
                    </StackPane>
                    <VBox spacing="1">
                        <Label fx:id="totalDecksLabel" text="0" style="-fx-text-fill:#F8FAFC;-fx-font-size:22px;-fx-font-weight:800;"/>
                        <Label text="Total Decks" style="-fx-text-fill:#64748B;-fx-font-size:11px;-fx-font-weight:500;"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox style="-fx-background-color:#0F172A;-fx-background-radius:16;-fx-border-color:#1E293B;-fx-border-radius:16;-fx-border-width:1;-fx-padding:14 18;" spacing="6" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane prefWidth="38" prefHeight="38" style="-fx-background-color:rgba(52,211,153,0.15);-fx-background-radius:12;">
                        <FontIcon iconLiteral="fth-check-circle" iconSize="18" iconColor="#34D399"/>
                    </StackPane>
                    <VBox spacing="1">
                        <Label fx:id="masteredLabel" text="0" style="-fx-text-fill:#F8FAFC;-fx-font-size:22px;-fx-font-weight:800;"/>
                        <Label text="Cards Mastered" style="-fx-text-fill:#64748B;-fx-font-size:11px;-fx-font-weight:500;"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox style="-fx-background-color:#0F172A;-fx-background-radius:16;-fx-border-color:#1E293B;-fx-border-radius:16;-fx-border-width:1;-fx-padding:14 18;" spacing="6" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane prefWidth="38" prefHeight="38" style="-fx-background-color:rgba(251,191,36,0.15);-fx-background-radius:12;">
                        <FontIcon iconLiteral="fth-clock" iconSize="18" iconColor="#FBBF24"/>
                    </StackPane>
                    <VBox spacing="1">
                        <Label fx:id="dueReviewLabel" text="0" style="-fx-text-fill:#F8FAFC;-fx-font-size:22px;-fx-font-weight:800;"/>
                        <Label text="Due for Review" style="-fx-text-fill:#64748B;-fx-font-size:11px;-fx-font-weight:500;"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox style="-fx-background-color:#0F172A;-fx-background-radius:16;-fx-border-color:#1E293B;-fx-border-radius:16;-fx-border-width:1;-fx-padding:14 18;" spacing="6" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane prefWidth="38" prefHeight="38" style="-fx-background-color:rgba(244,114,182,0.15);-fx-background-radius:12;">
                        <FontIcon iconLiteral="fth-zap" iconSize="18" iconColor="#F472B6"/>
                    </StackPane>
                    <VBox spacing="1">
                        <Label fx:id="streakLabel" text="0" style="-fx-text-fill:#F8FAFC;-fx-font-size:22px;-fx-font-weight:800;"/>
                        <Label text="Day Streak" style="-fx-text-fill:#64748B;-fx-font-size:11px;-fx-font-weight:500;"/>
                    </VBox>
                </HBox>
            </VBox>
        </HBox>

        <!-- Main Content — spacing réduit de 20 → 8 -->
        <HBox spacing="8" VBox.vgrow="ALWAYS">

            <!-- Decks Grid -->
            <VBox spacing="16" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Your Decks" style="-fx-text-fill:#F8FAFC;-fx-font-size:16px;-fx-font-weight:700;" HBox.hgrow="ALWAYS"/>
                    <HBox spacing="6">
                        <Button text="All" style="-fx-background-color:#7C3AED;-fx-text-fill:white;-fx-font-size:11px;-fx-font-weight:600;-fx-background-radius:20;-fx-padding:6 14;-fx-cursor:hand;"/>
                        <Button text="In Progress" style="-fx-background-color:#1E293B;-fx-text-fill:#94A3B8;-fx-font-size:11px;-fx-font-weight:600;-fx-background-radius:20;-fx-padding:6 14;-fx-cursor:hand;-fx-border-color:#334155;-fx-border-radius:20;-fx-border-width:1;"/>
                        <Button text="Mastered" style="-fx-background-color:#1E293B;-fx-text-fill:#94A3B8;-fx-font-size:11px;-fx-font-weight:600;-fx-background-radius:20;-fx-padding:6 14;-fx-cursor:hand;-fx-border-color:#334155;-fx-border-radius:20;-fx-border-width:1;"/>
                    </HBox>
                </HBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color:transparent;-fx-background:transparent;">
                    <FlowPane fx:id="decksGrid" hgap="18" vgap="18" prefWrapLength="900"/>
                </ScrollPane>
            </VBox>

            <!-- Right Sidebar — prefWidth augmenté de 320 → 380 -->
            <VBox prefWidth="380" spacing="16">

                <!-- Global Success Rate -->
                <VBox style="-fx-background-color:#0F172A;-fx-background-radius:16;-fx-border-color:#1E293B;-fx-border-radius:16;-fx-border-width:1;-fx-padding:16 18;" spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <StackPane prefWidth="28" prefHeight="28" style="-fx-background-color:linear-gradient(to bottom right,#7C3AED,#8B5CF6);-fx-background-radius:8;">
                            <FontIcon iconLiteral="fth-pie-chart" iconSize="14" iconColor="white"/>
                        </StackPane>
                        <Label text="Global Success Rate" style="-fx-text-fill:#F8FAFC;-fx-font-size:13px;-fx-font-weight:700;"/>
                    </HBox>
                    <!-- prefWidth augmenté de 280 → 340 -->
                    <StackPane fx:id="donutChartPane" prefHeight="140" prefWidth="340"/>
                </VBox>

                <!-- Weekly Progress -->
                <VBox style="-fx-background-color:#0F172A;-fx-background-radius:16;-fx-border-color:#1E293B;-fx-border-radius:16;-fx-border-width:1;-fx-padding:16 18;" spacing="10" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <StackPane prefWidth="28" prefHeight="28" style="-fx-background-color:linear-gradient(to bottom right,#059669,#10B981);-fx-background-radius:8;">
                            <FontIcon iconLiteral="fth-trending-up" iconSize="14" iconColor="white"/>
                        </StackPane>
                        <Label text="Weekly Progress" style="-fx-text-fill:#F8FAFC;-fx-font-size:13px;-fx-font-weight:700;"/>
                    </HBox>
                    <!-- prefWidth augmenté de 280 → 340 -->
                    <StackPane fx:id="lineChartPane" prefHeight="140" prefWidth="340" VBox.vgrow="ALWAYS"/>
                </VBox>

                <!-- Mastery Distribution -->
                <VBox style="-fx-background-color:#0F172A;-fx-background-radius:16;-fx-border-color:#1E293B;-fx-border-radius:16;-fx-border-width:1;-fx-padding:16 18;" spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <StackPane prefWidth="28" prefHeight="28" style="-fx-background-color:linear-gradient(to bottom right,#D97706,#F59E0B);-fx-background-radius:8;">
                            <FontIcon iconLiteral="fth-bar-chart-2" iconSize="14" iconColor="white"/>
                        </StackPane>
                        <Label text="Mastery Distribution" style="-fx-text-fill:#F8FAFC;-fx-font-size:13px;-fx-font-weight:700;"/>
                    </HBox>
                    <!-- prefWidth augmenté de 280 → 340 -->
                    <StackPane fx:id="barChartPane" prefHeight="120" prefWidth="340"/>
                </VBox>

            </VBox>
        </HBox>
    </VBox>

    <VBox fx:id="ratingView" visible="false" managed="false" spacing="20">
        <padding>
            <Insets top="0" right="0" bottom="24" left="0"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding:0 0 8 0;">
            <Button onAction="#handleRatingBack"
                    style="-fx-background-color:#1E293B;-fx-background-radius:10;-fx-cursor:hand;-fx-padding:8 12;-fx-border-color:#334155;-fx-border-radius:10;-fx-border-width:1;">
                <graphic>
                    <FontIcon iconLiteral="fth-arrow-left" iconSize="14" iconColor="#94A3B8"/>
                </graphic>
            </Button>
            <Label text="Flashcards" style="-fx-text-fill:#475569;-fx-font-size:13px;"/>
            <Label text="›" style="-fx-text-fill:#334155;-fx-font-size:14px;"/>
            <Label text="Deck Ratings" style="-fx-text-fill:#F8FAFC;-fx-font-size:13px;-fx-font-weight:700;"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Deck Ratings" style="-fx-text-fill:#F8FAFC;-fx-font-size:22px;-fx-font-weight:800;"/>
                <Label fx:id="ratingsSummaryLabel" text="Click Rating on a deck to see who rated it." style="-fx-text-fill:#64748B;-fx-font-size:12px;"/>
            </VBox>

            <Button text="Back to Decks" onAction="#handleRatingBack"
                    style="-fx-background-color:#1E293B;-fx-text-fill:#CBD5E1;-fx-font-size:12px;-fx-font-weight:700;-fx-background-radius:12;-fx-cursor:hand;-fx-padding:9 18;-fx-border-color:#334155;-fx-border-radius:12;-fx-border-width:1;">
                <graphic>
                    <FontIcon iconLiteral="fth-layers" iconSize="13" iconColor="#CBD5E1"/>
                </graphic>
            </Button>
        </HBox>

        <VBox style="-fx-background-color:#0F172A;-fx-background-radius:18;-fx-border-color:#1E293B;-fx-border-radius:18;-fx-border-width:1;-fx-padding:18 20;" spacing="14">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane prefWidth="42" prefHeight="42" style="-fx-background-color:linear-gradient(to bottom right,#7C3AED,#EC4899);-fx-background-radius:12;">
                    <FontIcon iconLiteral="fth-star" iconSize="18" iconColor="white"/>
                </StackPane>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label fx:id="selectedRatingDeckLabel" text="No deck selected" style="-fx-text-fill:#F8FAFC;-fx-font-size:18px;-fx-font-weight:800;"/>
                    <Label text="See who rated this deck, their stars, comment and date." style="-fx-text-fill:#64748B;-fx-font-size:11px;"/>
                </VBox>
            </HBox>

            <VBox spacing="10" style="-fx-background-color:#0B1220;-fx-background-radius:14;-fx-border-color:#1E293B;-fx-border-radius:14;-fx-border-width:1;-fx-padding:14 16;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane prefWidth="34" prefHeight="34" style="-fx-background-color:rgba(251,191,36,0.12);-fx-background-radius:10;">
                        <FontIcon iconLiteral="fth-bell" iconSize="14" iconColor="#FBBF24"/>
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Bad Rating Alerts" style="-fx-text-fill:#F8FAFC;-fx-font-size:13px;-fx-font-weight:700;"/>
                        <Label fx:id="ratingAlertsSummaryLabel" text="Support alerts will appear here when students rate a deck badly." style="-fx-text-fill:#64748B;-fx-font-size:11px;"/>
                    </VBox>
                </HBox>

                <VBox fx:id="ratingAlertsContainer" spacing="10">
                    <Label text="No support alert loaded yet." style="-fx-text-fill:#64748B;-fx-font-size:11px;"/>
                </VBox>
            </VBox>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                        style="-fx-background-color:transparent;-fx-background:transparent;">
                <VBox fx:id="ratingsListContainer" spacing="10" style="-fx-padding:2 0 2 0;">
                    <Label text="No ratings loaded yet." style="-fx-text-fill:#64748B;-fx-font-size:11px;"/>
                </VBox>
            </ScrollPane>
        </VBox>

    </VBox>

    <!-- Form View -->
    <VBox fx:id="formView" visible="false" managed="false" spacing="0">
        <padding>
            <Insets top="0" right="0" bottom="24" left="0"/>
        </padding>

        <!-- Form Header -->
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding:0 0 20 0;">
            <Button onAction="#handleCancel"
                    style="-fx-background-color:#1E293B;-fx-background-radius:10;-fx-cursor:hand;-fx-padding:8 12;-fx-border-color:#334155;-fx-border-radius:10;-fx-border-width:1;">
                <graphic>
                    <FontIcon iconLiteral="fth-arrow-left" iconSize="14" iconColor="#94A3B8"/>
                </graphic>
            </Button>
            <Label text="Flashcards" style="-fx-text-fill:#475569;-fx-font-size:13px;-fx-cursor:hand;" onMouseClicked="#handleCancel"/>
            <Label text="›" style="-fx-text-fill:#334155;-fx-font-size:14px;"/>
            <Label fx:id="formTitle" text="New Deck" style="-fx-text-fill:#F8FAFC;-fx-font-size:13px;-fx-font-weight:700;"/>
        </HBox>

        <!-- Form Card -->
        <VBox style="-fx-background-color:#0F172A;-fx-background-radius:20;-fx-border-color:#1E293B;-fx-border-radius:20;-fx-border-width:1;">

            <!-- Card Header -->
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding:20 24 20 24;-fx-border-color:#1E293B;-fx-border-width:0 0 1 0;">
                <StackPane prefWidth="40" prefHeight="40" style="-fx-background-color:linear-gradient(to bottom right,#7C3AED,#8B5CF6);-fx-background-radius:12;">
                    <FontIcon iconLiteral="fth-layers" iconSize="18" iconColor="white"/>
                </StackPane>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Deck Information" style="-fx-text-fill:#F8FAFC;-fx-font-size:15px;-fx-font-weight:700;"/>
                    <Label text="Fields marked * are required" style="-fx-text-fill:#64748B;-fx-font-size:11px;"/>
                </VBox>
            </HBox>

            <!-- Form Fields -->
            <VBox spacing="18" style="-fx-padding:24 24 20 24;">

                <!-- Title -->
                <VBox spacing="6">
                    <HBox alignment="CENTER_LEFT" spacing="5">
                        <FontIcon iconLiteral="fth-tag" iconSize="12" iconColor="#A78BFA"/>
                        <Label text="Title" style="-fx-text-fill:#CBD5E1;-fx-font-size:12px;-fx-font-weight:600;"/>
                        <Label text="*" style="-fx-text-fill:#FB7185;-fx-font-weight:700;"/>
                    </HBox>
                    <TextField fx:id="fieldTitre" promptText="e.g. Algorithms &amp; Data Structures..."
                               style="-fx-background-color:#1E293B;-fx-text-fill:#F8FAFC;-fx-prompt-text-fill:#475569;-fx-border-color:#334155;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:11 16;-fx-font-size:13px;"/>
                    <Label fx:id="errTitre" text="" style="-fx-text-fill:#FB7185;-fx-font-size:10px;-fx-font-weight:600;" visible="false" managed="false"/>
                </VBox>

                <!-- Subject and Level -->
                <HBox spacing="14">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="5">
                            <FontIcon iconLiteral="fth-book" iconSize="12" iconColor="#34D399"/>
                            <Label text="Subject" style="-fx-text-fill:#CBD5E1;-fx-font-size:12px;-fx-font-weight:600;"/>
                            <Label text="*" style="-fx-text-fill:#FB7185;-fx-font-weight:700;"/>
                        </HBox>
                        <TextField fx:id="fieldMatiere" promptText="e.g. Mathematics..."
                                   style="-fx-background-color:#1E293B;-fx-text-fill:#F8FAFC;-fx-prompt-text-fill:#475569;-fx-border-color:#334155;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:11 16;-fx-font-size:13px;"/>
                        <Label fx:id="errMatiere" text="" style="-fx-text-fill:#FB7185;-fx-font-size:10px;-fx-font-weight:600;" visible="false" managed="false"/>
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="5">
                            <FontIcon iconLiteral="fth-bar-chart-2" iconSize="12" iconColor="#FBBF24"/>
                            <Label text="Level" style="-fx-text-fill:#CBD5E1;-fx-font-size:12px;-fx-font-weight:600;"/>
                            <Label text="*" style="-fx-text-fill:#FB7185;-fx-font-weight:700;"/>
                        </HBox>
                        <ComboBox fx:id="combNiveau" promptText="Select level..." maxWidth="Infinity"
                                  style="-fx-background-color:#1E293B;-fx-border-color:#334155;-fx-border-radius:10;-fx-background-radius:10;-fx-font-size:13px;-fx-padding:6 10;"/>
                        <Label fx:id="errNiveau" text="" style="-fx-text-fill:#FB7185;-fx-font-size:10px;-fx-font-weight:600;" visible="false" managed="false"/>
                    </VBox>
                </HBox>

                <!-- Description -->
                <VBox spacing="6">
                    <HBox alignment="CENTER_LEFT" spacing="5">
                        <FontIcon iconLiteral="fth-align-left" iconSize="12" iconColor="#FB923C"/>
                        <Label text="Description" style="-fx-text-fill:#CBD5E1;-fx-font-size:12px;-fx-font-weight:600;"/>
                    </HBox>
                    <TextArea fx:id="fieldDescription" promptText="Describe your deck content..." prefRowCount="3"
                              style="-fx-control-inner-background:#1E293B;-fx-background-color:#1E293B;-fx-text-fill:#F8FAFC;-fx-prompt-text-fill:#475569;-fx-border-color:#334155;-fx-border-width:1.5;-fx-border-radius:10;-fx-background-radius:10;-fx-font-size:13px;"/>
                </VBox>

                <!-- Cover Image -->
                <VBox spacing="6">
                    <HBox alignment="CENTER_LEFT" spacing="5">
                        <FontIcon iconLiteral="fth-image" iconSize="12" iconColor="#38BDF8"/>
                        <Label text="Cover Image" style="-fx-text-fill:#CBD5E1;-fx-font-size:12px;-fx-font-weight:600;"/>
                        <Label text="*" style="-fx-text-fill:#FB7185;-fx-font-weight:700;"/>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="fieldImage" promptText="No image selected..." editable="false" HBox.hgrow="ALWAYS"
                                   style="-fx-background-color:#1E293B;-fx-text-fill:#94A3B8;-fx-prompt-text-fill:#475569;-fx-border-color:#334155;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:11 16;-fx-font-size:12px;"/>
                        <Button text=" Browse" onAction="#pickImage"
                                style="-fx-background-color:#1E293B;-fx-text-fill:#38BDF8;-fx-font-size:12px;-fx-font-weight:600;-fx-background-radius:10;-fx-cursor:hand;-fx-padding:10 16;-fx-border-color:#334155;-fx-border-radius:10;-fx-border-width:1;">
                            <graphic>
                                <FontIcon iconLiteral="fth-upload" iconSize="13" iconColor="#38BDF8"/>
                            </graphic>
                        </Button>
                    </HBox>
                    <Label fx:id="errImage" text="" style="-fx-text-fill:#FB7185;-fx-font-size:10px;-fx-font-weight:600;" visible="false" managed="false"/>
                    <Label fx:id="imagePreviewLabel" text="" style="-fx-text-fill:#34D399;-fx-font-size:10px;" visible="false" managed="false"/>
                </VBox>

                <!-- PDF Documents (multi) -->
                <VBox spacing="6">
                    <HBox alignment="CENTER_LEFT" spacing="5">
                        <FontIcon iconLiteral="fth-file-text" iconSize="12" iconColor="#F472B6"/>
                        <Label text="PDF Documents" style="-fx-text-fill:#CBD5E1;-fx-font-size:12px;-fx-font-weight:600;"/>
                        <Label text="*" style="-fx-text-fill:#FB7185;-fx-font-weight:700;"/>
                    </HBox>

                    <!-- Dynamic list of PDF rows populated by controller -->
                    <VBox fx:id="pdfListContainer" spacing="8"/>

                    <!-- Add PDF button -->
                    <HBox>
                        <Button fx:id="addPdfBtn" text=" Add PDF" onAction="#pickPdf" prefHeight="36"
                                style="-fx-background-color:rgba(244,114,182,0.08);-fx-text-fill:#F472B6;-fx-font-size:12px;-fx-font-weight:600;-fx-background-radius:8;-fx-cursor:hand;-fx-padding:8 16;-fx-border-color:#F472B6;-fx-border-radius:8;-fx-border-width:1;">
                            <graphic>
                                <FontIcon iconLiteral="fth-plus" iconSize="12" iconColor="#F472B6"/>
                            </graphic>
                        </Button>
                    </HBox>

                    <Label fx:id="errPdf" text="" style="-fx-text-fill:#FB7185;-fx-font-size:10px;-fx-font-weight:600;" visible="false" managed="false"/>
                    <Label fx:id="pdfPreviewLabel" text="" style="-fx-text-fill:#34D399;-fx-font-size:10px;" visible="false" managed="false"/>
                    <!-- hidden legacy field for backward compat -->
                    <TextField fx:id="fieldPdf" visible="false" managed="false" editable="false"/>
                </VBox>
            </VBox>

            <!-- Form Actions -->
            <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding:16 24 20 24;-fx-border-color:#1E293B;-fx-border-width:1 0 0 0;">
                <Button text="Cancel" onAction="#handleCancel"
                        style="-fx-background-color:#1E293B;-fx-text-fill:#94A3B8;-fx-font-size:13px;-fx-font-weight:600;-fx-background-radius:10;-fx-cursor:hand;-fx-padding:10 24;-fx-border-color:#334155;-fx-border-radius:10;-fx-border-width:1;"/>
                <Button text="Save Deck" onAction="#handleSave"
                        style="-fx-background-color:linear-gradient(to right,#7C3AED,#6D28D9);-fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:700;-fx-background-radius:10;-fx-cursor:hand;-fx-padding:10 28;"/>
            </HBox>
        </VBox>
    </VBox>

</StackPane>
