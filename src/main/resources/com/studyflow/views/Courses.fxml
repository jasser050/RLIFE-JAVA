<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.CoursesController"
      spacing="24" style="-fx-background-color: #020617;">

    <padding>
        <Insets top="0" right="0" bottom="24" left="0"/>
    </padding>

    <!-- Page Header -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Courses &amp; Resources" styleClass="text-heading"/>
            <Label text="Manage your courses and study materials" styleClass="text-muted"/>
        </VBox>
        <TextField promptText="Search courses..." styleClass="search-field" prefWidth="240"/>
        <Button text="Add Course" styleClass="btn-primary">
            <graphic>
                <FontIcon iconLiteral="fth-plus" iconSize="16" iconColor="white"/>
            </graphic>
        </Button>
    </HBox>

    <!-- Stats Row -->
    <HBox spacing="16">
        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, primary" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-book-open" iconSize="20"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="6" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                    <Label text="Active Courses" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, success" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-file-text" iconSize="20"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="47" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                    <Label text="Total Notes" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, accent" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-link" iconSize="20"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="23" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                    <Label text="Resources" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, warning" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-award" iconSize="20"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="68%" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                    <Label text="Avg. Progress" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>
    </HBox>

    <!-- Filter Badges -->
    <HBox spacing="8">
        <Label text="All Courses" styleClass="badge, primary" style="-fx-cursor: hand;"/>
        <Label text="Fall 2024" styleClass="badge, secondary" style="-fx-cursor: hand; -fx-background-color: #1E293B;"/>
        <Label text="Spring 2025" styleClass="badge, secondary" style="-fx-cursor: hand; -fx-background-color: #1E293B;"/>
        <Label text="Computer Science" styleClass="badge, secondary" style="-fx-cursor: hand; -fx-background-color: #1E293B;"/>
    </HBox>

    <!-- Course Grid -->
    <FlowPane fx:id="courseGrid" hgap="16" vgap="16">
        <!-- Course cards will be added dynamically -->
    </FlowPane>
</VBox>
