<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox spacing="24" styleClass="courses-page"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.CoursesController">

    <padding>
        <Insets bottom="24" left="0" right="0" top="0"/>
    </padding>

    <!-- ══ PAGE HEADER ══════════════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label fx:id="pageTitle" styleClass="text-heading" text="My Assessments"/>
            <Label fx:id="pageSubtitle" prefHeight="18.0" prefWidth="395.0"
                   styleClass="text-muted"
                   text="Track your results and manage your assessments by subject"/>
        </VBox>

        <ComboBox fx:id="sortCombo" prefHeight="32.0" prefWidth="100.0"
                  style="-fx-background-color:#1E293B;
                 -fx-border-color:#334155;
                 -fx-border-width:1.5;
                 -fx-border-radius:10;
                 -fx-background-radius:10;
                 -fx-font-size:12px;
                 -fx-text-fill:#F8FAFC;"/>

        <TextField fx:id="searchField" prefHeight="32.0" prefWidth="120.0"
                   promptText="Search…"
                   style="-fx-background-color:#1E293B;
                  -fx-text-fill:#F8FAFC;
                  -fx-prompt-text-fill:#64748B;
                  -fx-border-color:#334155;
                  -fx-border-width:1.5;
                  -fx-border-radius:10;
                  -fx-background-radius:10;
                  -fx-padding:6 12;
                  -fx-font-size:12px;">
            <font>
                <Font size="12.0"/>
            </font>
        </TextField>

        <!-- Voice Assistant Button -->
        <Button fx:id="btnVoiceAssistant" onAction="#handleVoiceAssistant"
                prefHeight="36.0"
                style="-fx-background-color:#7C3AED;
               -fx-text-fill:#FFFFFF;
               -fx-border-radius:10;
               -fx-background-radius:10;
               -fx-padding:8 16;
               -fx-font-size:12px;
               -fx-font-weight:700;
               -fx-cursor:hand;"
                text="🎤  Voice">
            <tooltip>
                <Tooltip text="Ask a question with your voice"/>
            </tooltip>
        </Button>

        <ComboBox fx:id="cmbLanguage" prefWidth="130" prefHeight="36.0"
                  style="-fx-background-color:#1E293B;
                     -fx-text-fill:#F8FAFC;
                     -fx-border-color:#7C3AED;
                     -fx-border-width:1.5;
                     -fx-border-radius:10;
                     -fx-background-radius:10;
                     -fx-font-size:12px;
                     -fx-font-weight:600;
                     -fx-cursor:hand;">
            <tooltip>
                <Tooltip text="Select your preferred language"/>
            </tooltip>
        </ComboBox>

        <!-- Export PDF -->
        <Button onAction="#handleExportPdf"
                prefHeight="36.0"
                style="-fx-background-color:#7C3AED;
               -fx-text-fill:#FFFFFF;
               -fx-border-radius:10;
               -fx-background-radius:10;
               -fx-padding:8 16;
               -fx-font-size:12px;
               -fx-font-weight:700;
               -fx-cursor:hand;"
                text="Export PDF"/>

        <!-- Statistics -->
        <Button onAction="#handleShowStats"
                prefHeight="36.0"
                style="-fx-background-color:#7C3AED;
               -fx-text-fill:#FFFFFF;
               -fx-border-radius:10;
               -fx-background-radius:10;
               -fx-padding:8 16;
               -fx-font-size:12px;
               -fx-font-weight:700;
               -fx-cursor:hand;"
                text="📊  Statistics"/>

        <Button fx:id="btnHeaderAction" onAction="#handleHeaderAction"
                styleClass="btn-primary" text="New Assessment">
            <graphic>
                <FontIcon fx:id="btnHeaderIcon" iconColor="white"
                          iconLiteral="fth-plus" iconSize="10"/>
            </graphic>
        </Button>
    </HBox>

    <!-- ══ STAT CARDS ═══════════════════════════════════════════════════════ -->
    <HBox fx:id="statCards" spacing="16">

        <VBox spacing="12" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane prefHeight="44" prefWidth="44" styleClass="stat-icon-box, primary">
                    <FontIcon iconLiteral="fth-clipboard" iconSize="20"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="statTotal" style="-fx-font-size:24px;"
                           styleClass="stat-value" text="0"/>
                    <Label styleClass="stat-label" text="Total Assessments"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox spacing="12" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane prefHeight="44" prefWidth="44" styleClass="stat-icon-box, success">
                    <FontIcon iconLiteral="fth-trending-up" iconSize="20"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="statMoyenne" style="-fx-font-size:24px;"
                           styleClass="stat-value" text="0.0"/>
                    <Label styleClass="stat-label" text="Average Score /20"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox spacing="12" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane prefHeight="44" prefWidth="44" styleClass="stat-icon-box, danger">
                    <FontIcon iconLiteral="fth-clock" iconSize="20"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="statLacunes" style="-fx-font-size:24px;"
                           styleClass="stat-value" text="0"/>
                    <Label styleClass="stat-label" text="Total Duration (min)"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox spacing="12" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane prefHeight="44" prefWidth="44" styleClass="stat-icon-box, warning">
                    <FontIcon iconLiteral="fth-award" iconSize="20"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="statMeilleur" style="-fx-font-size:24px;"
                           styleClass="stat-value" text="0.0"/>
                    <Label styleClass="stat-label" text="Best Score"/>
                </VBox>
            </HBox>
        </VBox>

    </HBox>

    <!-- ══ SMART QUIZ CARD ══════════════════════════════════════════════════ -->
    <VBox fx:id="smartQuizCard" spacing="0" styleClass="card"
          style="-fx-border-color:#4C1D95; -fx-border-width:1.5; -fx-border-radius:14; -fx-background-radius:14;">

        <HBox alignment="CENTER_LEFT" spacing="14"
              style="-fx-background-color:linear-gradient(to right,#1E1B4B,#2D1B69);
                     -fx-background-radius:12 12 0 0; -fx-padding:20 20 20 20;">

            <StackPane style="-fx-background-color:linear-gradient(to bottom right,#7C3AED,#A855F7);
                              -fx-background-radius:12;
                              -fx-min-width:48; -fx-min-height:48;
                              -fx-max-width:48; -fx-max-height:48;">
                <FontIcon iconLiteral="fth-zap" iconSize="22" iconColor="white"/>
            </StackPane>

            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill:#F8FAFC; -fx-font-size:17px; -fx-font-weight:700;"
                       text="Smart Quiz AI"/>
                <Label style="-fx-text-fill:#A78BFA; -fx-font-size:12px;"
                       text="Powered by Claude (Anthropic) — questions generated from your section"/>
            </VBox>

            <HBox spacing="8">
                <Label style="-fx-background-color:rgba(167,139,250,0.2);
                              -fx-text-fill:#A78BFA; -fx-background-radius:999;
                              -fx-padding:4 10; -fx-font-size:11px;" text="🎯 AI-Powered"/>
                <Label style="-fx-background-color:rgba(52,211,153,0.15);
                              -fx-text-fill:#34D399; -fx-background-radius:999;
                              -fx-padding:4 10; -fx-font-size:11px;" text="⚡ Instant"/>
                <Label style="-fx-background-color:rgba(251,146,60,0.15);
                              -fx-text-fill:#FB923C; -fx-background-radius:999;
                              -fx-padding:4 10; -fx-font-size:11px;" text="📚 Adaptive"/>
            </HBox>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding:16 20 16 20; -fx-background-color:rgba(124,58,237,0.06);">
            <Label style="-fx-text-fill:#CBD5E1; -fx-font-size:13px;"
                   text="Claude AI generates personalized MCQ questions based on your section and subject. Difficulty adapts to your average score!"
                   wrapText="true" HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnSmartQuiz" onAction="#handleShowQuiz"
                    style="-fx-background-color:linear-gradient(to right,#7C3AED,#A855F7);
                           -fx-text-fill:white; -fx-font-weight:700;
                           -fx-border-radius:10; -fx-background-radius:10;
                           -fx-padding:10 22; -fx-cursor:hand;
                           -fx-effect:dropshadow(gaussian,rgba(124,58,237,0.5),10,0,0,3);"
                    text="🚀 Launch Quiz"/>
        </HBox>

    </VBox>

    <!-- ══ MY CITY BUTTON ═══════════════════════════════════════════════════ -->
    <StackPane onMouseClicked="#handleShowCity"
               pickOnBounds="true"
               prefHeight="70"
               style="
               -fx-background-color: linear-gradient(to right, #4C1D95, #7C3AED);
               -fx-background-radius: 16;
               -fx-cursor: hand;
               -fx-effect: dropshadow(gaussian, rgba(124,58,237,0.4), 12, 0, 0, 4);
           ">

        <HBox alignment="CENTER_LEFT"
              spacing="12"
              style="-fx-padding: 14 20;">

            <Label text="🏙️"
                   style="-fx-font-size: 22px;" />

            <VBox spacing="2">
                <Label text="My City"
                       style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;" />
                <Label text="Enter your virtual world"
                       style="-fx-text-fill: #E9D5FF; -fx-font-size: 11px;" />
            </VBox>

        </HBox>

    </StackPane>

    <!-- ══ VUE LISTE ════════════════════════════════════════════════════════ -->
    <VBox fx:id="listView" spacing="16">
        <HBox spacing="8">
            <Label onMouseClicked="#filterAll"
                   style="-fx-cursor:hand;-fx-background-color:#7C3AED;-fx-text-fill:#FFFFFF;
                          -fx-padding:5 14;-fx-background-radius:20;-fx-font-size:12px;-fx-font-weight:600;"
                   text="All"/>
            <Label onMouseClicked="#filterBonne"
                   style="-fx-cursor:hand;-fx-background-color:#0D2C1F;-fx-text-fill:#34D399;
                          -fx-border-color:#34D399;-fx-border-width:1;
                          -fx-padding:5 14;-fx-background-radius:20;-fx-border-radius:20;
                          -fx-font-size:12px;-fx-font-weight:600;"
                   text="✅ Good (≥14)"/>
            <Label onMouseClicked="#filterMoyenne"
                   style="-fx-cursor:hand;-fx-background-color:#2C1E00;-fx-text-fill:#FBBF24;
                          -fx-border-color:#FBBF24;-fx-border-width:1;
                          -fx-padding:5 14;-fx-background-radius:20;-fx-border-radius:20;
                          -fx-font-size:12px;-fx-font-weight:600;"
                   text="🟡 Average (10–14)"/>
            <Label onMouseClicked="#filterFaible"
                   style="-fx-cursor:hand;-fx-background-color:#2D0A0A;-fx-text-fill:#FB7185;
                          -fx-border-color:#FB7185;-fx-border-width:1;
                          -fx-padding:5 14;-fx-background-radius:20;-fx-border-radius:20;
                          -fx-font-size:12px;-fx-font-weight:600;"
                   text="🔴 Low (&lt;10)"/>
            <Label onMouseClicked="#filterHaute"
                   style="-fx-cursor:hand;-fx-background-color:#2C1200;-fx-text-fill:#FB923C;
                          -fx-border-color:#FB923C;-fx-border-width:1;
                          -fx-padding:5 14;-fx-background-radius:20;-fx-border-radius:20;
                          -fx-font-size:12px;-fx-font-weight:600;"
                   text="🔥 High Priority"/>
        </HBox>
        <FlowPane fx:id="courseGrid" hgap="16" vgap="16"/>
    </VBox>

    <!-- ══ VUE FORMULAIRE ═══════════════════════════════════════════════════ -->
    <VBox fx:id="formPanel" managed="false" spacing="0"
          styleClass="courses-form-panel" visible="false">

        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="courses-form-header">
            <StackPane styleClass="courses-form-icon">
                <FontIcon iconColor="#A78BFA" iconLiteral="fth-edit-3" iconSize="18"/>
            </StackPane>
            <VBox spacing="2">
                <Label fx:id="formTitle"
                       style="-fx-font-size:18px;-fx-font-weight:700;-fx-text-fill:#F8FAFC;"
                       text="New Assessment"/>
                <Label style="-fx-font-size:12px;-fx-text-fill:#94A3B8;"
                       text="Fill in all required fields marked with *"/>
            </VBox>
        </HBox>

        <VBox spacing="20" style="-fx-padding:24 28 28 28;">

            <!-- Section -->
            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label style="-fx-font-size:13px;" text="🏫"/>
                    <Label style="-fx-font-size:13px;-fx-font-weight:700;-fx-text-fill:#F8FAFC;" text="Section"/>
                    <Label style="-fx-text-fill:#F43F5E;-fx-font-weight:800;" text="*"/>
                </HBox>
                <ComboBox fx:id="cmbSection" maxWidth="1.7976931348623157E308"
                          onAction="#handleSectionChange" promptText="Choose a section…"
                          style="-fx-background-color:#1E293B;-fx-border-color:#334155;
                                 -fx-border-width:1.5;-fx-border-radius:10;
                                 -fx-background-radius:10;-fx-padding:10 14;
                                 -fx-font-size:13px;-fx-text-fill:#F8FAFC;"/>
                <Label fx:id="errSection" style="-fx-text-fill:#F43F5E;-fx-font-size:11px;" text=""/>
            </VBox>

            <Region maxHeight="1" prefHeight="1" style="-fx-background-color:#1E293B;"/>

            <!-- Subject -->
            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label style="-fx-font-size:13px;" text="📚"/>
                    <Label style="-fx-font-size:13px;-fx-font-weight:700;-fx-text-fill:#F8FAFC;" text="Subject"/>
                    <Label style="-fx-text-fill:#F43F5E;-fx-font-weight:800;" text="*"/>
                    <Label style="-fx-font-size:11px;-fx-text-fill:#94A3B8;" text="(filtered by section)"/>
                </HBox>
                <ComboBox fx:id="cmbMatiere" maxWidth="1.7976931348623157E308"
                          promptText="Select a section first…"
                          style="-fx-background-color:#1E293B;-fx-border-color:#334155;
                                 -fx-border-width:1.5;-fx-border-radius:10;
                                 -fx-background-radius:10;-fx-padding:10 14;
                                 -fx-font-size:13px;-fx-text-fill:#F8FAFC;"/>
                <Label fx:id="errMatiere" style="-fx-text-fill:#F43F5E;-fx-font-size:11px;" text=""/>
            </VBox>

            <Region maxHeight="1" prefHeight="1" style="-fx-background-color:#1E293B;"/>

            <!-- Score -->
            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label style="-fx-font-size:13px;" text="🎯"/>
                    <Label style="-fx-font-size:13px;-fx-font-weight:700;-fx-text-fill:#F8FAFC;" text="Score Obtained"/>
                    <Label style="-fx-text-fill:#F43F5E;-fx-font-weight:800;" text="*"/>
                    <Label style="-fx-font-size:11px;-fx-text-fill:#94A3B8;" text="(between 0 and the max grade)"/>
                </HBox>
                <TextField fx:id="fldScore" promptText="e.g. 14.5"
                           style="-fx-background-color:#1E293B;-fx-text-fill:#F8FAFC;
                                  -fx-prompt-text-fill:#64748B;
                                  -fx-border-color:#334155;-fx-border-width:1.5;
                                  -fx-border-radius:12;-fx-background-radius:12;
                                  -fx-padding:12 16;-fx-font-size:14px;-fx-font-weight:500;"/>
                <Label fx:id="errScore" style="-fx-text-fill:#F43F5E;-fx-font-size:11px;-fx-font-weight:600;" text=""/>
            </VBox>

            <Region maxHeight="1" prefHeight="1" style="-fx-background-color:#1E293B;"/>

            <!-- Note Max -->
            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label style="-fx-font-size:13px;" text="📊"/>
                    <Label style="-fx-font-size:13px;-fx-font-weight:700;-fx-text-fill:#F8FAFC;" text="Maximum Grade"/>
                    <Label style="-fx-text-fill:#F43F5E;-fx-font-weight:800;" text="*"/>
                </HBox>
                <TextField fx:id="fldNoteMax" promptText="e.g. 20"
                           style="-fx-background-color:#1E293B;-fx-text-fill:#F8FAFC;
                                  -fx-prompt-text-fill:#64748B;
                                  -fx-border-color:#334155;-fx-border-width:1.5;
                                  -fx-border-radius:10;-fx-background-radius:10;
                                  -fx-padding:12 14;-fx-font-size:14px;"/>
                <Label fx:id="errNoteMax" style="-fx-text-fill:#F43F5E;-fx-font-size:11px;" text=""/>
            </VBox>

            <Region maxHeight="1" prefHeight="1" style="-fx-background-color:#1E293B;"/>

            <!-- Duration -->
            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label style="-fx-font-size:13px;" text="⏱"/>
                    <Label style="-fx-font-size:13px;-fx-font-weight:700;-fx-text-fill:#F8FAFC;" text="Duration"/>
                    <Label style="-fx-text-fill:#F43F5E;-fx-font-weight:800;" text="*"/>
                    <Label style="-fx-font-size:11px;-fx-text-fill:#94A3B8;" text="(minutes of revision)"/>
                </HBox>
                <TextField fx:id="fldDuree" promptText="e.g. 90"
                           style="-fx-background-color:#1E293B;-fx-text-fill:#F8FAFC;
                                  -fx-prompt-text-fill:#64748B;
                                  -fx-border-color:#334155;-fx-border-width:1.5;
                                  -fx-border-radius:10;-fx-background-radius:10;
                                  -fx-padding:12 14;-fx-font-size:14px;"/>
                <Label fx:id="errDuree" style="-fx-text-fill:#F43F5E;-fx-font-size:11px;" text=""/>
            </VBox>

            <Region maxHeight="1" prefHeight="1" style="-fx-background-color:#1E293B;"/>

            <!-- Priority -->
            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label style="-fx-font-size:13px;" text="⚡"/>
                    <Label style="-fx-font-size:13px;-fx-font-weight:700;-fx-text-fill:#F8FAFC;" text="Priority"/>
                    <Label style="-fx-text-fill:#F43F5E;-fx-font-weight:800;" text="*"/>
                </HBox>
                <HBox fx:id="priorityBox" spacing="12">
                    <Button fx:id="btnPrioHaute" onAction="#selectPrioHaute"
                            style="-fx-background-color:#1E293B;-fx-text-fill:#FB7185;
                                   -fx-border-color:#FB7185;-fx-border-width:1.5;
                                   -fx-border-radius:10;-fx-background-radius:10;
                                   -fx-padding:10 20;-fx-font-size:13px;-fx-cursor:hand;"
                            text="🔴  High"/>
                    <Button fx:id="btnPrioMoyenne" onAction="#selectPrioMoyenne"
                            style="-fx-background-color:#1E293B;-fx-text-fill:#FBBF24;
                                   -fx-border-color:#FBBF24;-fx-border-width:1.5;
                                   -fx-border-radius:10;-fx-background-radius:10;
                                   -fx-padding:10 20;-fx-font-size:13px;-fx-cursor:hand;"
                            text="🟡 Medium"/>
                    <Button fx:id="btnPrioBasse" onAction="#selectPrioBasse"
                            style="-fx-background-color:#1E293B;-fx-text-fill:#34D399;
                                   -fx-border-color:#34D399;-fx-border-width:1.5;
                                   -fx-border-radius:10;-fx-background-radius:10;
                                   -fx-padding:10 20;-fx-font-size:13px;-fx-cursor:hand;"
                            text="🟢  Low"/>
                </HBox>
                <ComboBox fx:id="cmbPriorite" managed="false" visible="false"/>
                <Label fx:id="errPriorite" style="-fx-text-fill:#F43F5E;-fx-font-size:11px;" text=""/>
            </VBox>

            <Region maxHeight="1" prefHeight="1" style="-fx-background-color:#1E293B;"/>

            <!-- Date -->
            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label style="-fx-font-size:13px;" text="📅"/>
                    <Label style="-fx-font-size:13px;-fx-font-weight:700;-fx-text-fill:#F8FAFC;"
                           text="Assessment Date"/>
                    <Label style="-fx-text-fill:#F43F5E;-fx-font-weight:800;" text="*"/>
                    <Label style="-fx-font-size:11px;-fx-text-fill:#94A3B8;" text="(today or earlier)"/>
                </HBox>
                <DatePicker fx:id="dpDate" maxWidth="1.7976931348623157E308"
                            promptText="Select a date…"
                            style="-fx-background-color:#1E293B;-fx-border-color:#6D28D9;
                                   -fx-border-width:1.5;-fx-border-radius:10;
                                   -fx-background-radius:10;-fx-text-fill:#F8FAFC;
                                   -fx-font-size:13px;-fx-padding:4 0;"/>
                <Label fx:id="errDate" style="-fx-text-fill:#F43F5E;-fx-font-size:11px;" text=""/>
            </VBox>

            <Label fx:id="formError"
                   style="-fx-background-color:#2D0A0A;-fx-text-fill:#FB7185;
                          -fx-font-size:12px;-fx-font-weight:600;
                          -fx-background-radius:8;-fx-padding:10 14;"
                   text="" visible="false" wrapText="true"/>

            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding:4 0 0 0;">
                <Button fx:id="btnSave" onAction="#handleSave"
                        style="-fx-padding:12 28;-fx-font-size:14px;-fx-font-weight:700;"
                        styleClass="btn-primary" text="➕  Add Assessment"/>
                <Button onAction="#handleCancel"
                        style="-fx-background-color:#1E293B;-fx-text-fill:#94A3B8;
                               -fx-border-color:#334155;-fx-border-radius:10;
                               -fx-background-radius:10;-fx-padding:12 24;
                               -fx-font-size:13px;-fx-cursor:hand;" text="✕  Cancel"/>
            </HBox>

        </VBox>
    </VBox>

    <!-- ══ VUE STATISTIQUES ══════════════════════════════════════════════════ -->
    <VBox fx:id="statsView" managed="false" spacing="20" visible="false">

        <HBox spacing="16">
            <VBox styleClass="card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="card-header">
                    <StackPane prefHeight="32" prefWidth="32" styleClass="stat-icon-box, primary">
                        <FontIcon iconLiteral="fth-bar-chart-2" iconSize="14"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label styleClass="card-title" text="Score by Subject"/>
                        <Label styleClass="text-small" text="Average score per subject"/>
                    </VBox>
                </HBox>
                <VBox styleClass="card-body">
                    <BarChart fx:id="scoreBySubjectChart" animated="true"
                              legendVisible="false" prefHeight="240">
                        <xAxis>
                            <CategoryAxis side="BOTTOM"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis lowerBound="0" side="LEFT" upperBound="20"/>
                        </yAxis>
                    </BarChart>
                </VBox>
            </VBox>

            <VBox prefWidth="280" styleClass="card">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="card-header">
                    <StackPane prefHeight="32" prefWidth="32" styleClass="stat-icon-box, success">
                        <FontIcon iconLiteral="fth-pie-chart" iconSize="14"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label styleClass="card-title" text="By Priority"/>
                        <Label styleClass="text-small" text="Assessment breakdown"/>
                    </VBox>
                </HBox>
                <VBox alignment="CENTER" styleClass="card-body">
                    <PieChart fx:id="priorityPieChart" animated="true"
                              labelsVisible="false" legendVisible="true" prefHeight="240"/>
                </VBox>
            </VBox>
        </HBox>

        <VBox styleClass="card">
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="card-header">
                <StackPane prefHeight="32" prefWidth="32" styleClass="stat-icon-box, warning">
                    <FontIcon iconLiteral="fth-trending-up" iconSize="14"/>
                </StackPane>
                <VBox spacing="2">
                    <Label styleClass="card-title" text="Score Evolution"/>
                    <Label styleClass="text-small" text="Your scores in chronological order"/>
                </VBox>
            </HBox>
            <VBox styleClass="card-body">
                <LineChart fx:id="progressLineChart" animated="true"
                           createSymbols="true" legendVisible="false" prefHeight="180">
                    <xAxis>
                        <CategoryAxis side="BOTTOM"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis lowerBound="0" side="LEFT" upperBound="20"/>
                    </yAxis>
                </LineChart>
            </VBox>
        </VBox>

        <VBox spacing="12" styleClass="card">
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="card-header">
                <StackPane prefHeight="32" prefWidth="32" styleClass="stat-icon-box, accent">
                    <FontIcon iconLiteral="fth-zap" iconSize="14"/>
                </StackPane>
                <VBox spacing="2">
                    <Label styleClass="card-title" text="Performance Insights"/>
                    <Label styleClass="text-small" text="Smart analysis of your results"/>
                </VBox>
            </HBox>
            <HBox fx:id="insightBox" alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding:0 20 16 20;"/>
        </VBox>

    </VBox>

    <!-- ══ VUE QUIZ PRINCIPALE ══════════════════════════════════════════════ -->
    <VBox fx:id="quizMainView" managed="false" spacing="20" visible="false">

        <!-- ── QUIZ SETUP ───────────────────────────────────────────────── -->
        <VBox fx:id="quizSetupView" spacing="0" styleClass="courses-form-panel">

            <HBox alignment="CENTER_LEFT" spacing="20"
                  style="-fx-background-color:linear-gradient(to right,#4C1D95,#2D1B69);
                         -fx-background-radius:12 12 0 0; -fx-padding:24 28;">
                <StackPane style="-fx-background-color:rgba(255,255,255,0.15);
                                  -fx-background-radius:12;
                                  -fx-min-width:56;-fx-min-height:56;
                                  -fx-max-width:56;-fx-max-height:56;">
                    <FontIcon iconColor="white" iconLiteral="fth-cpu" iconSize="28"/>
                </StackPane>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill:white;-fx-font-size:22px;-fx-font-weight:700;"
                           text="Smart Quiz — Claude AI"/>
                    <Label style="-fx-text-fill:rgba(255,255,255,0.75);-fx-font-size:13px;"
                           text="Questions generated by Claude (Anthropic) based on your section and subject"/>
                </VBox>
                <HBox spacing="8">
                    <Label style="-fx-background-color:rgba(255,255,255,0.18);-fx-text-fill:white;-fx-font-size:11px;-fx-background-radius:999;-fx-padding:4 12;"
                           text="🤖  Claude AI"/>
                    <Label style="-fx-background-color:rgba(255,255,255,0.18);-fx-text-fill:white;-fx-font-size:11px;-fx-background-radius:999;-fx-padding:4 12;"
                           text="🎯  Adaptive"/>
                    <Label style="-fx-background-color:rgba(255,255,255,0.18);-fx-text-fill:white;-fx-font-size:11px;-fx-background-radius:999;-fx-padding:4 12;"
                           text="⚡  Instant"/>
                </HBox>
            </HBox>

            <VBox spacing="20" style="-fx-padding:24 28 28 28;">

                <VBox spacing="8">
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <Label style="-fx-font-size:13px;" text="🏫"/>
                        <Label style="-fx-font-size:13px;-fx-font-weight:700;-fx-text-fill:#F8FAFC;" text="Section"/>
                        <Label style="-fx-text-fill:#F43F5E;-fx-font-weight:800;" text="*"/>
                    </HBox>
                    <ComboBox fx:id="cmbQuizSection" maxWidth="1.7976931348623157E308"
                              onAction="#handleQuizSectionChange" promptText="Choose a section…"
                              style="-fx-background-color:#1E293B;-fx-border-color:#334155;-fx-border-width:1.5;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:10 14;-fx-font-size:13px;-fx-text-fill:#F8FAFC;"/>
                </VBox>

                <Region maxHeight="1" prefHeight="1" style="-fx-background-color:#1E293B;"/>

                <VBox spacing="8">
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <Label style="-fx-font-size:13px;" text="📚"/>
                        <Label style="-fx-font-size:13px;-fx-font-weight:700;-fx-text-fill:#F8FAFC;" text="Subject"/>
                        <Label style="-fx-text-fill:#F43F5E;-fx-font-weight:800;" text="*"/>
                        <Label style="-fx-font-size:11px;-fx-text-fill:#94A3B8;" text="(filtered by section)"/>
                    </HBox>
                    <ComboBox fx:id="cmbQuizMatiere" maxWidth="1.7976931348623157E308"
                              promptText="Select a section first…"
                              style="-fx-background-color:#1E293B;-fx-border-color:#334155;-fx-border-width:1.5;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:10 14;-fx-font-size:13px;-fx-text-fill:#F8FAFC;"/>
                </VBox>

                <Region maxHeight="1" prefHeight="1" style="-fx-background-color:#1E293B;"/>

                <HBox spacing="16">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <Label style="-fx-font-size:13px;" text="⚡"/>
                            <Label style="-fx-font-size:13px;-fx-font-weight:700;-fx-text-fill:#F8FAFC;"
                                   text="Difficulty"/>
                        </HBox>
                        <ComboBox fx:id="cmbQuizDifficulty" maxWidth="1.7976931348623157E308"
                                  style="-fx-background-color:#1E293B;-fx-border-color:#334155;-fx-border-width:1.5;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:10 14;-fx-font-size:13px;-fx-text-fill:#F8FAFC;"/>
                    </VBox>
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <Label style="-fx-font-size:13px;" text="🔢"/>
                            <Label style="-fx-font-size:13px;-fx-font-weight:700;-fx-text-fill:#F8FAFC;"
                                   text="Number of questions"/>
                        </HBox>
                        <ComboBox fx:id="cmbQuizCount" maxWidth="1.7976931348623157E308"
                                  style="-fx-background-color:#1E293B;-fx-border-color:#334155;-fx-border-width:1.5;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:10 14;-fx-font-size:13px;-fx-text-fill:#F8FAFC;"/>
                    </VBox>
                </HBox>

                <Button fx:id="btnGenerateAIQuiz" onAction="#handleGenerateAIQuiz"
                        maxWidth="Infinity"
                        style="-fx-background-color:linear-gradient(to right,#7C3AED,#A855F7);
                               -fx-text-fill:white;-fx-font-weight:bold;
                               -fx-padding:14 32;-fx-font-size:14px;
                               -fx-border-radius:10;-fx-background-radius:10;
                               -fx-cursor:hand;
                               -fx-effect:dropshadow(gaussian,rgba(124,58,237,0.5),10,0,0,3);"
                        text="🤖  Generate AI Quiz with Claude"/>

                <Label fx:id="lblQuizSetupError"
                       style="-fx-text-fill:#F43F5E;-fx-font-size:12px;-fx-font-weight:600;" text=""/>

                <VBox spacing="6"
                      style="-fx-background-color:#0C1A2E;-fx-border-color:#1E3A5F;
                             -fx-border-width:1;-fx-border-radius:10;
                             -fx-background-radius:10;-fx-padding:14 16;">
                    <Label style="-fx-text-fill:#93C5FD;-fx-font-size:13px;-fx-font-weight:700;"
                           text="💡  How it works"/>
                    <Label style="-fx-text-fill:#BFDBFE;-fx-font-size:12px;"
                           text="✓  Claude AI reads your section and subject"/>
                    <Label style="-fx-text-fill:#BFDBFE;-fx-font-size:12px;"
                           text="✓  Questions adapt to your average score in the subject"/>
                    <Label style="-fx-text-fill:#BFDBFE;-fx-font-size:12px;"
                           text="✓  Multiple choice format — 4 options per question"/>
                    <Label style="-fx-text-fill:#BFDBFE;-fx-font-size:12px;"
                           text="✓  API key needed — get yours at console.anthropic.com"/>
                </VBox>

            </VBox>
        </VBox>

        <!-- ── QUIZ LOADING ─────────────────────────────────────────────── -->
        <VBox fx:id="quizLoadingView" alignment="CENTER" managed="false"
              spacing="24" style="-fx-padding:60 0;" visible="false">
            <ProgressIndicator fx:id="quizLoadingSpinner" prefHeight="60" prefWidth="60"
                               style="-fx-accent:#7C3AED;"/>
            <VBox alignment="CENTER" spacing="8">
                <Label fx:id="lblQuizLoadingStatus"
                       style="-fx-text-fill:#A78BFA;-fx-font-size:16px;-fx-font-weight:600;"
                       text="Claude AI is generating your questions…"/>
                <Label style="-fx-text-fill:#64748B;-fx-font-size:13px;" text="This may take a few seconds…"/>
            </VBox>
            <VBox alignment="CENTER" spacing="6"
                  style="-fx-background-color:#1E1B4B;-fx-background-radius:12;-fx-padding:16 24;">
                <Label style="-fx-text-fill:#A78BFA;-fx-font-size:12px;" text="🤖  Powered by Claude (Anthropic)"/>
                <Label style="-fx-text-fill:#6D28D9;-fx-font-size:11px;" text="console.anthropic.com"/>
            </VBox>
        </VBox>

        <!-- ── QUIZ IN PROGRESS ─────────────────────────────────────────── -->
        <VBox fx:id="quizInProgressView" managed="false" spacing="16" visible="false">

            <HBox alignment="CENTER_LEFT" spacing="16"
                  style="-fx-background-color:#1E293B;-fx-border-color:#7C3AED;
                         -fx-border-width:0 0 2 0;-fx-padding:14 20;
                         -fx-background-radius:12;-fx-border-radius:12;">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <FontIcon iconLiteral="fth-clock" iconSize="16" style="-fx-icon-color:#A78BFA;"/>
                    <Label fx:id="lblQuizTimer"
                           style="-fx-text-fill:#F8FAFC;-fx-font-size:20px;-fx-font-weight:700;" text="0:00"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblQuizProgress"
                       style="-fx-text-fill:#A78BFA;-fx-font-size:14px;-fx-font-weight:600;" text="1 / 10"/>
                <ProgressBar fx:id="quizProgressBar" prefHeight="10" prefWidth="180" progress="0"
                             style="-fx-accent:#7C3AED;-fx-background-color:#334155;-fx-background-radius:5;-fx-border-radius:5;"/>
                <Label fx:id="lblQuizAnsweredCount"
                       style="-fx-text-fill:#64748B;-fx-font-size:12px;" text="0 answered"/>
            </HBox>

            <VBox spacing="0"
                  style="-fx-background-color:#1E293B;-fx-border-color:#334155;
                         -fx-border-width:1.5;-fx-border-radius:12;-fx-background-radius:12;">
                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-padding:18 20 14 20;-fx-border-color:#334155;-fx-border-width:0 0 1 0;">
                    <Label fx:id="lblQuizQuestionNum"
                           style="-fx-background-color:#534AB7;-fx-text-fill:white;-fx-background-radius:8;-fx-padding:5 14;-fx-font-size:13px;-fx-font-weight:700;"
                           text="Question 1"/>
                    <Label fx:id="lblQuizDiffBadge"
                           style="-fx-background-color:#FAEEDA;-fx-text-fill:#854F0B;-fx-background-radius:999;-fx-padding:3 10;-fx-font-size:11px;-fx-font-weight:700;"
                           text="Medium"/>
                    <Label fx:id="lblQuizCategoryBadge"
                           style="-fx-background-color:#1E293B;-fx-text-fill:#A78BFA;-fx-border-color:#534AB7;-fx-border-width:1;-fx-background-radius:999;-fx-border-radius:999;-fx-padding:3 10;-fx-font-size:11px;"
                           text="Category"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label style="-fx-background-color:rgba(124,58,237,0.15);-fx-text-fill:#A78BFA;-fx-font-size:10px;-fx-background-radius:20;-fx-padding:3 8;"
                           text="🤖 Claude AI"/>
                </HBox>
                <Label fx:id="lblQuizQuestionText"
                       style="-fx-text-fill:#F8FAFC;-fx-font-size:16px;-fx-font-weight:500;-fx-padding:18 20 14 20;-fx-line-spacing:3;"
                       text="" wrapText="true"/>
                <VBox fx:id="quizVboxOptions" spacing="8" style="-fx-padding:0 20 20 20;"/>
            </VBox>

            <HBox alignment="CENTER_RIGHT">
                <Button fx:id="btnQuizNext" disable="true" onAction="#handleQuizNextQuestion"
                        style="-fx-background-color:#7C3AED;-fx-text-fill:white;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:12 28;-fx-font-size:14px;-fx-font-weight:700;-fx-cursor:hand;"
                        text="Next Question →"/>
            </HBox>

        </VBox>

        <!-- ── QUIZ RESULTS ─────────────────────────────────────────────── -->
        <ScrollPane fx:id="quizResultsView" fitToWidth="true" managed="false"
                    style="-fx-background:transparent;-fx-background-color:transparent;-fx-border-color:transparent;"
                    visible="false">
            <VBox spacing="20">

                <VBox alignment="CENTER" spacing="12"
                      style="-fx-background-color:linear-gradient(to bottom right,#3C3489,#1E1B4B);-fx-background-radius:14;-fx-padding:32 24;">
                    <Label style="-fx-background-color:rgba(255,255,255,0.15);-fx-text-fill:white;-fx-background-radius:999;-fx-padding:6 18;-fx-font-size:13px;-fx-font-weight:600;"
                           text="✅  Quiz Completed — Powered by Claude AI"/>
                    <Label fx:id="lblQuizFinalScore"
                           style="-fx-text-fill:white;-fx-font-size:54px;-fx-font-weight:900;" text="0 / 0"/>
                    <Label fx:id="lblQuizFinalPercent"
                           style="-fx-text-fill:rgba(255,255,255,0.75);-fx-font-size:22px;-fx-font-weight:600;"
                           text="0%"/>
                    <Label fx:id="lblQuizFinalLevel"
                           style="-fx-text-fill:#34D399;-fx-font-size:20px;-fx-font-weight:700;" text="Good"/>
                    <HBox alignment="CENTER" spacing="16" style="-fx-padding:12 0 0 0;">
                        <VBox alignment="CENTER" spacing="4"
                              style="-fx-background-color:rgba(255,255,255,0.12);-fx-background-radius:10;-fx-padding:12 20;">
                            <FontIcon iconColor="white" iconLiteral="fth-clock" iconSize="20"/>
                            <Label fx:id="lblQuizTotalTime"
                                   style="-fx-text-fill:white;-fx-font-size:22px;-fx-font-weight:700;" text="0:00"/>
                            <Label style="-fx-text-fill:rgba(255,255,255,0.7);-fx-font-size:11px;" text="Total Time"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="4"
                              style="-fx-background-color:rgba(255,255,255,0.12);-fx-background-radius:10;-fx-padding:12 20;">
                            <FontIcon iconColor="#34D399" iconLiteral="fth-check-circle" iconSize="20"/>
                            <Label fx:id="lblQuizCorrectCount"
                                   style="-fx-text-fill:#34D399;-fx-font-size:22px;-fx-font-weight:700;" text="0"/>
                            <Label style="-fx-text-fill:rgba(255,255,255,0.7);-fx-font-size:11px;" text="Correct"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="4"
                              style="-fx-background-color:rgba(255,255,255,0.12);-fx-background-radius:10;-fx-padding:12 20;">
                            <FontIcon iconColor="#FB7185" iconLiteral="fth-x-circle" iconSize="20"/>
                            <Label fx:id="lblQuizWrongCount"
                                   style="-fx-text-fill:#FB7185;-fx-font-size:22px;-fx-font-weight:700;" text="0"/>
                            <Label style="-fx-text-fill:rgba(255,255,255,0.7);-fx-font-size:11px;" text="Wrong"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox spacing="0"
                      style="-fx-background-color:#0F172A;-fx-border-color:#1E293B;-fx-border-width:1.5;-fx-border-radius:12;-fx-background-radius:12;">
                    <HBox alignment="CENTER_LEFT" spacing="12"
                          style="-fx-padding:16 20 14 20;-fx-border-color:#1E293B;-fx-border-width:0 0 1 0;">
                        <StackPane
                                style="-fx-background-color:#1E293B;-fx-background-radius:8;-fx-min-width:36;-fx-max-width:36;-fx-min-height:36;-fx-max-height:36;">
                            <FontIcon iconLiteral="fth-list" iconSize="16" style="-fx-icon-color:#A78BFA;"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label style="-fx-text-fill:#F8FAFC;-fx-font-size:16px;-fx-font-weight:700;"
                                   text="Detailed Analysis"/>
                            <Label style="-fx-text-fill:#64748B;-fx-font-size:12px;"
                                   text="Review each question and correct answers"/>
                        </VBox>
                    </HBox>
                    <VBox fx:id="quizVboxDetailedResults" spacing="10" style="-fx-padding:16;"/>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-background-color:#1E293B;-fx-border-color:#334155;-fx-border-width:1.5;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:16 20;">
                    <Button fx:id="btnQuizRetake" onAction="#handleQuizRetake"
                            style="-fx-background-color:#7C3AED;-fx-text-fill:white;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:11 24;-fx-font-size:13px;-fx-font-weight:700;-fx-cursor:hand;"
                            text="🔄  Retake Quiz"/>
                    <Button fx:id="btnQuizBackToSetup" onAction="#handleQuizBackToSetup"
                            style="-fx-background-color:#1E293B;-fx-text-fill:#94A3B8;-fx-border-color:#334155;-fx-border-radius:10;-fx-background-radius:10;-fx-padding:11 24;-fx-font-size:13px;-fx-cursor:hand;"
                            text="← New Quiz"/>
                </HBox>

            </VBox>
        </ScrollPane>

    </VBox>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- ══ VOICE ASSISTANT BAR ═══════════════════════════════════════════ -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <VBox fx:id="voiceBar" spacing="8" visible="false" managed="false"
          style="-fx-background-color:#1E1B4B; -fx-background-radius:12; -fx-padding:12 16;
                 -fx-border-color:#7C3AED; -fx-border-width:1; -fx-border-radius:12;">

        <HBox alignment="CENTER_LEFT" spacing="12">
            <!-- Icône micro -->
            <StackPane style="-fx-background-color:#7C3AED; -fx-background-radius:20;
                             -fx-min-width:32; -fx-min-height:32;">
                <FontIcon iconLiteral="fth-mic" iconSize="16" iconColor="white"/>
            </StackPane>

            <!-- Statut -->
            <Label fx:id="voiceStatusLabel" style="-fx-text-fill:#A78BFA;-fx-font-size:12px;-fx-font-weight:600;"
                   text="Assistant vocal prêt"/>

            <!-- Progress indicator -->
            <ProgressIndicator fx:id="voiceProgress" prefHeight="20" prefWidth="20" visible="false"
                               style="-fx-accent:#7C3AED;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Bouton cancel -->
            <Button fx:id="btnVoiceCancel" onAction="#handleCancelVoice"
                    style="-fx-background-color:#EF4444;-fx-text-fill:white;-fx-font-size:11px;
                           -fx-padding:4 12;-fx-background-radius:8;-fx-cursor:hand;
                           -fx-font-weight:700;"
                    text="Cancel"/>
        </HBox>

        <!-- Transcription -->
        <Label fx:id="voiceTranscriptionLabel"
               style="-fx-text-fill:#CBD5E1;-fx-font-size:12px;-fx-line-spacing:2;"
               wrapText="true" text=""/>

        <!-- Réponse IA -->
        <Label fx:id="voiceResponseLabel"
               style="-fx-text-fill:#34D399;-fx-font-size:12px;-fx-line-spacing:2;-fx-font-weight:500;"
               wrapText="true" text=""/>

    </VBox>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- ══ CITY VIEW CONTAINER (AJOUT OBLIGATOIRE) ═══════════════════════ -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <VBox fx:id="cityView" spacing="20" visible="false" managed="false">
        <!-- CityView.fxml sera chargé dynamiquement ici -->
    </VBox>

</VBox>