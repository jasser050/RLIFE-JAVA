<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color:#060D1A;-fx-background:#060D1A;-fx-border-color:transparent;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.studyflow.controllers.CityViewController">

    <VBox spacing="18" style="-fx-background-color:#060D1A;">
        <padding>
            <Insets top="18" right="22" bottom="28" left="22"/>
        </padding>

        <HBox alignment="CENTER_LEFT"
              spacing="14"
              style="-fx-background-color:#0B1526;-fx-border-color:#16304D;-fx-border-width:1;-fx-border-radius:12;-fx-background-radius:12;-fx-padding:14 18;">
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label fx:id="lblCityName"
                       text="My City"
                       style="-fx-text-fill:#F8FAFC;-fx-font-size:24px;-fx-font-weight:800;"/>
                <Label text="Walk inside the city, enter buildings, and grow your score."
                       style="-fx-text-fill:#64748B;-fx-font-size:12px;"/>
            </VBox>
            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label text="TOTAL POINTS"
                       style="-fx-text-fill:#334155;-fx-font-size:9px;-fx-font-weight:800;"/>
                <Label fx:id="lblTotalPoints"
                       text="0"
                       style="-fx-text-fill:#A78BFA;-fx-font-size:24px;-fx-font-weight:900;"/>
            </VBox>
            <Label fx:id="lblRank"
                   text="Loading..."
                   style="-fx-text-fill:#34D399;-fx-font-size:12px;-fx-font-weight:800;-fx-background-color:#0D2C1F;-fx-padding:5 12;-fx-background-radius:20;"/>
        </HBox>

        <VBox spacing="10"
              style="-fx-background-color:#07111F;-fx-border-color:#1E3A5F;-fx-border-width:1;-fx-border-radius:16;-fx-background-radius:16;-fx-padding:12;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="CITY MAP"
                       style="-fx-text-fill:#F8FAFC;-fx-font-size:14px;-fx-font-weight:800;"/>
                <Label text="Interactive game view"
                       style="-fx-text-fill:#64748B;-fx-font-size:12px;"/>
            </HBox>
            <StackPane fx:id="cityMapHost"
                       prefHeight="560"
                       minHeight="460"
                       style="-fx-background-color:#081322;-fx-background-radius:12;">
                <Label text="Loading city map..."
                       style="-fx-text-fill:#64748B;-fx-font-size:13px;-fx-font-weight:700;"/>
            </StackPane>
        </VBox>

        <HBox spacing="16">
            <VBox alignment="CENTER"
                  spacing="10"
                  prefWidth="220"
                  minWidth="220"
                  style="-fx-background-color:#0F172A;-fx-border-color:#7C3AED;-fx-border-width:2;-fx-border-radius:20;-fx-background-radius:20;-fx-padding:28 20;-fx-effect:dropshadow(gaussian,rgba(124,58,237,0.45),24,0,0,6);">
                <Label fx:id="lblBuildingEmoji" text=""
                       style="-fx-text-fill:#F8FAFC;-fx-font-size:58px;"/>
                <Label fx:id="lblCurrentBuilding" text="Building"
                       style="-fx-text-fill:#F8FAFC;-fx-font-size:18px;-fx-font-weight:800;"/>
                <Label fx:id="lblBuildingDesc" text="Loading city level..."
                       wrapText="true"
                       style="-fx-text-fill:#64748B;-fx-font-size:12px;-fx-alignment:CENTER;"/>
                <Label text="CURRENT BUILDING"
                       style="-fx-text-fill:#334155;-fx-font-size:9px;-fx-font-weight:800;"/>
            </VBox>

            <VBox spacing="14" HBox.hgrow="ALWAYS">
                <VBox spacing="10"
                      style="-fx-background-color:#0F172A;-fx-border-color:#1E293B;-fx-border-width:1;-fx-border-radius:16;-fx-background-radius:16;-fx-padding:18 20;">
                    <Label text="NEXT BUILDING"
                           style="-fx-text-fill:#334155;-fx-font-size:9px;-fx-font-weight:800;"/>
                    <Label fx:id="lblNextBuilding" text="Loading next level..."
                           style="-fx-text-fill:#A78BFA;-fx-font-size:14px;-fx-font-weight:700;"/>
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <ProgressBar fx:id="pbProgress"
                                     progress="0"
                                     prefHeight="10"
                                     HBox.hgrow="ALWAYS"
                                     style="-fx-accent:#7C3AED;-fx-background-color:#1E293B;-fx-background-radius:6;-fx-border-radius:6;"/>
                        <Label fx:id="lblProgressPct"
                               text="0%"
                               style="-fx-text-fill:#7C3AED;-fx-font-size:14px;-fx-font-weight:900;-fx-min-width:46;"/>
                    </HBox>
                </VBox>

                <VBox spacing="8"
                      style="-fx-background-color:#0F172A;-fx-border-color:#1E293B;-fx-border-width:1;-fx-border-radius:16;-fx-background-radius:16;-fx-padding:16 20;">
                    <Label text="YOUR EVALUATIONS BREAKDOWN"
                           style="-fx-text-fill:#334155;-fx-font-size:9px;-fx-font-weight:800;"/>
                    <Label fx:id="lblPointsBreakdown"
                           text=""
                           wrapText="true"
                           style="-fx-text-fill:#94A3B8;-fx-font-size:12px;"/>
                </VBox>
            </VBox>
        </HBox>

        <VBox spacing="12"
              style="-fx-background-color:#0F172A;-fx-border-color:#1E293B;-fx-border-width:1;-fx-border-radius:16;-fx-background-radius:16;-fx-padding:18 20;">
            <Label text="ACHIEVEMENTS"
                   style="-fx-text-fill:#F8FAFC;-fx-font-size:14px;-fx-font-weight:800;"/>
            <HBox fx:id="achievementRow" spacing="10" alignment="CENTER_LEFT"/>
        </VBox>

        <VBox spacing="12"
              style="-fx-background-color:#0F172A;-fx-border-color:#1E293B;-fx-border-width:1;-fx-border-radius:16;-fx-background-radius:16;-fx-padding:18 20;">
            <VBox spacing="2">
                <Label text="ALL BUILDINGS"
                       style="-fx-text-fill:#F8FAFC;-fx-font-size:14px;-fx-font-weight:800;"/>
                <Label text="Earn points from evaluations to unlock bigger city buildings."
                       style="-fx-text-fill:#475569;-fx-font-size:12px;"/>
            </VBox>
            <FlowPane fx:id="buildingsGrid" hgap="12" vgap="12"/>
        </VBox>

        <VBox spacing="12">
            <VBox spacing="2">
                <Label text="YOUR CITIES BY SUBJECT"
                       style="-fx-text-fill:#F8FAFC;-fx-font-size:14px;-fx-font-weight:800;"/>
                <Label text="Each subject grows based on its own evaluation points."
                       style="-fx-text-fill:#475569;-fx-font-size:12px;"/>
            </VBox>
            <VBox fx:id="subjectCityList" spacing="10"/>
        </VBox>
    </VBox>
</ScrollPane>
