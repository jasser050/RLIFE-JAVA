<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<!--
  CityView.fxml
  Path: src/main/resources/com/studyflow/views/CityView.fxml
  Controller: com.studyflow.controllers.CityViewController
-->
<ScrollPane fitToWidth="true"
            style="-fx-background-color:#060D1A;-fx-background:#060D1A;-fx-border-color:transparent;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.studyflow.controllers.CityViewController">

    <VBox spacing="20" style="-fx-background-color:#060D1A;">
        <padding><Insets top="24" right="28" bottom="32" left="28"/></padding>

        <!-- ═══════════════════════════════════════════════════
             HEADER — City name + total points + rank
        ═══════════════════════════════════════════════════ -->
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color:#0F172A;-fx-background-radius:16;-fx-padding:20 24;
                     -fx-border-color:#1E293B;-fx-border-width:1;-fx-border-radius:16;">

            <Label text="🏙️" style="-fx-font-size:42px;"/>

            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label fx:id="lblCityName" text="My City"
                       style="-fx-text-fill:#F8FAFC;-fx-font-size:26px;-fx-font-weight:800;"/>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Total points:"
                           style="-fx-text-fill:#64748B;-fx-font-size:13px;"/>
                    <Label fx:id="lblTotalPoints" text="0"
                           style="-fx-text-fill:#A78BFA;-fx-font-size:22px;-fx-font-weight:800;"/>
                    <Label fx:id="lblRank" text="🌱 Beginner"
                           style="-fx-text-fill:#34D399;-fx-font-size:12px;-fx-font-weight:700;
                                  -fx-background-color:rgba(52,211,153,0.12);
                                  -fx-padding:4 12;-fx-background-radius:20;"/>
                </HBox>
            </VBox>

            <!-- Points formula mini legend -->
            <VBox spacing="4" alignment="CENTER_RIGHT">
                <Label text="POINT FORMULA" style="-fx-text-fill:#334155;-fx-font-size:9px;-fx-font-weight:700;"/>
                <Label text="(Score ÷ Max) × 100 × Priority"
                       style="-fx-text-fill:#475569;-fx-font-size:11px;"/>
                <HBox spacing="6" alignment="CENTER_RIGHT">
                    <Label text="🔴×2" style="-fx-text-fill:#FB7185;-fx-font-size:11px;
                                              -fx-background-color:#2D0A0A;-fx-padding:2 8;-fx-background-radius:12;"/>
                    <Label text="🟡×1.5" style="-fx-text-fill:#FBBF24;-fx-font-size:11px;
                                                -fx-background-color:#2C1E00;-fx-padding:2 8;-fx-background-radius:12;"/>
                    <Label text="🟢×1" style="-fx-text-fill:#34D399;-fx-font-size:11px;
                                              -fx-background-color:#0D2C1F;-fx-padding:2 8;-fx-background-radius:12;"/>
                </HBox>
            </VBox>
        </HBox>

        <VBox spacing="12"
              style="-fx-background-color:#07111F;-fx-border-color:#1E3A5F;-fx-border-width:1;
                     -fx-border-radius:16;-fx-background-radius:16;-fx-padding:14;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="CITY MAP" style="-fx-text-fill:#F8FAFC;-fx-font-size:14px;-fx-font-weight:800;"/>
                <Label text="Walk to a subject building and press E to enter"
                       style="-fx-text-fill:#64748B;-fx-font-size:12px;"/>
            </HBox>
            <WebView fx:id="cityMapWebView" prefHeight="560" minHeight="460"/>
        </VBox>

        <!-- ═══════════════════════════════════════════════════
             CURRENT BUILDING SHOWCASE + PROGRESS
        ═══════════════════════════════════════════════════ -->
        <HBox spacing="16">

            <!-- Big building display -->
            <VBox alignment="CENTER" spacing="10" prefWidth="200" minWidth="200"
                  style="-fx-background-color:#0F172A;-fx-border-color:#7C3AED;-fx-border-width:2;
                         -fx-border-radius:20;-fx-background-radius:20;-fx-padding:28 20;
                         -fx-effect:dropshadow(gaussian,rgba(124,58,237,0.5),24,0,0,6);">
                <Label fx:id="lblBuildingEmoji" text="🏕️" style="-fx-font-size:72px;"/>
                <Label fx:id="lblCurrentBuilding" text="Tent"
                       style="-fx-text-fill:#F8FAFC;-fx-font-size:18px;-fx-font-weight:800;"/>
                <Label fx:id="lblBuildingDesc" text="Your first shelter"
                       style="-fx-text-fill:#64748B;-fx-font-size:11px;-fx-alignment:CENTER;"
                       wrapText="true"/>
                <Label text="CURRENT BUILDING"
                       style="-fx-text-fill:#334155;-fx-font-size:9px;-fx-font-weight:700;
                              -fx-letter-spacing:1;-fx-padding:4 0 0 0;"/>
            </VBox>

            <!-- Progress panel -->
            <VBox spacing="14" HBox.hgrow="ALWAYS">

                <!-- Next building -->
                <VBox spacing="10"
                      style="-fx-background-color:#0F172A;-fx-border-color:#1E293B;-fx-border-width:1;
                             -fx-border-radius:16;-fx-background-radius:16;-fx-padding:18 20;">
                    <Label text="NEXT BUILDING"
                           style="-fx-text-fill:#334155;-fx-font-size:9px;-fx-font-weight:700;
                                  -fx-letter-spacing:1.5;"/>
                    <Label fx:id="lblNextBuilding" text="Next: 🛖 Hut  (50 pts away)"
                           style="-fx-text-fill:#A78BFA;-fx-font-size:14px;-fx-font-weight:600;"/>
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <ProgressBar fx:id="pbProgress" progress="0"
                                     prefHeight="12" HBox.hgrow="ALWAYS"
                                     style="-fx-accent:#7C3AED;-fx-background-color:#1E293B;
                                            -fx-background-radius:6;-fx-border-radius:6;"/>
                        <Label fx:id="lblProgressPct" text="0%"
                               style="-fx-text-fill:#7C3AED;-fx-font-size:14px;-fx-font-weight:800;
                                      -fx-min-width:46;"/>
                    </HBox>
                </VBox>

                <!-- Points breakdown -->
                <VBox spacing="8"
                      style="-fx-background-color:#0F172A;-fx-border-color:#1E293B;-fx-border-width:1;
                             -fx-border-radius:16;-fx-background-radius:16;-fx-padding:16 20;">
                    <Label text="YOUR EVALUATIONS BREAKDOWN"
                           style="-fx-text-fill:#334155;-fx-font-size:9px;-fx-font-weight:700;
                                  -fx-letter-spacing:1.5;"/>
                    <Label fx:id="lblPointsBreakdown" text=""
                           style="-fx-text-fill:#94A3B8;-fx-font-size:12px;" wrapText="true"/>
                </VBox>

            </VBox>
        </HBox>

        <!-- ═══════════════════════════════════════════════════
             ACHIEVEMENTS
        ═══════════════════════════════════════════════════ -->
        <VBox spacing="12"
              style="-fx-background-color:#0F172A;-fx-border-color:#1E293B;-fx-border-width:1;
                     -fx-border-radius:16;-fx-background-radius:16;-fx-padding:18 20;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="🏅" style="-fx-font-size:18px;"/>
                <Label text="ACHIEVEMENTS"
                       style="-fx-text-fill:#F8FAFC;-fx-font-size:14px;-fx-font-weight:700;"/>
            </HBox>
            <HBox fx:id="achievementRow" spacing="10" alignment="CENTER_LEFT"/>
        </VBox>

        <!-- ═══════════════════════════════════════════════════
             ALL BUILDINGS — LOCKED / UNLOCKED GRID
        ═══════════════════════════════════════════════════ -->
        <VBox spacing="12"
              style="-fx-background-color:#0F172A;-fx-border-color:#1E293B;-fx-border-width:1;
                     -fx-border-radius:16;-fx-background-radius:16;-fx-padding:18 20;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="🏗️" style="-fx-font-size:18px;"/>
                <VBox spacing="2">
                    <Label text="ALL BUILDINGS"
                           style="-fx-text-fill:#F8FAFC;-fx-font-size:14px;-fx-font-weight:700;"/>
                    <Label text="Earn points by adding evaluations to unlock new buildings"
                           style="-fx-text-fill:#475569;-fx-font-size:12px;"/>
                </VBox>
            </HBox>
            <FlowPane fx:id="buildingsGrid" hgap="12" vgap="12"/>
        </VBox>

        <!-- ═══════════════════════════════════════════════════
             PER-SUBJECT MINI CITIES
        ═══════════════════════════════════════════════════ -->
        <VBox spacing="12">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="📚" style="-fx-font-size:18px;"/>
                <VBox spacing="2">
                    <Label text="YOUR CITIES BY SUBJECT"
                           style="-fx-text-fill:#F8FAFC;-fx-font-size:14px;-fx-font-weight:700;"/>
                    <Label text="Each subject has its own city — ranked by points earned"
                           style="-fx-text-fill:#475569;-fx-font-size:12px;"/>
                </VBox>
            </HBox>
            <VBox fx:id="subjectCityList" spacing="10"/>
        </VBox>

    </VBox>
</ScrollPane>
