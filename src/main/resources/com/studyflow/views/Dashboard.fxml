<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.DashboardController"
      spacing="24" style="-fx-background-color: #020617;">

    <padding>
        <Insets top="0" right="0" bottom="24" left="0"/>
    </padding>

    <!-- Welcome Header -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="welcomeLabel" text="Good evening, Student" styleClass="text-heading"/>
            <Label text="Here's what's happening with your studies today" styleClass="text-muted"/>
        </VBox>

        <!-- Streak Card -->
        <HBox styleClass="card" alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 12 16;">
            <StackPane styleClass="stat-icon-box, accent" prefWidth="40" prefHeight="40">
                <FontIcon iconLiteral="fth-zap" iconSize="18"/>
            </StackPane>
            <VBox spacing="2">
                <Label fx:id="streakLabel" text="7" styleClass="stat-value" style="-fx-font-size: 22px;"/>
                <Label text="Day streak" styleClass="text-small"/>
            </VBox>
        </HBox>
    </HBox>

    <!-- Stats Cards Row -->
    <HBox spacing="16">
        <!-- Due Soon Card -->
        <VBox styleClass="stat-card" spacing="16" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <StackPane styleClass="stat-icon-box, primary" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-clock" iconSize="20"/>
                </StackPane>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="This week" styleClass="badge, primary"/>
            </HBox>
            <VBox spacing="4">
                <Label fx:id="assignmentsDueLabel" text="5" styleClass="stat-value"/>
                <Label text="Assignments due" styleClass="stat-label"/>
            </VBox>
        </VBox>

        <!-- Completed Card -->
        <VBox styleClass="stat-card" spacing="16" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <StackPane styleClass="stat-icon-box, success" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-check-circle" iconSize="20"/>
                </StackPane>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="+3" styleClass="badge, success"/>
            </HBox>
            <VBox spacing="4">
                <Label fx:id="completedLabel" text="12" styleClass="stat-value"/>
                <Label text="Completed" styleClass="stat-label"/>
            </VBox>
        </VBox>

        <!-- Study Hours Card -->
        <VBox styleClass="stat-card" spacing="16" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <StackPane styleClass="stat-icon-box, accent" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-clock" iconSize="20"/>
                </StackPane>
            </HBox>
            <VBox spacing="4">
                <HBox alignment="BASELINE_LEFT" spacing="2">
                    <Label fx:id="studyHoursLabel" text="24" styleClass="stat-value"/>
                    <Label text="h" styleClass="text-muted" style="-fx-font-size: 16px;"/>
                </HBox>
                <Label text="Study time" styleClass="stat-label"/>
            </VBox>
        </VBox>

        <!-- Cards Reviewed Card -->
        <VBox styleClass="stat-card" spacing="16" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <StackPane styleClass="stat-icon-box, warning" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-layers" iconSize="20"/>
                </StackPane>
            </HBox>
            <VBox spacing="4">
                <Label fx:id="cardsReviewedLabel" text="48" styleClass="stat-value"/>
                <Label text="Cards reviewed" styleClass="stat-label"/>
            </VBox>
        </VBox>
    </HBox>

    <!-- Charts Row -->
    <HBox spacing="16">
        <!-- Study Time Chart -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS">
            <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, primary" prefWidth="36" prefHeight="36">
                    <FontIcon iconLiteral="fth-bar-chart-2" iconSize="16"/>
                </StackPane>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Study Time" styleClass="card-title"/>
                    <Label text="Hours per day this week" styleClass="text-small"/>
                </VBox>
                <Label text="This Week" styleClass="badge, primary"/>
            </HBox>
            <VBox styleClass="card-body" VBox.vgrow="ALWAYS">
                <AreaChart fx:id="studyTimeChart" legendVisible="false"
                           prefHeight="200" createSymbols="true">
                    <xAxis><CategoryAxis side="BOTTOM"/></xAxis>
                    <yAxis><NumberAxis side="LEFT" autoRanging="true"/></yAxis>
                </AreaChart>
            </VBox>
        </VBox>

        <!-- Weekly Progress Chart -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS">
            <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, success" prefWidth="36" prefHeight="36">
                    <FontIcon iconLiteral="fth-trending-up" iconSize="16"/>
                </StackPane>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Weekly Progress" styleClass="card-title"/>
                    <Label text="Tasks completed vs pending" styleClass="text-small"/>
                </VBox>
                <Label text="+3" styleClass="badge, success"/>
            </HBox>
            <VBox styleClass="card-body" VBox.vgrow="ALWAYS">
                <BarChart fx:id="weeklyProgressChart" legendVisible="true"
                          prefHeight="200" barGap="2" categoryGap="20">
                    <xAxis><CategoryAxis side="BOTTOM"/></xAxis>
                    <yAxis><NumberAxis side="LEFT" autoRanging="true"/></yAxis>
                </BarChart>
            </VBox>
        </VBox>
    </HBox>

    <!-- Main Content Grid -->
    <HBox spacing="16">
        <!-- Today's Schedule -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" maxWidth="400">
            <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, primary" prefWidth="36" prefHeight="36">
                    <FontIcon iconLiteral="fth-calendar" iconSize="16"/>
                </StackPane>
                <Label text="Today's Schedule" styleClass="card-title" HBox.hgrow="ALWAYS"/>
                <Hyperlink text="View all" style="-fx-text-fill: #A78BFA; -fx-font-size: 13px;"/>
            </HBox>
            <VBox fx:id="scheduleList" styleClass="card-body" spacing="8"/>
        </VBox>

        <!-- Upcoming Tasks -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" maxWidth="400">
            <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, accent" prefWidth="36" prefHeight="36">
                    <FontIcon iconLiteral="fth-clipboard" iconSize="16"/>
                </StackPane>
                <Label text="Upcoming Tasks" styleClass="card-title" HBox.hgrow="ALWAYS"/>
                <Hyperlink text="View all" style="-fx-text-fill: #A78BFA; -fx-font-size: 13px;"/>
            </HBox>
            <VBox fx:id="tasksList" styleClass="card-body" spacing="8"/>
        </VBox>

        <!-- Recent Activity -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" maxWidth="400">
            <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, success" prefWidth="36" prefHeight="36">
                    <FontIcon iconLiteral="fth-activity" iconSize="16"/>
                </StackPane>
                <Label text="Recent Activity" styleClass="card-title" HBox.hgrow="ALWAYS"/>
            </HBox>
            <VBox fx:id="activityList" styleClass="card-body" spacing="12"/>
        </VBox>
    </HBox>

    <!-- Course Progress Section -->
    <VBox styleClass="card">
        <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="12">
            <StackPane styleClass="stat-icon-box, primary" prefWidth="36" prefHeight="36">
                <FontIcon iconLiteral="fth-book-open" iconSize="16"/>
            </StackPane>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="Course Progress" styleClass="card-title"/>
                <Label text="Track your learning journey" styleClass="text-small"/>
            </VBox>
            <Button text="View all" styleClass="btn-secondary">
                <graphic>
                    <FontIcon iconLiteral="fth-arrow-right" iconSize="14"/>
                </graphic>
            </Button>
        </HBox>
        <HBox styleClass="card-body" spacing="16">
            <fx:include fx:id="courseCard1" source="components/CourseCard.fxml"/>
            <fx:include fx:id="courseCard2" source="components/CourseCard.fxml"/>
            <fx:include fx:id="courseCard3" source="components/CourseCard.fxml"/>
        </HBox>
    </VBox>

    <!-- Quick Actions — each card has an fx:id so DashboardController can add click handlers -->
    <HBox spacing="16">

        <!-- Add Assignment -->
        <VBox fx:id="quickCardAssignment" styleClass="stat-card" alignment="CENTER"
              spacing="12" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
            <StackPane styleClass="stat-icon-box, primary" prefWidth="48" prefHeight="48">
                <FontIcon iconLiteral="fth-plus-circle" iconSize="24"/>
            </StackPane>
            <Label text="Add Assignment" styleClass="text-body" style="-fx-font-weight: 600;"/>
            <Label text="Track new tasks" styleClass="text-small"/>
        </VBox>

        <!-- Schedule Event -->
        <VBox fx:id="quickCardSchedule" styleClass="stat-card" alignment="CENTER"
              spacing="12" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
            <StackPane styleClass="stat-icon-box, accent" prefWidth="48" prefHeight="48">
                <FontIcon iconLiteral="fth-calendar" iconSize="24"/>
            </StackPane>
            <Label text="Schedule Event" styleClass="text-body" style="-fx-font-weight: 600;"/>
            <Label text="Plan your time" styleClass="text-small"/>
        </VBox>

        <!-- Start Revision — navigates to Revisions.fxml (Decks) -->
        <VBox fx:id="quickCardDecks" styleClass="stat-card" alignment="CENTER"
              spacing="12" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
            <StackPane styleClass="stat-icon-box, success" prefWidth="48" prefHeight="48">
                <FontIcon iconLiteral="fth-layers" iconSize="24"/>
            </StackPane>
            <Label text="Start Revision" styleClass="text-body" style="-fx-font-weight: 600;"/>
            <Label text="Review flashcards" styleClass="text-small"/>
        </VBox>

        <!-- Wellness Check -->
        <VBox fx:id="quickCardWellness" styleClass="stat-card" alignment="CENTER"
              spacing="12" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
            <StackPane styleClass="stat-icon-box, danger" prefWidth="48" prefHeight="48">
                <FontIcon iconLiteral="fth-heart" iconSize="24"/>
            </StackPane>
            <Label text="Wellness Check" styleClass="text-body" style="-fx-font-weight: 600;"/>
            <Label text="How are you feeling?" styleClass="text-small"/>
        </VBox>

    </HBox>
</VBox>
