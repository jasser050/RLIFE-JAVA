<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.web.WebView?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.ForgotPasswordController"
      styleClass="app-container">

    <!-- Title Bar -->
    <HBox styleClass="title-bar" alignment="CENTER_LEFT" spacing="0"
          onMousePressed="#onDragStart" onMouseDragged="#onDragged">
        <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
            <padding><Insets left="16"/></padding>
            <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                <image><Image url="@../images/logo.png"/></image>
            </ImageView>
            <Label text="RLife" styleClass="title-bar-title"/>
            <Label text="—" style="-fx-text-fill: #475569;"/>
            <Label text="Reset Password" styleClass="title-bar-subtitle"/>
        </HBox>
        <HBox alignment="CENTER_RIGHT" spacing="0" styleClass="window-controls">
            <Button styleClass="window-btn, minimize-btn" onAction="#minimizeWindow">
                <graphic><FontIcon iconLiteral="fth-minus" iconSize="14"/></graphic>
            </Button>
            <Button styleClass="window-btn, maximize-btn" onAction="#maximizeWindow">
                <graphic><FontIcon iconLiteral="fth-square" iconSize="12"/></graphic>
            </Button>
            <Button styleClass="window-btn, close-btn" onAction="#closeWindow">
                <graphic><FontIcon iconLiteral="fth-x" iconSize="14"/></graphic>
            </Button>
        </HBox>
    </HBox>

    <!-- Content -->
    <HBox VBox.vgrow="ALWAYS" spacing="0">

        <!-- Left: Form -->
        <VBox styleClass="auth-left-panel" HBox.hgrow="SOMETIMES" minWidth="520" maxWidth="580">
            <VBox VBox.vgrow="ALWAYS" alignment="CENTER" spacing="0">
                <padding><Insets top="0" right="48" bottom="0" left="48"/></padding>

                <ImageView fitWidth="80" fitHeight="80" preserveRatio="true" styleClass="auth-logo-img">
                    <image><Image url="@../images/logo.png"/></image>
                </ImageView>
                <VBox.margin><Insets bottom="8"/></VBox.margin>
                <Label text="RLife" styleClass="auth-brand-label"/>
                <VBox.margin><Insets bottom="24"/></VBox.margin>

                <Label text="Reset Your Password" styleClass="auth-title"/>
                <VBox.margin><Insets bottom="6"/></VBox.margin>
                <Label fx:id="subtitleLabel" text="Enter your email to receive a reset code"
                       styleClass="auth-subtitle"/>
                <VBox.margin><Insets bottom="24"/></VBox.margin>

                <Label fx:id="errorLabel" styleClass="auth-error" managed="false" visible="false"
                       wrapText="true" maxWidth="Infinity"/>
                <VBox.margin><Insets bottom="12"/></VBox.margin>

                <Label fx:id="successLabel" style="-fx-text-fill: #34D399; -fx-font-size: 13px;"
                       managed="false" visible="false" wrapText="true" maxWidth="Infinity"/>
                <VBox.margin><Insets bottom="12"/></VBox.margin>

                <!-- Step 1: Email input -->
                <VBox fx:id="emailPane" spacing="8">
                    <Label text="Email address" styleClass="auth-field-label"/>
                    <TextField fx:id="emailField" styleClass="auth-field" promptText="you@university.edu"/>
                    <VBox.margin><Insets bottom="20"/></VBox.margin>

                    <Button fx:id="sendCodeBtn" text="Send Reset Code" styleClass="auth-btn-primary"
                            maxWidth="Infinity" onAction="#handleSendCode">
                        <graphic><FontIcon iconLiteral="fth-mail" iconSize="16" iconColor="white"/></graphic>
                    </Button>
                </VBox>

                <!-- Step 2: Code verification -->
                <VBox fx:id="codePane" spacing="8" managed="false" visible="false">
                    <Label text="Reset Code" styleClass="auth-field-label"/>
                    <TextField fx:id="codeField" styleClass="auth-field" promptText="Enter 6-digit code"/>
                    <VBox.margin><Insets bottom="20"/></VBox.margin>

                    <Button text="Verify Code" styleClass="auth-btn-primary"
                            maxWidth="Infinity" onAction="#handleVerifyCode">
                        <graphic><FontIcon iconLiteral="fth-check-circle" iconSize="16" iconColor="white"/></graphic>
                    </Button>
                </VBox>

                <!-- Step 3: New password -->
                <VBox fx:id="passwordPane" spacing="8" managed="false" visible="false">
                    <Label text="New Password" styleClass="auth-field-label"/>
                    <PasswordField fx:id="newPasswordField" styleClass="auth-field"
                                   promptText="Enter new password"/>
                    <VBox.margin><Insets bottom="12"/></VBox.margin>

                    <Label text="Confirm Password" styleClass="auth-field-label"/>
                    <PasswordField fx:id="confirmPasswordField" styleClass="auth-field"
                                   promptText="Confirm new password"/>
                    <VBox.margin><Insets bottom="20"/></VBox.margin>

                    <Button text="Reset Password" styleClass="auth-btn-primary"
                            maxWidth="Infinity" onAction="#handleResetPassword">
                        <graphic><FontIcon iconLiteral="fth-lock" iconSize="16" iconColor="white"/></graphic>
                    </Button>
                </VBox>

                <VBox.margin><Insets top="24"/></VBox.margin>
                <HBox alignment="CENTER">
                    <Button text="← Back to Sign In" styleClass="auth-link-sm" onAction="#goToLogin"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- Right: Marketing Panel -->
        <StackPane fx:id="robotContainer" styleClass="auth-right-panel" HBox.hgrow="ALWAYS">
            <WebView fx:id="splineWebView"/>
        </StackPane>
    </HBox>
</VBox>
