<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.ProjectsController"
      spacing="20"
      styleClass="page-section">

    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="projects-toolbar">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Projects" styleClass="text-heading"/>
            <Label text="A cleaner project registry with separate edit/delete windows, a separate share section, and 500-character descriptions." styleClass="text-muted"/>
        </VBox>
        <HBox spacing="12" alignment="CENTER_RIGHT" styleClass="projects-toolbar-actions">
            <ComboBox fx:id="projectSortCombo" prefWidth="190" styleClass="form-combo"/>
            <Button fx:id="exportProjectsPdfButton" text="Export PDF" onAction="#handleExportProjectsPdf" styleClass="pdf-export-button">
                <graphic>
                    <FontIcon iconLiteral="fth-download" iconSize="16"/>
                </graphic>
            </Button>
            <TextField fx:id="projectSearchField" promptText="Search projects..." styleClass="search-field" prefWidth="300"/>
        </HBox>
    </HBox>

    <Label fx:id="feedbackLabel" managed="false" visible="false" maxWidth="Infinity" styleClass="inline-alert, inline-alert-success"/>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <VBox spacing="16" HBox.hgrow="ALWAYS">
            <VBox styleClass="card, board-hero-card, projects-hero-card" spacing="14">
                <HBox alignment="CENTER_LEFT" spacing="16" styleClass="projects-hero-layout">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Project Registry" styleClass="card-title, projects-hero-kicker"/>
                        <Label fx:id="selectedProjectTitleLabel" text="Select a project to manage it from the right-side interfaces." styleClass="text-muted, projects-hero-title" wrapText="true"/>
                    </VBox>
                    <VBox alignment="CENTER_RIGHT" spacing="4" styleClass="projects-hero-meta">
                        <Label fx:id="selectedProjectMetaLabel" text="No project selected" styleClass="card-subtitle, projects-hero-subtitle"/>
                        <Label fx:id="selectedProjectCountLabel" text="0 assignments" styleClass="text-muted, projects-hero-count"/>
                    </VBox>
                </HBox>

                <HBox spacing="10" styleClass="panel-toolbar">
                    <Button fx:id="showCreateProjectPanelButton" text="Create" onAction="#handleShowCreatePanel" styleClass="panel-switch-button, active">
                        <graphic>
                            <FontIcon iconLiteral="fth-folder-plus" iconSize="15"/>
                        </graphic>
                    </Button>
                    <Button fx:id="showEditProjectPanelButton" text="Edit Window" onAction="#handleShowEditPanel" styleClass="panel-switch-button">
                        <graphic>
                            <FontIcon iconLiteral="fth-edit-3" iconSize="15"/>
                        </graphic>
                    </Button>
                    <Button fx:id="showDeleteProjectPanelButton" text="Delete Window" onAction="#handleShowDeletePanel" styleClass="panel-switch-button">
                        <graphic>
                            <FontIcon iconLiteral="fth-trash-2" iconSize="15"/>
                        </graphic>
                    </Button>
                    <Button fx:id="showShareProjectPanelButton" text="Share" onAction="#handleShowSharePanel" styleClass="panel-switch-button">
                        <graphic>
                            <FontIcon iconLiteral="fth-send" iconSize="15"/>
                        </graphic>
                    </Button>
                    <Button fx:id="showProjectStatsPanelButton" text="Stats" onAction="#handleShowStatsPanel" styleClass="panel-switch-button">
                        <graphic>
                            <FontIcon iconLiteral="fth-bar-chart-2" iconSize="15"/>
                        </graphic>
                    </Button>
                    <Button fx:id="openProjectAiWorkspaceButton" text="AI Workspace" onAction="#handleOpenProjectAiWorkspace" styleClass="panel-switch-button">
                        <graphic>
                            <FontIcon iconLiteral="fth-cpu" iconSize="15"/>
                        </graphic>
                    </Button>
                </HBox>
            </VBox>

            <VBox styleClass="card, registry-shell, projects-workspace-shell" VBox.vgrow="ALWAYS" spacing="16">
                <HBox styleClass="card-header" alignment="CENTER_LEFT">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Projects Registry" styleClass="card-title"/>
                        <Label text="Browse all owned and shared projects, then inspect the linked assignments in the snapshot panel." styleClass="card-subtitle"/>
                    </VBox>
                    <Label text="Live workspace" styleClass="badge, secondary, projects-section-chip"/>
                </HBox>

                <HBox spacing="18" VBox.vgrow="ALWAYS" styleClass="projects-content-split" style="-fx-padding: 0 16 16 16;">
                    <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" styleClass="transparent-scroll, projects-registry-scroll">
                        <VBox fx:id="projectList" spacing="12" styleClass="projects-registry-list" style="-fx-padding: 4 2 4 2;"/>
                    </ScrollPane>

                    <VBox styleClass="card, project-detail-shell, projects-snapshot-shell" prefWidth="330" minWidth="310" maxWidth="360" spacing="12">
                        <HBox styleClass="card-header, projects-snapshot-header" alignment="CENTER_LEFT">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Project Snapshot" styleClass="card-title"/>
                                <Label text="Linked assignments and quick context for the active project." styleClass="card-subtitle"/>
                            </VBox>
                            <Button fx:id="generateProjectAiTasksButton" onAction="#handleGenerateProjectAiTasks" styleClass="btn-secondary" contentDisplay="GRAPHIC_ONLY">
                                <graphic>
                                    <FontIcon iconLiteral="fth-zap" iconSize="15"/>
                                </graphic>
                            </Button>
                        </HBox>
                        <VBox fx:id="projectAssignmentsList" spacing="10" styleClass="projects-snapshot-body" style="-fx-padding: 0 16 16 16;" VBox.vgrow="ALWAYS"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>

        <StackPane fx:id="projectActionPanelStack" prefWidth="430" minWidth="400" maxWidth="450" styleClass="projects-action-stack">
            <VBox fx:id="createProjectPanel" styleClass="card, form-shell, action-panel-card, projects-action-panel" spacing="14">
                <Label text="Create Project" styleClass="card-title"/>
                <Label text="Create a new project in its own dedicated interface." styleClass="text-muted" wrapText="true"/>

                <VBox spacing="6">
                    <Label text="Title" styleClass="form-label"/>
                    <TextField fx:id="createProjectTitleField" styleClass="form-input" promptText="Capstone sprint"/>
                    <Label fx:id="createProjectTitleError" styleClass="field-error" managed="false" visible="false"/>
                </VBox>

                <HBox spacing="12">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Start Date" styleClass="form-label"/>
                        <DatePicker fx:id="createProjectStartDatePicker" maxWidth="Infinity" styleClass="form-date"/>
                        <Label fx:id="createProjectStartDateError" styleClass="field-error" managed="false" visible="false"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="End Date" styleClass="form-label"/>
                        <DatePicker fx:id="createProjectEndDatePicker" maxWidth="Infinity" styleClass="form-date"/>
                        <Label fx:id="createProjectEndDateError" styleClass="field-error" managed="false" visible="false"/>
                    </VBox>
                </HBox>

                <VBox spacing="8">
                    <Label text="Status" styleClass="form-label"/>
                    <ComboBox fx:id="createProjectStatusCombo" maxWidth="Infinity" styleClass="form-combo"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="Description" styleClass="form-label"/>
                    <TextArea fx:id="createProjectDescriptionArea" styleClass="form-textarea" wrapText="true" promptText="Describe the project scope and goals. 500 characters maximum."/>
                </VBox>

                <HBox spacing="10">
                    <Button fx:id="createProjectButton" text="Create Project" onAction="#handleCreateProject" styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button fx:id="clearCreateProjectButton" text="Clear" onAction="#handleResetCreateProject" styleClass="btn-secondary"/>
                </HBox>
            </VBox>

            <VBox fx:id="shareProjectPanel" styleClass="card, form-shell, action-panel-card, projects-action-panel" spacing="14" visible="false" managed="false">
                <Label text="Share Project" styleClass="card-title"/>
                <Label text="Sharing has its own interface, separate from edit and delete." styleClass="text-muted" wrapText="true"/>

                <VBox spacing="6">
                    <Label text="Recipient" styleClass="form-label"/>
                    <TextField fx:id="shareProjectEmailField" styleClass="form-input" promptText="username, email, phone, or student id"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Role" styleClass="form-label"/>
                    <ComboBox fx:id="shareProjectRoleCombo" maxWidth="Infinity" styleClass="form-combo"/>
                </VBox>

                <Button fx:id="shareProjectButton" text="Share Project" onAction="#handleShareProject" styleClass="btn-primary" maxWidth="Infinity"/>
            </VBox>

            <VBox fx:id="statsProjectPanel" styleClass="card, form-shell, action-panel-card, projects-action-panel, projects-stats-panel" spacing="14" visible="false" managed="false">
                <Label text="Project Stats" styleClass="card-title"/>
                <Label text="The old stats section is moved here behind a dedicated button." styleClass="text-muted" wrapText="true"/>

                <HBox spacing="12">
                    <VBox styleClass="mini-stat-card, mini-stat-purple" HBox.hgrow="ALWAYS">
                        <Label fx:id="totalProjectsLabel" text="0" styleClass="mini-stat-value"/>
                        <Label text="Total" styleClass="mini-stat-label"/>
                    </VBox>
                    <VBox styleClass="mini-stat-card, mini-stat-violet" HBox.hgrow="ALWAYS">
                        <Label fx:id="inProgressProjectsLabel" text="0" styleClass="mini-stat-value"/>
                        <Label text="Active" styleClass="mini-stat-label"/>
                    </VBox>
                </HBox>

                <HBox spacing="12">
                    <VBox styleClass="mini-stat-card, mini-stat-green" HBox.hgrow="ALWAYS">
                        <Label fx:id="completedProjectsLabel" text="0" styleClass="mini-stat-value"/>
                        <Label text="Completed" styleClass="mini-stat-label"/>
                    </VBox>
                    <VBox styleClass="mini-stat-card, mini-stat-amber" HBox.hgrow="ALWAYS">
                        <Label fx:id="linkedAssignmentsLabel" text="0" styleClass="mini-stat-value"/>
                        <Label text="Assignments" styleClass="mini-stat-label"/>
                    </VBox>
                </HBox>

                <VBox styleClass="card, chart-shell">
                    <HBox styleClass="card-header" alignment="CENTER_LEFT">
                        <Label text="Status Mix" styleClass="card-title"/>
                    </HBox>
                    <VBox styleClass="card-body" alignment="CENTER">
                        <PieChart fx:id="projectStatusChart" prefHeight="210" labelsVisible="false"/>
                    </VBox>
                </VBox>

                <VBox styleClass="card, chart-shell">
                    <HBox styleClass="card-header" alignment="CENTER_LEFT">
                        <Label text="Assignment Load" styleClass="card-title"/>
                    </HBox>
                    <VBox styleClass="card-body">
                        <BarChart fx:id="projectLoadChart" legendVisible="false" prefHeight="210">
                            <xAxis>
                                <CategoryAxis side="BOTTOM"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis side="LEFT"/>
                            </yAxis>
                        </BarChart>
                    </VBox>
                </VBox>
            </VBox>
        </StackPane>
    </HBox>

    <padding>
        <Insets top="0" right="0" bottom="24" left="0"/>
    </padding>
</VBox>
