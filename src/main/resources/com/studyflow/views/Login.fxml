<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.web.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.LoginController"
      styleClass="app-container">

    <!-- ══════════ TITLE BAR ══════════ -->
    <HBox styleClass="title-bar" alignment="CENTER_LEFT" spacing="0"
          onMousePressed="#onDragStart" onMouseDragged="#onDragged">
        <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
            <padding><Insets left="16"/></padding>
            <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                <image><Image url="@../images/logo.png"/></image>
            </ImageView>
            <Label text="RLife" styleClass="title-bar-title"/>
            <Label text="—" style="-fx-text-fill: #475569;"/>
            <Label text="Sign In" styleClass="title-bar-subtitle"/>
        </HBox>
        <HBox alignment="CENTER_RIGHT" spacing="0">
            <Button fx:id="themeBtn" styleClass="theme-toggle-btn" onAction="#toggleTheme">
                <graphic><FontIcon iconLiteral="fth-sun" iconSize="13"/></graphic>
            </Button>
            <HBox styleClass="window-controls" spacing="0">
                <Button styleClass="window-btn, minimize-btn" onAction="#minimizeWindow">
                    <graphic><FontIcon iconLiteral="fth-minus" iconSize="14"/></graphic>
                </Button>
                <Button styleClass="window-btn, maximize-btn" onAction="#maximizeWindow">
                    <graphic><FontIcon iconLiteral="fth-square" iconSize="12"/></graphic>
                </Button>
                <Button styleClass="window-btn, close-btn" onAction="#closeWindow">
                    <graphic><FontIcon iconLiteral="fth-x" iconSize="14"/></graphic>
                </Button>
            </HBox>
        </HBox>
    </HBox>

    <!-- ══════════ CONTENT ══════════ -->
    <HBox VBox.vgrow="ALWAYS" spacing="0">

        <!-- ─── LEFT: Form ─── -->
        <VBox styleClass="auth-left-panel" HBox.hgrow="SOMETIMES" minWidth="520" maxWidth="580">
            <VBox VBox.vgrow="ALWAYS" alignment="CENTER" spacing="0">
                <padding><Insets top="0" right="48" bottom="0" left="48"/></padding>

                <!-- RLife Logo image -->
                <ImageView fitWidth="80" fitHeight="80" preserveRatio="true" styleClass="auth-logo-img">
                    <image><Image url="@../images/logo.png"/></image>
                </ImageView>
                <VBox.margin><Insets bottom="8"/></VBox.margin>
                <Label text="RLife" styleClass="auth-brand-label"/>
                <VBox.margin><Insets bottom="30"/></VBox.margin>

                <Label text="Welcome back" styleClass="auth-title"/>
                <VBox.margin><Insets bottom="6"/></VBox.margin>
                <Label text="Sign in to continue your learning journey" styleClass="auth-subtitle"/>
                <VBox.margin><Insets bottom="30"/></VBox.margin>

                <Label fx:id="errorLabel" styleClass="auth-error" managed="false" visible="false"
                       wrapText="true" maxWidth="Infinity"/>
                <VBox.margin><Insets bottom="12"/></VBox.margin>

                <VBox spacing="8">
                    <Label text="Email address" styleClass="auth-field-label"/>
                    <TextField fx:id="emailField" styleClass="auth-field" promptText="you@university.edu"/>
                </VBox>
                <VBox.margin><Insets bottom="20"/></VBox.margin>

                <VBox spacing="8">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Password" styleClass="auth-field-label" HBox.hgrow="ALWAYS"/>
                        <Button text="Forgot password?" styleClass="auth-link" onAction="#forgotPassword"/>
                    </HBox>
                    <PasswordField fx:id="passwordField" styleClass="auth-field" promptText="Enter your password"/>
                </VBox>
                <VBox.margin><Insets bottom="40"/></VBox.margin>

                <Button fx:id="loginBtn" text="Sign In" styleClass="auth-btn-primary"
                        maxWidth="Infinity" onAction="#handleLogin">
                    <VBox.margin><Insets top="16"/></VBox.margin>
                </Button>
                <VBox.margin><Insets bottom="24"/></VBox.margin>

                <HBox alignment="CENTER" spacing="12">
                    <Separator HBox.hgrow="ALWAYS"/>
                    <Label text="or" styleClass="auth-divider-text"/>
                    <Separator HBox.hgrow="ALWAYS"/>
                </HBox>
                <VBox.margin><Insets bottom="16"/></VBox.margin>

                <Button text="Sign in with Face ID" styleClass="auth-btn-secondary"
                        maxWidth="Infinity" onAction="#handleFaceLogin">
                    <graphic><FontIcon iconLiteral="fth-camera" iconSize="16"/></graphic>
                </Button>
                <VBox.margin><Insets bottom="20"/></VBox.margin>

                <HBox alignment="CENTER" spacing="6">
                    <Label text="Don't have an account?" styleClass="auth-muted-text"/>
                    <Button text="Create one for free" styleClass="auth-link" onAction="#goToRegister"/>
                </HBox>
                <VBox.margin><Insets bottom="12"/></VBox.margin>

                <HBox alignment="CENTER">
                    <Button text="← Back to home" styleClass="auth-link-sm" onAction="#goToLanding"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- ─── RIGHT: Marketing Panel ─── -->
        <StackPane styleClass="auth-right-panel" HBox.hgrow="ALWAYS">

            <!-- Background glows -->
            <StackPane styleClass="auth-right-glow" mouseTransparent="true"/>
            <StackPane styleClass="mrkt-orb-tr" mouseTransparent="true" StackPane.alignment="TOP_RIGHT"/>
            <StackPane styleClass="mrkt-orb-bl" mouseTransparent="true" StackPane.alignment="BOTTOM_LEFT"/>

            <!-- Marketing content -->
            <VBox alignment="CENTER" spacing="0" maxWidth="360">
                <padding><Insets top="32" right="40" bottom="32" left="40"/></padding>

                <!-- Badge -->
                <HBox alignment="CENTER">
                    <Label text="★  Rated #1 Student Platform" styleClass="mrkt-pill"/>
                </HBox>
                <VBox.margin><Insets bottom="24"/></VBox.margin>

                <!-- Headline -->
                <Label text="Study Smarter." styleClass="mrkt-h1" maxWidth="Infinity" alignment="CENTER"/>
                <VBox.margin><Insets bottom="2"/></VBox.margin>
                <Label text="Achieve More." styleClass="mrkt-h1 mrkt-h1-purple" maxWidth="Infinity" alignment="CENTER"/>
                <VBox.margin><Insets bottom="14"/></VBox.margin>

                <!-- Subtitle -->
                <Label styleClass="mrkt-sub" wrapText="true" textAlignment="CENTER" maxWidth="300"
                       text="Join 50,000+ students who've transformed their academic life with RLife."/>
                <VBox.margin><Insets bottom="30"/></VBox.margin>

                <!-- Feature cards -->
                <VBox spacing="10">
                    <HBox styleClass="mrkt-card" spacing="14" alignment="CENTER_LEFT">
                        <StackPane styleClass="mrkt-ic mrkt-ic-purple" prefWidth="42" prefHeight="42" minWidth="42" minHeight="42" maxWidth="42" maxHeight="42">
                            <FontIcon iconLiteral="fth-book-open" iconSize="17" styleClass="mrkt-ico"/>
                        </StackPane>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="AI-Powered Notes" styleClass="mrkt-card-title"/>
                            <Label text="Capture and organize content intelligently" styleClass="mrkt-card-sub"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="mrkt-card" spacing="14" alignment="CENTER_LEFT">
                        <StackPane styleClass="mrkt-ic mrkt-ic-blue" prefWidth="42" prefHeight="42" minWidth="42" minHeight="42" maxWidth="42" maxHeight="42">
                            <FontIcon iconLiteral="fth-calendar" iconSize="17" styleClass="mrkt-ico"/>
                        </StackPane>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Smart Scheduling" styleClass="mrkt-card-title"/>
                            <Label text="Never miss a deadline or exam again" styleClass="mrkt-card-sub"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="mrkt-card" spacing="14" alignment="CENTER_LEFT">
                        <StackPane styleClass="mrkt-ic mrkt-ic-pink" prefWidth="42" prefHeight="42" minWidth="42" minHeight="42" maxWidth="42" maxHeight="42">
                            <FontIcon iconLiteral="fth-trending-up" iconSize="17" styleClass="mrkt-ico"/>
                        </StackPane>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Progress Analytics" styleClass="mrkt-card-title"/>
                            <Label text="Visual insights to maximize performance" styleClass="mrkt-card-sub"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="mrkt-card" spacing="14" alignment="CENTER_LEFT">
                        <StackPane styleClass="mrkt-ic mrkt-ic-teal" prefWidth="42" prefHeight="42" minWidth="42" minHeight="42" maxWidth="42" maxHeight="42">
                            <FontIcon iconLiteral="fth-users" iconSize="17" styleClass="mrkt-ico"/>
                        </StackPane>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Collaborate &amp; Connect" styleClass="mrkt-card-title"/>
                            <Label text="Study groups and shared resources" styleClass="mrkt-card-sub"/>
                        </VBox>
                    </HBox>
                </VBox>
                <VBox.margin><Insets bottom="26"/></VBox.margin>

                <!-- Divider -->
                <StackPane styleClass="mrkt-rule" maxWidth="Infinity" minHeight="1" maxHeight="1"/>
                <VBox.margin><Insets bottom="22"/></VBox.margin>

                <!-- Stats -->
                <HBox alignment="CENTER" spacing="0">
                    <VBox alignment="CENTER" spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="50K+" styleClass="mrkt-sn"/>
                        <Label text="Students" styleClass="mrkt-sl"/>
                    </VBox>
                    <StackPane styleClass="mrkt-sep" minWidth="1" maxWidth="1" minHeight="40" maxHeight="40"/>
                    <VBox alignment="CENTER" spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="98%" styleClass="mrkt-sn"/>
                        <Label text="Exam Success" styleClass="mrkt-sl"/>
                    </VBox>
                    <StackPane styleClass="mrkt-sep" minWidth="1" maxWidth="1" minHeight="40" maxHeight="40"/>
                    <VBox alignment="CENTER" spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="4.9 ★" styleClass="mrkt-sn"/>
                        <Label text="Rating" styleClass="mrkt-sl"/>
                    </VBox>
                </HBox>

            </VBox>
        </StackPane>
    </HBox>
</VBox>
