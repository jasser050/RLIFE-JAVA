<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.web.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.LoginController"
      styleClass="app-container">

    <!-- ══════════ TITLE BAR ══════════ -->
    <HBox styleClass="title-bar" alignment="CENTER_LEFT" spacing="0"
          onMousePressed="#onDragStart" onMouseDragged="#onDragged">
        <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
            <padding><Insets left="16"/></padding>
            <StackPane styleClass="title-bar-logo">
                <ImageView fitWidth="18" fitHeight="18" preserveRatio="true">
                    <image>
                        <Image url="@../assets/rlife-logo.png"/>
                    </image>
                </ImageView>
            </StackPane>
            <Label text="RLIFE" styleClass="title-bar-title"/>
            <Label text="—" style="-fx-text-fill: #475569;"/>
            <Label text="Sign In" styleClass="title-bar-subtitle"/>
        </HBox>
        <HBox alignment="CENTER_RIGHT" spacing="0" styleClass="window-controls">
            <Button styleClass="window-btn, minimize-btn" onAction="#minimizeWindow">
                <graphic><FontIcon iconLiteral="fth-minus" iconSize="14"/></graphic>
            </Button>
            <Button styleClass="window-btn, maximize-btn" onAction="#maximizeWindow">
                <graphic><FontIcon iconLiteral="fth-square" iconSize="12"/></graphic>
            </Button>
            <Button styleClass="window-btn, close-btn" onAction="#closeWindow">
                <graphic><FontIcon iconLiteral="fth-x" iconSize="14"/></graphic>
            </Button>
        </HBox>
    </HBox>

    <!-- ══════════ CONTENT ══════════ -->
    <HBox VBox.vgrow="ALWAYS" spacing="0">

        <!-- ─── LEFT: Form ─── -->
        <VBox styleClass="auth-left-panel" HBox.hgrow="SOMETIMES" minWidth="440" maxWidth="480">
            <VBox VBox.vgrow="ALWAYS" alignment="CENTER" spacing="0">
                <padding><Insets top="0" right="48" bottom="0" left="48"/></padding>

                <StackPane styleClass="auth-icon-badge" alignment="CENTER">
                    <ImageView fitWidth="42" fitHeight="42" preserveRatio="true">
                        <image>
                            <Image url="@../assets/rlife-logo.png"/>
                        </image>
                    </ImageView>
                </StackPane>
                <VBox.margin><Insets bottom="22"/></VBox.margin>

                <Label text="Welcome back" styleClass="auth-title"/>
                <VBox.margin><Insets bottom="6"/></VBox.margin>
                <Label text="Sign in to continue your learning journey" styleClass="auth-subtitle"/>
                <VBox.margin><Insets bottom="30"/></VBox.margin>

                <Label fx:id="errorLabel" styleClass="auth-error" managed="false" visible="false"
                       wrapText="true" maxWidth="Infinity"/>
                <VBox.margin><Insets bottom="12"/></VBox.margin>

                <VBox spacing="8">
                    <Label text="Email address" styleClass="auth-field-label"/>
                    <TextField fx:id="emailField" styleClass="auth-field" promptText="you@university.edu"/>
                </VBox>
                <VBox.margin><Insets bottom="20"/></VBox.margin>

                <VBox spacing="8">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Password" styleClass="auth-field-label" HBox.hgrow="ALWAYS"/>
                        <Button text="Forgot password?" styleClass="auth-link" onAction="#forgotPassword"/>
                    </HBox>
                    <PasswordField fx:id="passwordField" styleClass="auth-field" promptText="Enter your password"/>
                </VBox>
                <VBox.margin><Insets bottom="28"/></VBox.margin>

                <Button fx:id="loginBtn" text="Sign In" styleClass="auth-btn-primary"
                        maxWidth="Infinity" onAction="#handleLogin"/>
                <VBox.margin><Insets bottom="24"/></VBox.margin>

                <HBox alignment="CENTER" spacing="12">
                    <Separator HBox.hgrow="ALWAYS"/>
                    <Label text="or" styleClass="auth-divider-text"/>
                    <Separator HBox.hgrow="ALWAYS"/>
                </HBox>
                <VBox.margin><Insets bottom="24"/></VBox.margin>

                <HBox alignment="CENTER" spacing="6">
                    <Label text="Don't have an account?" styleClass="auth-muted-text"/>
                    <Button text="Create one for free" styleClass="auth-link" onAction="#goToRegister"/>
                </HBox>
                <VBox.margin><Insets bottom="12"/></VBox.margin>

                <HBox alignment="CENTER">
                    <Button text="← Back to home" styleClass="auth-link-sm" onAction="#goToLanding"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- ─── RIGHT: Spline 3D Robot ─── -->
        <StackPane styleClass="auth-right-panel" HBox.hgrow="ALWAYS">

            <!-- 3D Robot via WebView -->
            <WebView fx:id="splineView"/>

            <!-- Top badge -->
            <VBox alignment="TOP_CENTER" pickOnBounds="false">
                <padding><Insets top="32"/></padding>
                <Label text="★  Rated #1 Student App Worldwide" styleClass="auth-award-badge"/>
            </VBox>

            <!-- Bottom overlay -->
            <VBox alignment="BOTTOM_CENTER" spacing="14" pickOnBounds="false">
                <padding><Insets bottom="36"/></padding>
                <Label text="Study smarter. Live better." styleClass="auth-right-headline"/>
                <HBox alignment="CENTER" spacing="12">
                    <VBox styleClass="auth-stat-card" alignment="CENTER" spacing="4">
                        <Label text="4.9 ★" styleClass="auth-stat-value"/>
                        <Label text="Rating" styleClass="auth-stat-label"/>
                    </VBox>
                    <VBox styleClass="auth-stat-card" alignment="CENTER" spacing="4">
                        <Label text="98%" styleClass="auth-stat-value"/>
                        <Label text="Exam Success" styleClass="auth-stat-label"/>
                    </VBox>
                    <VBox styleClass="auth-stat-card" alignment="CENTER" spacing="4">
                        <Label text="Free" styleClass="auth-stat-value"/>
                        <Label text="Forever" styleClass="auth-stat-label"/>
                    </VBox>
                </HBox>
            </VBox>

        </StackPane>
    </HBox>
</VBox>
