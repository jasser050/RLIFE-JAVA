<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.AdminProjectsController"
      spacing="20"
      styleClass="page-section">

    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Users And Projects" styleClass="text-heading"/>
            <Label text="Browse RLIFE users and inspect the projects they created." styleClass="text-muted"/>
        </VBox>
        <TextField fx:id="adminSearchField" promptText="Search by user email, name, or project title..." styleClass="search-field" prefWidth="340"/>
    </HBox>

    <HBox spacing="16">
        <VBox styleClass="stat-card, colorful-card, colorful-purple" spacing="16" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, primary" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-users" iconSize="20"/>
                </StackPane>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="People" styleClass="badge, primary"/>
            </HBox>
            <VBox spacing="2">
                <Label fx:id="adminUsersCountLabel" text="0" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                <Label text="Users Listed" styleClass="stat-label"/>
            </VBox>
        </VBox>

        <VBox styleClass="stat-card, colorful-card, colorful-coral" spacing="16" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, accent" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-folder" iconSize="20"/>
                </StackPane>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Registry" styleClass="badge, accent"/>
            </HBox>
            <VBox spacing="2">
                <Label fx:id="adminProjectsCountLabel" text="0" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                <Label text="Projects Tracked" styleClass="stat-label"/>
            </VBox>
        </VBox>
    </HBox>

    <VBox styleClass="card" spacing="14" VBox.vgrow="ALWAYS">
        <HBox styleClass="card-header" alignment="CENTER_LEFT">
            <Label text="User Project Registry" styleClass="card-title" HBox.hgrow="ALWAYS"/>
            <Label text="Grouped by owner" styleClass="card-subtitle"/>
        </HBox>
        <VBox fx:id="adminUsersProjectsList" spacing="12" style="-fx-padding: 14;" VBox.vgrow="ALWAYS"/>
    </VBox>

    <padding>
        <Insets top="0" right="0" bottom="24" left="0"/>
    </padding>
</VBox>
