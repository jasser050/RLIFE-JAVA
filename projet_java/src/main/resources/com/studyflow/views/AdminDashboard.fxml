<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.AdminDashboardController"
      spacing="20"
      styleClass="page-section">

    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Admin Dashboard" styleClass="text-heading"/>
            <Label text="Monitor RLIFE users, projects, and activity from one place." styleClass="text-muted"/>
        </VBox>
        <Label text="ADMIN" styleClass="badge, danger"/>
    </HBox>

    <HBox spacing="16">
        <VBox styleClass="stat-card, colorful-card, colorful-purple" spacing="16" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, primary" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-users" iconSize="20"/>
                </StackPane>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Users" styleClass="badge, primary"/>
            </HBox>
            <VBox spacing="2">
                <Label fx:id="totalUsersLabel" text="0" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                <Label text="Registered Users" styleClass="stat-label"/>
            </VBox>
        </VBox>

        <VBox styleClass="stat-card, colorful-card, colorful-amber" spacing="16" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, warning" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-folder" iconSize="20"/>
                </StackPane>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Projects" styleClass="badge, warning"/>
            </HBox>
            <VBox spacing="2">
                <Label fx:id="totalProjectsLabel" text="0" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                <Label text="All Projects" styleClass="stat-label"/>
            </VBox>
        </VBox>

        <VBox styleClass="stat-card, colorful-card, colorful-green" spacing="16" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, success" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-clipboard" iconSize="20"/>
                </StackPane>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Tasks" styleClass="badge, success"/>
            </HBox>
            <VBox spacing="2">
                <Label fx:id="totalAssignmentsLabel" text="0" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                <Label text="All Assignments" styleClass="stat-label"/>
            </VBox>
        </VBox>

        <VBox styleClass="stat-card, colorful-card, colorful-coral" spacing="16" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, accent" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-send" iconSize="20"/>
                </StackPane>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Shares" styleClass="badge, accent"/>
            </HBox>
            <VBox spacing="2">
                <Label fx:id="sharedProjectsLabel" text="0" styleClass="stat-value" style="-fx-font-size: 24px;"/>
                <Label text="Project Shares" styleClass="stat-label"/>
            </VBox>
        </VBox>
    </HBox>

    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <VBox styleClass="card" spacing="14" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
            <HBox styleClass="card-header" alignment="CENTER_LEFT">
                <Label text="Recent Projects" styleClass="card-title" HBox.hgrow="ALWAYS"/>
                <Label text="Latest activity across RLIFE" styleClass="card-subtitle"/>
            </HBox>
            <VBox fx:id="recentProjectsList" spacing="10" style="-fx-padding: 14;" VBox.vgrow="ALWAYS"/>
        </VBox>

        <VBox styleClass="card" spacing="14" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
            <HBox styleClass="card-header" alignment="CENTER_LEFT">
                <Label text="Highlighted Users" styleClass="card-title" HBox.hgrow="ALWAYS"/>
                <Label text="Quick ownership snapshot" styleClass="card-subtitle"/>
            </HBox>
            <VBox fx:id="highlightedUsersList" spacing="10" style="-fx-padding: 14;" VBox.vgrow="ALWAYS"/>
        </VBox>
    </HBox>

    <padding>
        <Insets top="0" right="0" bottom="24" left="0"/>
    </padding>
</VBox>
