<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.AssignmentsController"
      spacing="22"
      styleClass="page-section">

    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Assignments Board" styleClass="text-heading"/>
            <Label text="Track work clearly, move cards between stages, and open editing in a dedicated page."
                   styleClass="text-muted" wrapText="true"/>
        </VBox>
        <HBox spacing="12">
            <Button text="Statistics" onAction="#handleOpenStatsPage" styleClass="btn-secondary">
                <graphic>
                    <FontIcon iconLiteral="fth-bar-chart-2" iconSize="16"/>
                </graphic>
            </Button>
        </HBox>
    </HBox>

    <Label fx:id="feedbackLabel" managed="false" visible="false"
           maxWidth="Infinity" styleClass="inline-alert, inline-alert-success"/>

    <HBox spacing="16">
        <VBox styleClass="stat-card, stat-card-primary" spacing="8" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, primary" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-layout" iconSize="18"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="totalAssignmentsLabel" text="0" styleClass="stat-value"/>
                    <Label text="Visible Assignments" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, warning" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-clock" iconSize="18"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="todoSummaryLabel" text="0" styleClass="stat-value"/>
                    <Label text="To Do" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, accent" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-loader" iconSize="18"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="progressSummaryLabel" text="0" styleClass="stat-value"/>
                    <Label text="In Progress" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, success" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-check-circle" iconSize="18"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="completedSummaryLabel" text="0" styleClass="stat-value"/>
                    <Label text="Completed" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card, stat-card-danger" spacing="8" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="stat-icon-box, danger" prefWidth="40" prefHeight="40">
                    <FontIcon iconLiteral="fth-alert-circle" iconSize="18"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="overdueSummaryLabel" text="0" styleClass="stat-value"/>
                    <Label text="Overdue" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <VBox spacing="16" prefWidth="272" minWidth="248">
            <VBox styleClass="card" spacing="0" VBox.vgrow="ALWAYS">
                <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="10">
                    <FontIcon iconLiteral="fth-plus-circle" iconSize="16" styleClass="detail-row-icon"/>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Quick Add" styleClass="card-title"/>
                        <Label text="Compact draft panel, styled like the rest of the app."
                               styleClass="text-small" wrapText="true"/>
                    </VBox>
                </HBox>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="transparent-scroll">
                    <VBox styleClass="card-body" spacing="12">
                        <VBox spacing="4">
                            <Label text="TITLE" styleClass="form-label"/>
                            <TextField fx:id="createAssignmentTitleField" styleClass="form-input"
                                       promptText="Assignment title"/>
                            <Label fx:id="createAssignmentTitleError" styleClass="field-error"
                                   visible="false" managed="false"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="PROJECT" styleClass="form-label"/>
                            <ComboBox fx:id="createAssignmentProjectCombo" styleClass="form-combo"
                                      maxWidth="Infinity"/>
                            <Label fx:id="createAssignmentProjectError" styleClass="field-error"
                                   visible="false" managed="false"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="COLUMN" styleClass="form-label"/>
                            <ComboBox fx:id="createAssignmentStatusCombo" styleClass="form-combo"
                                      maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="PRIORITY" styleClass="form-label"/>
                            <ComboBox fx:id="createAssignmentPriorityCombo" styleClass="form-combo"
                                      maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="START DATE" styleClass="form-label"/>
                            <DatePicker fx:id="createAssignmentStartDatePicker" styleClass="form-date"
                                        maxWidth="Infinity"/>
                            <Label fx:id="createAssignmentStartDateError" styleClass="field-error"
                                   visible="false" managed="false"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="END DATE" styleClass="form-label"/>
                            <DatePicker fx:id="createAssignmentEndDatePicker" styleClass="form-date"
                                        maxWidth="Infinity"/>
                            <Label fx:id="createAssignmentEndDateError" styleClass="field-error"
                                   visible="false" managed="false"/>
                        </VBox>
                        <VBox spacing="4">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="DESCRIPTION" styleClass="form-label" HBox.hgrow="ALWAYS"/>
                                <Label fx:id="createDescriptionCountLabel" text="0/500" styleClass="text-small"/>
                            </HBox>
                            <TextArea fx:id="createAssignmentDescriptionArea" styleClass="form-textarea"
                                      wrapText="true" prefRowCount="3"
                                      promptText="Short description"/>
                        </VBox>
                        <Button text="Create Assignment" onAction="#handleCreateAssignment"
                                styleClass="btn-primary" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fth-plus-circle" iconSize="16" iconColor="white"/>
                            </graphic>
                        </Button>
                    </VBox>
                </ScrollPane>
            </VBox>

            <VBox styleClass="card, colorful-card, colorful-purple" spacing="0">
                <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="8">
                    <FontIcon iconLiteral="fth-info" iconSize="16" styleClass="detail-row-icon"/>
                    <Label text="Workflow" styleClass="card-title"/>
                </HBox>
                <VBox styleClass="card-body" spacing="8">
                    <Label text="1. Add a compact draft here." styleClass="text-small" wrapText="true"/>
                    <Label text="2. Drag cards between columns to update status." styleClass="text-small" wrapText="true"/>
                    <Label text="3. Use Edit on an owned card for the full editing page." styleClass="text-small" wrapText="true"/>
                </VBox>
            </VBox>
        </VBox>

        <VBox spacing="14" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <TextField fx:id="assignmentSearchField" promptText="Search assignments, projects, owners..."
                           styleClass="search-field" prefWidth="320"/>
                <ComboBox fx:id="assignmentSortCombo" prefWidth="180" styleClass="form-combo"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox alignment="CENTER_LEFT">
                <Label text="Select a card for sharing and comments. Owned cards open in a separate editor."
                       styleClass="text-muted" wrapText="true"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="taskCountLabel" text="0 visible assignments" styleClass="text-muted"/>
            </HBox>

            <HBox spacing="14" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                <VBox styleClass="card, board-column" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                    <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="8">
                        <Label text="To Do" styleClass="card-title"/>
                        <Label fx:id="todoCountLabel" text="0" styleClass="badge, secondary"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Add" onAction="#handlePrepareTodoCard" styleClass="btn-ghost"/>
                    </HBox>
                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="transparent-scroll">
                        <VBox fx:id="todoColumn" spacing="10" style="-fx-padding: 14;"/>
                    </ScrollPane>
                </VBox>

                <VBox styleClass="card, board-column" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                    <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="8">
                        <Label text="In Progress" styleClass="card-title"/>
                        <Label fx:id="progressCountLabel" text="0" styleClass="badge, primary"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Add" onAction="#handlePrepareProgressCard" styleClass="btn-ghost"/>
                    </HBox>
                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="transparent-scroll">
                        <VBox fx:id="progressColumn" spacing="10" style="-fx-padding: 14;"/>
                    </ScrollPane>
                </VBox>

                <VBox styleClass="card, board-column" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                    <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="8">
                        <Label text="Completed" styleClass="card-title"/>
                        <Label fx:id="completedCountLabel" text="0" styleClass="badge, success"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Add" onAction="#handlePrepareDoneCard" styleClass="btn-ghost"/>
                    </HBox>
                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="transparent-scroll">
                        <VBox fx:id="completedColumn" spacing="10" style="-fx-padding: 14;"/>
                    </ScrollPane>
                </VBox>
            </HBox>
        </VBox>

        <VBox spacing="14" prefWidth="300" minWidth="272">
            <VBox styleClass="card, colorful-card, colorful-coral" spacing="0">
                <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="8">
                    <VBox HBox.hgrow="ALWAYS" spacing="4">
                        <Label fx:id="selectedAssignmentTitleLabel" text="No assignment selected"
                               styleClass="card-title" wrapText="true"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label fx:id="selectedAssignmentStatusLabel" text="--"
                                   styleClass="badge, secondary"/>
                            <Label fx:id="selectedAssignmentOwnerLabel" text="--"
                                   styleClass="text-small"/>
                        </HBox>
                    </VBox>
                    <Button onAction="#handleClearSelection" styleClass="btn-ghost">
                        <graphic>
                            <FontIcon iconLiteral="fth-x" iconSize="14"/>
                        </graphic>
                    </Button>
                </HBox>
                <VBox styleClass="card-body" spacing="10">
                    <Label fx:id="selectedAssignmentMetaLabel"
                           text="Click a card on the board to share it or leave a comment."
                           styleClass="text-muted" wrapText="true"/>
                    <Button fx:id="openEditorButton" text="Open Separate Editor" onAction="#handleOpenSelectedAssignmentEditor"
                            styleClass="action-outline-button" maxWidth="Infinity" disable="true">
                        <graphic>
                            <FontIcon iconLiteral="fth-edit-2" iconSize="16"/>
                        </graphic>
                    </Button>
                </VBox>
            </VBox>

            <VBox styleClass="card" spacing="0">
                <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="10">
                    <FontIcon iconLiteral="fth-share-2" iconSize="16" styleClass="detail-row-icon"/>
                    <Label text="Share Assignment" styleClass="card-title"/>
                </HBox>
                <VBox styleClass="card-body" spacing="10">
                    <Label fx:id="shareHintLabel"
                           text="Select a card to share it by username or email."
                           styleClass="text-small" wrapText="true"/>
                    <TextField fx:id="shareEmailField" styleClass="form-input"
                               promptText="username or email"/>
                    <Button fx:id="shareButton" text="Share" onAction="#handleShareAssignment"
                            styleClass="btn-secondary" maxWidth="Infinity" disable="true"/>
                </VBox>
            </VBox>

            <VBox styleClass="card" spacing="0" VBox.vgrow="ALWAYS">
                <HBox styleClass="card-header" alignment="CENTER_LEFT" spacing="10">
                    <FontIcon iconLiteral="fth-message-circle" iconSize="16" styleClass="detail-row-icon"/>
                    <Label text="Comments" styleClass="card-title" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="commentCountLabel" text="0 comments" styleClass="text-small"/>
                </HBox>
                <VBox styleClass="card-body" spacing="12" VBox.vgrow="ALWAYS">
                    <ScrollPane fitToWidth="true" prefHeight="200" styleClass="transparent-scroll">
                        <VBox fx:id="commentsList" spacing="8"/>
                    </ScrollPane>
                    <TextArea fx:id="newCommentArea" styleClass="form-textarea" wrapText="true"
                              prefRowCount="3" promptText="Write a comment..." disable="true"/>
                    <Button fx:id="addCommentButton" text="Add Comment"
                            onAction="#handleAddComment" styleClass="btn-primary"
                            maxWidth="Infinity" disable="true"/>
                </VBox>
            </VBox>
        </VBox>
    </HBox>

    <padding>
        <Insets top="0" right="0" bottom="24" left="0"/>
    </padding>
</VBox>
