<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.studyflow.controllers.PresentationStudioController"
      style="-fx-background-color:#0F0F1A;"
      spacing="0">

    <!-- TOP BAR -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color:#13131F;
                 -fx-border-color:rgba(127,119,221,0.25);
                 -fx-border-width:0 0 1 0;
                 -fx-padding:0 16 0 16;">
        <Label text="★" style="-fx-text-fill:#7F77DD;-fx-font-size:18px;-fx-font-weight:800;"/>
        <Label text="Presentation Studio"
               style="-fx-text-fill:#F8FAFC;-fx-font-size:15px;-fx-font-weight:800;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="closeBtn" text="✕ Fermer" onAction="#closeStudio"
                style="-fx-background-color:rgba(127,119,221,0.12);
                       -fx-border-color:rgba(127,119,221,0.25);
                       -fx-border-radius:8;-fx-background-radius:8;
                       -fx-text-fill:#F8FAFC;-fx-font-size:12px;
                       -fx-font-weight:700;-fx-cursor:hand;
                       -fx-padding:8 16;-fx-margin:8 0;">
        </Button>
    </HBox>

    <!-- WEBVIEW — le vrai éditeur HTML Canva-like -->
    <WebView fx:id="webView" VBox.vgrow="ALWAYS"/>

</VBox>
