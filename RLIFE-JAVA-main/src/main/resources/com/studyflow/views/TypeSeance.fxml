<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox fillWidth="true" maxWidth="1.7976931348623157E308" spacing="24" styleClass="planning-root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.studyflow.controllers.TypeSeanceController">

	<padding>
		<Insets bottom="24" left="0" right="0" top="0" />
	</padding>

	<HBox alignment="CENTER_LEFT" spacing="16">
		<VBox spacing="4">
			<Label styleClass="text-heading" text="Session Types" />
			<Label styleClass="text-muted" text="Manage your custom session types" />
		</VBox>
		<Region HBox.hgrow="ALWAYS" />
		<Label fx:id="typesCountLabel" styleClass="text-muted" text="0 types" />
		<Button onAction="#handleBackToPlanning" styleClass="btn-secondary" text="Back to Planning">
			<graphic>
				<FontIcon iconLiteral="fth-arrow-left" iconSize="16" />
			</graphic>
		</Button>
		<Button onAction="#handleAddType" styleClass="btn-primary" text="Add Type">
			<graphic>
				<FontIcon iconColor="white" iconLiteral="fth-plus" iconSize="16" />
			</graphic>
		</Button>
	</HBox>

	<Label fx:id="pageMessageLabel" managed="false" visible="false" />

	<VBox fx:id="formCard" managed="false" spacing="0" styleClass="card" visible="false">
		<HBox alignment="CENTER_LEFT" spacing="12" styleClass="card-header">
			<StackPane prefHeight="36" prefWidth="36" styleClass="stat-icon-box, accent">
				<FontIcon iconLiteral="fth-edit-3" iconSize="16" />
			</StackPane>
			<VBox spacing="2" HBox.hgrow="ALWAYS">
				<Label fx:id="formTitleLabel" styleClass="card-title" text="Add Type" />
				<Label styleClass="text-small" text="Create or update a session type without popup" />
			</VBox>
		</HBox>

		<VBox spacing="18" styleClass="card-body">
			<GridPane hgap="16" vgap="12">
				<columnConstraints>
					<ColumnConstraints minWidth="120" />
					<ColumnConstraints hgrow="ALWAYS" />
				</columnConstraints>

				<Label styleClass="text-body" text="Type Name" GridPane.columnIndex="0" GridPane.rowIndex="0" />
				<VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
					<TextField fx:id="typeNameField" maxWidth="1.7976931348623157E308" promptText="Enter type name" />
					<Label styleClass="session-field-tip" text="Tip: letters only. Spaces, '_' and '-' are allowed." />
					<Label fx:id="typeNameErrorLabel" managed="false" styleClass="session-field-error" visible="false" />
				</VBox>
			</GridPane>

			<HBox alignment="CENTER_RIGHT" spacing="10">
				<Button onAction="#handleCancelType" styleClass="btn-secondary" text="Cancel" />
				<Button onAction="#handleSaveType" styleClass="btn-primary" text="Save Type">
					<graphic>
						<FontIcon iconColor="white" iconLiteral="fth-save" iconSize="16" />
					</graphic>
				</Button>
			</HBox>
		</VBox>
	</VBox>

	<VBox fx:id="listCard" maxWidth="1.7976931348623157E308" spacing="0" styleClass="card" VBox.vgrow="ALWAYS">
		<HBox alignment="CENTER_LEFT" spacing="12" styleClass="card-header">
			<StackPane prefHeight="36" prefWidth="36" styleClass="stat-icon-box, primary">
				<FontIcon iconLiteral="fth-list" iconSize="16" />
			</StackPane>
			<VBox spacing="2">
				<Label styleClass="card-title" text="Types List" />
				<Label styleClass="text-small" text="Edit and delete your saved types" />
			</VBox>
		</HBox>

		<ListView fx:id="typesListView" styleClass="sessions-list-view planning-list-view" VBox.vgrow="ALWAYS" />
	</VBox>
</VBox>

